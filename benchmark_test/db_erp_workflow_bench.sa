    EXPAND DB_FILTER_U64_I64_PAIR_KEY1_HANDLE paid_count_status, paid_count_written, paid_invoice_count, result_rows, RESULT_ROWS_CAP, invoices_handle, 2, 3, invoice_paid_id, 0, RESULT_ROWS_CAP
    t_due1 = call @sa_time_instant_ns()
