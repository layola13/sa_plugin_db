@import "db.sal"
@import "sa_std/fmt.sai"
@import "sa_std/io/print.sai"
@import "sa_std/time.sai"

@const ROOT = utf8:"."
@const TABLE_CUSTOMERS = utf8:"erp_customers"
@const TABLE_PRODUCTS = utf8:"erp_products"
@const TABLE_ORDERS = utf8:"erp_orders"
@const TABLE_LINES = utf8:"erp_order_lines"
@const TABLE_INVENTORY = utf8:"erp_inventory"
@const TABLE_INVOICES = utf8:"erp_invoices"
@const CUSTOMERS_SCHEMA_PATH = utf8:"erp_customers.sadb-schema"
@const PRODUCTS_SCHEMA_PATH = utf8:"erp_products.sadb-schema"
@const ORDERS_SCHEMA_PATH = utf8:"erp_orders.sadb-schema"
@const LINES_SCHEMA_PATH = utf8:"erp_order_lines.sadb-schema"
@const INVENTORY_SCHEMA_PATH = utf8:"erp_inventory.sadb-schema"
@const INVOICES_SCHEMA_PATH = utf8:"erp_invoices.sadb-schema"

@const CUSTOMERS_SCHEMA = utf8:"#def MAX_ROWS = 1024\n#def COL_ID_STRIDE = 8 // u64\n#def COL_TIER_STRIDE = 8 // u64\n#def COL_CREDIT_CENTS_STRIDE = 8 // i64 decimal(2)\n"
@const PRODUCTS_SCHEMA = utf8:"#def MAX_ROWS = 512\n#def COL_ID_STRIDE = 8 // u64\n#def COL_CATEGORY_STRIDE = 8 // u64\n#def COL_PRICE_CENTS_STRIDE = 8 // i64 decimal(2)\n"
@const ORDERS_SCHEMA = utf8:"#def MAX_ROWS = 8192\n#def COL_ID_STRIDE = 8 // u64\n#def COL_CUSTOMER_ID_STRIDE = 8 // u64\n#def COL_STATUS_STRIDE = 8 // u64\n#def COL_ORDER_DAY_STRIDE = 8 // i64 date\n"
@const LINES_SCHEMA = utf8:"#def MAX_ROWS = 32768\n#def COL_ORDER_ID_STRIDE = 8 // u64\n#def COL_LINE_NO_STRIDE = 8 // u64\n#def COL_PRODUCT_ID_STRIDE = 8 // u64\n#def COL_QTY_STRIDE = 8 // u64\n#def COL_NET_CENTS_STRIDE = 8 // i64 decimal(2)\n"
@const INVENTORY_SCHEMA = utf8:"#def MAX_ROWS = 16384\n#def COL_PRODUCT_ID_STRIDE = 8 // u64\n#def COL_MOVE_SEQ_STRIDE = 8 // u64\n#def COL_QTY_DELTA_STRIDE = 8 // i64\n"
@const INVOICES_SCHEMA = utf8:"#def MAX_ROWS = 8192\n#def COL_ID_STRIDE = 8 // u64\n#def COL_ORDER_ID_STRIDE = 8 // u64\n#def COL_STATUS_STRIDE = 8 // u64\n#def COL_DUE_DAY_STRIDE = 8 // i64 date\n#def COL_AMOUNT_CENTS_STRIDE = 8 // i64 decimal(2)\n"

@const ORDER_STATUS_DICT = utf8:"order_status"
@const INVOICE_STATUS_DICT = utf8:"invoice_status"
@const STATUS_OPEN = utf8:"open"
@const STATUS_POSTED = utf8:"posted"
@const STATUS_PAID = utf8:"paid"
@const STATUS_UNPAID = utf8:"unpaid"
@const NL = utf8:"\n"

@const ERP_INIT = utf8:"db_erp_init_ns="
@const ERP_PREPARE = utf8:"db_erp_prepare_ns="
@const ERP_INGEST = utf8:"db_erp_ingest_ns="
@const ERP_INDEX = utf8:"db_erp_index_ns="
@const ERP_ORDER_LINES = utf8:"db_erp_order_lines_ns="
@const ERP_CUSTOMER_ORDERS = utf8:"db_erp_customer_orders_ns="
@const ERP_DUE_INVOICES = utf8:"db_erp_due_invoices_ns="
@const ERP_INVENTORY = utf8:"db_erp_inventory_ns="
@const ERP_PROJECT = utf8:"db_erp_project_ns="
@const ERP_VERIFY = utf8:"db_erp_verify_ns="
@const ORDER_LINE_TOTAL = utf8:"order_line_total="
@const CUSTOMER_ORDER_TOTAL = utf8:"customer_order_total="
@const DUE_INVOICE_TOTAL = utf8:"due_invoice_total="
@const INVENTORY_MOVE_TOTAL = utf8:"inventory_move_total="
@const PROJECT_WRITTEN_ROWS = utf8:"project_written_rows="
@const PAID_INVOICE_COUNT = utf8:"paid_invoice_count="

#def ROOT_LEN = 1
#def TABLE_CUSTOMERS_LEN = 13
#def TABLE_PRODUCTS_LEN = 12
#def TABLE_ORDERS_LEN = 10
#def TABLE_LINES_LEN = 15
#def TABLE_INVENTORY_LEN = 13
#def TABLE_INVOICES_LEN = 12
#def CUSTOMERS_SCHEMA_PATH_LEN = 25
#def PRODUCTS_SCHEMA_PATH_LEN = 24
#def ORDERS_SCHEMA_PATH_LEN = 22
#def LINES_SCHEMA_PATH_LEN = 27
#def INVENTORY_SCHEMA_PATH_LEN = 25
#def INVOICES_SCHEMA_PATH_LEN = 24
#def CUSTOMERS_SCHEMA_LEN = 134
#def PRODUCTS_SCHEMA_LEN = 136
#def ORDERS_SCHEMA_LEN = 166
#def LINES_SCHEMA_LEN = 210
#def INVENTORY_SCHEMA_LEN = 133
#def INVOICES_SCHEMA_LEN = 212
#def ORDER_STATUS_DICT_LEN = 12
#def INVOICE_STATUS_DICT_LEN = 14
#def STATUS_OPEN_LEN = 4
#def STATUS_POSTED_LEN = 6
#def STATUS_PAID_LEN = 4
#def STATUS_UNPAID_LEN = 6

#def CUSTOMER_ROWS = 1024
#def PRODUCT_ROWS = 512
#def ORDER_ROWS = 8192
#def LINE_ROWS = 32768
#def INVENTORY_ROWS = 16384
#def INVOICE_ROWS = 8192
#def CUSTOMER_COL_BYTES = 8192
#def PRODUCT_COL_BYTES = 4096
#def ORDER_COL_BYTES = 65536
#def LINE_COL_BYTES = 262144
#def INVENTORY_COL_BYTES = 131072
#def INVOICE_COL_BYTES = 65536
#def MAX_COLUMNS_BYTES = 80
#def RESULT_ROWS_CAP = 64
#def RESULT_ROWS_BYTES = 512
#def PROJECT_COLUMNS = 3
#def PROJECT_COLUMNS_BYTES = 24
#def PROJECT_BYTES = 96
#def FMT_BUF_BYTES = 32

#def TARGET_CUSTOMER = 17
#def TARGET_ORDER = 1234
#def TARGET_ORDER_FIRST_LINE_ROW = 4932
#def TARGET_PRODUCT = 42
#def EXPECTED_CUSTOMER_ORDERS = 8
#def EXPECTED_ORDER_LINES = 4
#def EXPECTED_INVENTORY_MOVES = 32
#def EXPECTED_DUE_INVOICES = 640
#def EXPECTED_PAID_INVOICES = 4096

#def ERP_INIT_LEN = 15
#def ERP_PREPARE_LEN = 18
#def ERP_INGEST_LEN = 17
#def ERP_INDEX_LEN = 16
#def ERP_ORDER_LINES_LEN = 22
#def ERP_CUSTOMER_ORDERS_LEN = 26
#def ERP_DUE_INVOICES_LEN = 23
#def ERP_INVENTORY_LEN = 20
#def ERP_PROJECT_LEN = 18
#def ERP_VERIFY_LEN = 17
#def ORDER_LINE_TOTAL_LEN = 17
#def CUSTOMER_ORDER_TOTAL_LEN = 21
#def DUE_INVOICE_TOTAL_LEN = 18
#def INVENTORY_MOVE_TOTAL_LEN = 21
#def PROJECT_WRITTEN_ROWS_LEN = 21
#def PAID_INVOICE_COUNT_LEN = 19

[MACRO] PRINT_U64_LINE %label, %label_len, %value
    __fmt_buf_%value = stack_alloc FMT_BUF_BYTES
    __fmt_len_slot_%value = stack_alloc 8
    __fmt_status_%value = call @sa_fmt_u64_into(%value, 10, __fmt_buf_%value, FMT_BUF_BYTES, &__fmt_len_slot_%value)
    __fmt_len_%value = load __fmt_len_slot_%value+0 as u64
    call @sa_print_bytes(&%label, %label_len)
    call @sa_print_bytes(&__fmt_buf_%value, __fmt_len_%value)
    call @sa_print_bytes(&NL, 1)
    !__fmt_status_%value
    !__fmt_len_%value
[END_MACRO]

@fill_customer_columns(&id_col: ptr, &tier_col: ptr, &credit_col: ptr) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, CUSTOMER_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    id_ptr = ptr_add id_col, off
    tier_ptr = ptr_add tier_col, off
    credit_ptr = ptr_add credit_col, off
    id_value = add i, 1
    tier_low = and i, 3
    tier_value = add tier_low, 1
    credit_value = mul id_value, 100
    store id_ptr+0, id_value as u64
    store tier_ptr+0, tier_value as u64
    store credit_ptr+0, credit_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !id_ptr
    !tier_ptr
    !credit_ptr
    !id_value
    !tier_low
    !tier_value
    !credit_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !id_col
    !tier_col
    !credit_col
    return 0

@fill_product_columns(&id_col: ptr, &category_col: ptr, &price_col: ptr) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, PRODUCT_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    id_ptr = ptr_add id_col, off
    category_ptr = ptr_add category_col, off
    price_ptr = ptr_add price_col, off
    id_value = add i, 1
    category_low = and i, 15
    category_value = add category_low, 1
    price_low = and i, 31
    price_units = add price_low, 1
    price_value = mul price_units, 125
    store id_ptr+0, id_value as u64
    store category_ptr+0, category_value as u64
    store price_ptr+0, price_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !id_ptr
    !category_ptr
    !price_ptr
    !id_value
    !category_low
    !category_value
    !price_low
    !price_units
    !price_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !id_col
    !category_col
    !price_col
    return 0

@fill_order_columns(&id_col: ptr, &customer_col: ptr, &status_col: ptr, &day_col: ptr, open_status_id: u64, posted_status_id: u64, base_day: i64) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, ORDER_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    id_ptr = ptr_add id_col, off
    customer_ptr = ptr_add customer_col, off
    status_ptr = ptr_add status_col, off
    day_ptr = ptr_add day_col, off
    id_value = add i, 1
    customer_low = and i, 1023
    customer_value = add customer_low, 1
    status_bit = and i, 1
    status_value = add open_status_id, status_bit
    day_offset = and i, 63
    day_value = add base_day, day_offset
    store id_ptr+0, id_value as u64
    store customer_ptr+0, customer_value as u64
    store status_ptr+0, status_value as u64
    store day_ptr+0, day_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !id_ptr
    !customer_ptr
    !status_ptr
    !day_ptr
    !id_value
    !customer_low
    !customer_value
    !status_bit
    !status_value
    !day_offset
    !day_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !id_col
    !customer_col
    !status_col
    !day_col
    !open_status_id
    !posted_status_id
    !base_day
    return 0

@fill_line_columns(&order_col: ptr, &line_col: ptr, &product_col: ptr, &qty_col: ptr, &net_col: ptr) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, LINE_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    order_ptr = ptr_add order_col, off
    line_ptr = ptr_add line_col, off
    product_ptr = ptr_add product_col, off
    qty_ptr = ptr_add qty_col, off
    net_ptr = ptr_add net_col, off
    order_base = lshr i, 2
    order_value = add order_base, 1
    line_low = and i, 3
    line_value = add line_low, 1
    product_low = and i, 511
    product_value = add product_low, 1
    qty_low = and i, 7
    qty_value = add qty_low, 1
    net_value = mul qty_value, 250
    store order_ptr+0, order_value as u64
    store line_ptr+0, line_value as u64
    store product_ptr+0, product_value as u64
    store qty_ptr+0, qty_value as u64
    store net_ptr+0, net_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !order_ptr
    !line_ptr
    !product_ptr
    !qty_ptr
    !net_ptr
    !order_base
    !order_value
    !line_low
    !line_value
    !product_low
    !product_value
    !qty_low
    !qty_value
    !net_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !order_col
    !line_col
    !product_col
    !qty_col
    !net_col
    return 0

@fill_inventory_columns(&product_col: ptr, &seq_col: ptr, &qty_delta_col: ptr) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, INVENTORY_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    product_ptr = ptr_add product_col, off
    seq_ptr = ptr_add seq_col, off
    qty_ptr = ptr_add qty_delta_col, off
    product_low = and i, 511
    product_value = add product_low, 1
    seq_base = lshr i, 9
    seq_value = add seq_base, 1
    qty_low = and i, 1
    qty_value = add qty_low, 4
    store product_ptr+0, product_value as u64
    store seq_ptr+0, seq_value as u64
    store qty_ptr+0, qty_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !product_ptr
    !seq_ptr
    !qty_ptr
    !product_low
    !product_value
    !seq_base
    !seq_value
    !qty_low
    !qty_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !product_col
    !seq_col
    !qty_delta_col
    return 0

@fill_invoice_columns(&id_col: ptr, &order_col: ptr, &status_col: ptr, &due_col: ptr, &amount_col: ptr, paid_status_id: u64, unpaid_status_id: u64, base_day: i64) -> i32:
L_ENTRY:
    i_slot = stack_alloc 8
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, INVOICE_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    off = shl i, 3
    id_ptr = ptr_add id_col, off
    order_ptr = ptr_add order_col, off
    status_ptr = ptr_add status_col, off
    due_ptr = ptr_add due_col, off
    amount_ptr = ptr_add amount_col, off
    id_value = add i, 1
    order_value = add i, 1
    paid_bit = and i, 1
    status_value = add paid_status_id, paid_bit
    due_offset = and i, 63
    due_value = add base_day, due_offset
    amount_value = mul id_value, 100
    store id_ptr+0, id_value as u64
    store order_ptr+0, order_value as u64
    store status_ptr+0, status_value as u64
    store due_ptr+0, due_value as i64
    store amount_ptr+0, amount_value as i64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !cond
    !off
    !id_ptr
    !order_ptr
    !status_ptr
    !due_ptr
    !amount_ptr
    !id_value
    !order_value
    !paid_bit
    !status_value
    !due_offset
    !due_value
    !amount_value
    !next_i
    jmp L_COND

L_DONE:
    !i
    !cond
    !id_col
    !order_col
    !status_col
    !due_col
    !amount_col
    !paid_status_id
    !unpaid_status_id
    !base_day
    return 0

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    cust_columns = stack_alloc MAX_COLUMNS_BYTES
    prod_columns = stack_alloc MAX_COLUMNS_BYTES
    order_columns = stack_alloc MAX_COLUMNS_BYTES
    line_columns = stack_alloc MAX_COLUMNS_BYTES
    inventory_columns = stack_alloc MAX_COLUMNS_BYTES
    invoice_columns = stack_alloc MAX_COLUMNS_BYTES
    result_rows = alloc RESULT_ROWS_BYTES
    project_columns = alloc PROJECT_COLUMNS_BYTES
    project_bytes = alloc PROJECT_BYTES

    cust_id_col = alloc CUSTOMER_COL_BYTES
    cust_tier_col = alloc CUSTOMER_COL_BYTES
    cust_credit_col = alloc CUSTOMER_COL_BYTES
    prod_id_col = alloc PRODUCT_COL_BYTES
    prod_category_col = alloc PRODUCT_COL_BYTES
    prod_price_col = alloc PRODUCT_COL_BYTES
    order_id_col = alloc ORDER_COL_BYTES
    order_customer_col = alloc ORDER_COL_BYTES
    order_status_col = alloc ORDER_COL_BYTES
    order_day_col = alloc ORDER_COL_BYTES
    line_order_col = alloc LINE_COL_BYTES
    line_no_col = alloc LINE_COL_BYTES
    line_product_col = alloc LINE_COL_BYTES
    line_qty_col = alloc LINE_COL_BYTES
    line_net_col = alloc LINE_COL_BYTES
    inventory_product_col = alloc INVENTORY_COL_BYTES
    inventory_seq_col = alloc INVENTORY_COL_BYTES
    inventory_qty_col = alloc INVENTORY_COL_BYTES
    invoice_id_col = alloc INVOICE_COL_BYTES
    invoice_order_col = alloc INVOICE_COL_BYTES
    invoice_status_col = alloc INVOICE_COL_BYTES
    invoice_due_col = alloc INVOICE_COL_BYTES
    invoice_amount_col = alloc INVOICE_COL_BYTES

    store project_columns+0, 2 as u64
    store project_columns+8, 3 as u64
    store project_columns+16, 4 as u64

    t_init0 = call @sa_time_instant_ns()
    EXPAND DB_REMOVE_TABLE remove_customers_status, ROOT, ROOT_LEN, TABLE_CUSTOMERS, TABLE_CUSTOMERS_LEN, info
    EXPAND DB_REMOVE_TABLE remove_products_status, ROOT, ROOT_LEN, TABLE_PRODUCTS, TABLE_PRODUCTS_LEN, info
    EXPAND DB_REMOVE_TABLE remove_orders_status, ROOT, ROOT_LEN, TABLE_ORDERS, TABLE_ORDERS_LEN, info
    EXPAND DB_REMOVE_TABLE remove_lines_status, ROOT, ROOT_LEN, TABLE_LINES, TABLE_LINES_LEN, info
    EXPAND DB_REMOVE_TABLE remove_inventory_status, ROOT, ROOT_LEN, TABLE_INVENTORY, TABLE_INVENTORY_LEN, info
    EXPAND DB_REMOVE_TABLE remove_invoices_status, ROOT, ROOT_LEN, TABLE_INVOICES, TABLE_INVOICES_LEN, info
    EXPAND DB_INIT_SCHEMA init_customers_status, ROOT, ROOT_LEN, CUSTOMERS_SCHEMA_PATH, CUSTOMERS_SCHEMA_PATH_LEN, CUSTOMERS_SCHEMA, CUSTOMERS_SCHEMA_LEN, info
    EXPAND DB_INIT_SCHEMA init_products_status, ROOT, ROOT_LEN, PRODUCTS_SCHEMA_PATH, PRODUCTS_SCHEMA_PATH_LEN, PRODUCTS_SCHEMA, PRODUCTS_SCHEMA_LEN, info
    EXPAND DB_INIT_SCHEMA init_orders_status, ROOT, ROOT_LEN, ORDERS_SCHEMA_PATH, ORDERS_SCHEMA_PATH_LEN, ORDERS_SCHEMA, ORDERS_SCHEMA_LEN, info
    EXPAND DB_INIT_SCHEMA init_lines_status, ROOT, ROOT_LEN, LINES_SCHEMA_PATH, LINES_SCHEMA_PATH_LEN, LINES_SCHEMA, LINES_SCHEMA_LEN, info
    EXPAND DB_INIT_SCHEMA init_inventory_status, ROOT, ROOT_LEN, INVENTORY_SCHEMA_PATH, INVENTORY_SCHEMA_PATH_LEN, INVENTORY_SCHEMA, INVENTORY_SCHEMA_LEN, info
    EXPAND DB_INIT_SCHEMA init_invoices_status, ROOT, ROOT_LEN, INVOICES_SCHEMA_PATH, INVOICES_SCHEMA_PATH_LEN, INVOICES_SCHEMA, INVOICES_SCHEMA_LEN, info
    EXPAND DB_DICT_INTERN order_open_status, order_open_id, order_open_inserted, ROOT, ROOT_LEN, TABLE_ORDERS, TABLE_ORDERS_LEN, ORDER_STATUS_DICT, ORDER_STATUS_DICT_LEN, STATUS_OPEN, STATUS_OPEN_LEN, info
    EXPAND DB_DICT_INTERN order_posted_status, order_posted_id, order_posted_inserted, ROOT, ROOT_LEN, TABLE_ORDERS, TABLE_ORDERS_LEN, ORDER_STATUS_DICT, ORDER_STATUS_DICT_LEN, STATUS_POSTED, STATUS_POSTED_LEN, info
    EXPAND DB_DICT_INTERN invoice_paid_status, invoice_paid_id, invoice_paid_inserted, ROOT, ROOT_LEN, TABLE_INVOICES, TABLE_INVOICES_LEN, INVOICE_STATUS_DICT, INVOICE_STATUS_DICT_LEN, STATUS_PAID, STATUS_PAID_LEN, info
    EXPAND DB_DICT_INTERN invoice_unpaid_status, invoice_unpaid_id, invoice_unpaid_inserted, ROOT, ROOT_LEN, TABLE_INVOICES, TABLE_INVOICES_LEN, INVOICE_STATUS_DICT, INVOICE_STATUS_DICT_LEN, STATUS_UNPAID, STATUS_UNPAID_LEN, info
    EXPAND DB_DATE_FROM_YMD base_day_status, base_day, 2026, 1, 1
    min_due_day = add base_day, 10
    max_due_day = add base_day, 19
    t_init1 = call @sa_time_instant_ns()
    db_erp_init_ns = sub t_init1, t_init0

    t_prepare0 = call @sa_time_instant_ns()
    fill_customers_status = call @fill_customer_columns(&cust_id_col, &cust_tier_col, &cust_credit_col)
    fill_products_status = call @fill_product_columns(&prod_id_col, &prod_category_col, &prod_price_col)
    fill_orders_status = call @fill_order_columns(&order_id_col, &order_customer_col, &order_status_col, &order_day_col, order_open_id, order_posted_id, base_day)
    fill_lines_status = call @fill_line_columns(&line_order_col, &line_no_col, &line_product_col, &line_qty_col, &line_net_col)
    fill_inventory_status = call @fill_inventory_columns(&inventory_product_col, &inventory_seq_col, &inventory_qty_col)
    fill_invoices_status = call @fill_invoice_columns(&invoice_id_col, &invoice_order_col, &invoice_status_col, &invoice_due_col, &invoice_amount_col, invoice_paid_id, invoice_unpaid_id, base_day)
    t_prepare1 = call @sa_time_instant_ns()
    db_erp_prepare_ns = sub t_prepare1, t_prepare0

    EXPAND DB_COLUMN_INPUT_SET cust_columns, 0, cust_id_col, CUSTOMER_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET cust_columns, 1, cust_tier_col, CUSTOMER_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET cust_columns, 2, cust_credit_col, CUSTOMER_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET prod_columns, 0, prod_id_col, PRODUCT_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET prod_columns, 1, prod_category_col, PRODUCT_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET prod_columns, 2, prod_price_col, PRODUCT_COL_BYTES
