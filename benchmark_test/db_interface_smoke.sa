@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"members"
@const SCHEMA_PATH = utf8:"members.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 16\n#def COL_ID_STRIDE = 8 // u64\n#def COL_PLAN_STRIDE = 8 // u64\n#def COL_STATUS_STRIDE = 8 // u64\n#def COL_POINTS_STRIDE = 8 // u64\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 7
#def SCHEMA_PATH_LEN = 19
#def SCHEMA_LEN = 149
#def ROWS = 4
#def TOTAL_ROWS = 5
#def UPSERT_ROWS = 6
#def COL_BYTES = 32
#def ROW_BYTES = 32
#def RANGE_ROWS_CAP = 4
#def RANGE_ROWS_BYTES = 32
#def PROJECT_COLUMNS = 2
#def PROJECT_COLUMNS_BYTES = 16
#def PROJECTED_ROWS_BYTES = 32
#def COLUMN_COUNT = 4
#def COLUMNS_BYTES = 64

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    snapshot_info = stack_alloc SaDbSnapshotInfo_SIZE
    column_info = stack_alloc SaDbColumnInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    id_col = alloc COL_BYTES
    plan_col = alloc COL_BYTES
    status_col = alloc COL_BYTES
    points_col = alloc COL_BYTES
    new_row = alloc ROW_BYTES
    fetched_row = alloc ROW_BYTES
    range_rows = alloc RANGE_ROWS_BYTES
    project_columns = alloc PROJECT_COLUMNS_BYTES
    projected_rows = alloc PROJECTED_ROWS_BYTES

    store id_col+0, 1 as u64
    store id_col+8, 2 as u64
    store id_col+16, 3 as u64
    store id_col+24, 4 as u64
    store plan_col+0, 1 as u64
    store plan_col+8, 2 as u64
    store plan_col+16, 1 as u64
    store plan_col+24, 3 as u64
    store status_col+0, 1 as u64
    store status_col+8, 1 as u64
    store status_col+16, 0 as u64
    store status_col+24, 1 as u64
    store points_col+0, 10 as u64
    store points_col+8, 20 as u64
    store points_col+16, 30 as u64
    store points_col+24, 40 as u64
    store new_row+0, 5 as u64
    store new_row+8, 4 as u64
    store new_row+16, 1 as u64
    store new_row+24, 50 as u64
    store project_columns+0, 0 as u64
    store project_columns+8, 3 as u64

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, id_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, plan_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, status_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 3, points_col, COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_INFO_ROW_COUNT rows, info
    EXPAND DB_CREATE_U64_INDEX create_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, info
    EXPAND DB_INSERT_ROW insert_row_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, new_row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_insert, info
    EXPAND DB_INSERT_ROW duplicate_insert_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, new_row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_duplicate, info
    store new_row+0, 5 as u64
    store new_row+8, 4 as u64
    store new_row+16, 1 as u64
    store new_row+24, 55 as u64
    EXPAND DB_UPSERT_ROW_U64_KEY upsert_existing_status, upsert_existing_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 5, new_row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_upsert_existing, info
    store new_row+0, 6 as u64
    store new_row+8, 5 as u64
    store new_row+16, 0 as u64
    store new_row+24, 60 as u64
    EXPAND DB_UPSERT_ROW_U64_KEY upsert_new_status, upsert_new_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 6, new_row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_upsert_new, info
    EXPAND DB_SNAPSHOT snapshot_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INFO_EPOCH snapshot_epoch, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_SNAPSHOT_INFO_HANDLE shape_status, read_handle, snapshot_info
    EXPAND DB_SNAPSHOT_INFO_ROW_COUNT shape_rows, snapshot_info
    EXPAND DB_SNAPSHOT_INFO_COLUMN_COUNT shape_columns, snapshot_info
    EXPAND DB_SNAPSHOT_INFO_ROW_BYTES shape_row_bytes, snapshot_info
    EXPAND DB_SNAPSHOT_INFO_EPOCH shape_epoch, snapshot_info
    EXPAND DB_COLUMN_INFO_HANDLE column_info_status, read_handle, 3, column_info
    EXPAND DB_COLUMN_INFO_STRIDE column_stride, column_info
    EXPAND DB_COLUMN_INFO_TYPE_CODE column_type, column_info
    EXPAND DB_COLUMN_INFO_NAME_LEN column_name_len, column_info
    EXPAND DB_COLUMN_INFO_TYPE_NAME_LEN column_type_name_len, column_info
    EXPAND DB_SUM_U64_HANDLE handle_sum_status, handle_points_sum_before, read_handle, 3
    EXPAND DB_COUNT_U64_CMP_HANDLE handle_count_status, handle_plan_ge_count, read_handle, 1, SA_DB_CMP_GE, 2
    EXPAND DB_RANGE_U64_HANDLE range_status, range_written, range_total, range_rows, RANGE_ROWS_CAP, read_handle, 0, 2, 5, 1, 2
    range_row0 = load range_rows+0 as u64
    range_row1 = load range_rows+8 as u64
    EXPAND DB_GET_ROW_HANDLE get_range_row_status, read_handle, range_row1, fetched_row, ROW_BYTES
    range_fetched_id = load fetched_row+0 as u64
    range_fetched_points = load fetched_row+24 as u64
    EXPAND DB_PROJECT_ROWS_HANDLE project_status, project_written, project_required, projected_rows, PROJECTED_ROWS_BYTES, read_handle, range_rows, range_written, project_columns, PROJECT_COLUMNS
    project_id0 = load projected_rows+0 as u64
    project_points0 = load projected_rows+8 as u64
    project_id1 = load projected_rows+16 as u64
    project_points1 = load projected_rows+24 as u64
    EXPAND DB_FIND_U64_HANDLE find_status, found_member, found_row, read_handle, 0, 5
    EXPAND DB_GET_U64_HANDLE get_status, found_points, read_handle, 3, found_row
    EXPAND DB_GET_ROW_U64_KEY_HANDLE get_row_key_status, read_handle, 0, 5, fetched_row, ROW_BYTES
    fetched_id = load fetched_row+0 as u64
    fetched_plan = load fetched_row+8 as u64
    fetched_status = load fetched_row+16 as u64
    fetched_points = load fetched_row+24 as u64
    EXPAND DB_GET_ROW_U64_KEY_HANDLE get_row_missing_status, read_handle, 0, 99, fetched_row, ROW_BYTES
    EXPAND DB_MIN_U64_HANDLE handle_min_status, handle_points_min, read_handle, 3
    EXPAND DB_MAX_U64_HANDLE handle_max_status, handle_points_max, read_handle, 3
    EXPAND DB_UPDATE_U64_ADD update_status, updated_rows, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 3, 0, ROWS, 5
    EXPAND DB_RECOVER recover_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_SUM_U64_HANDLE stale_handle_sum_status, stale_handle_points_sum, read_handle, 3
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_DELETE_U64_KEY delete_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 5, info
    EXPAND DB_INFO_ROW_COUNT rows_after_delete, info
    EXPAND DB_DELETE_U64_KEY delete_missing_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 5, info
    EXPAND DB_INFO_ROW_COUNT rows_after_delete_missing, info
    EXPAND DB_OPEN_READ_TABLE open_after_status, read_handle_after, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_SUM_U64_HANDLE sum_after_status, points_sum_after, read_handle_after, 3
    EXPAND DB_COUNT_U64_EQ_HANDLE count_status, plan_one_count, read_handle_after, 1, 1
    EXPAND DB_CLOSE_READ_TABLE close_after_status, read_handle_after
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_RESTORE restore_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, snapshot_epoch, info
    EXPAND DB_OPEN_READ_TABLE open_restore_status, read_handle_restore, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_SUM_U64_HANDLE restore_sum_status, points_sum_restore, read_handle_restore, 3
    EXPAND DB_CLOSE_READ_TABLE close_restore_status, read_handle_restore

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_rows = eq rows, ROWS
    ok_create_index_status = eq create_index_status, SA_DB_OK
    ok_insert_row_status = eq insert_row_status, SA_DB_OK
    ok_rows_after_insert = eq rows_after_insert, TOTAL_ROWS
    ok_duplicate_insert_status = eq duplicate_insert_status, SA_DB_ERR_CONSTRAINT
    ok_rows_after_duplicate = eq rows_after_duplicate, TOTAL_ROWS
    ok_upsert_existing_status = eq upsert_existing_status, SA_DB_OK
    ok_upsert_existing_inserted = eq upsert_existing_inserted, 0
    ok_rows_after_upsert_existing = eq rows_after_upsert_existing, TOTAL_ROWS
    ok_upsert_new_status = eq upsert_new_status, SA_DB_OK
    ok_upsert_new_inserted = eq upsert_new_inserted, 1
    ok_rows_after_upsert_new = eq rows_after_upsert_new, UPSERT_ROWS
    ok_snapshot_status = eq snapshot_status, SA_DB_OK
    ok_snapshot_epoch = eq snapshot_epoch, 5
    ok_open_status = eq open_status, SA_DB_OK
    ok_shape_status = eq shape_status, SA_DB_OK
    ok_shape_rows = eq shape_rows, UPSERT_ROWS
    ok_shape_columns = eq shape_columns, COLUMN_COUNT
    ok_shape_row_bytes = eq shape_row_bytes, ROW_BYTES
    ok_shape_epoch = eq shape_epoch, 5
    ok_column_info_status = eq column_info_status, SA_DB_OK
    ok_column_stride = eq column_stride, 8
    ok_column_type = eq column_type, SA_DB_TYPE_U64
    ok_column_name_len = eq column_name_len, 6
    ok_column_type_name_len = eq column_type_name_len, 3
    ok_handle_sum_status = eq handle_sum_status, SA_DB_OK
    ok_handle_sum = eq handle_points_sum_before, 215
    ok_handle_count_status = eq handle_count_status, SA_DB_OK
    ok_handle_count = eq handle_plan_ge_count, 4
    ok_range_status = eq range_status, SA_DB_OK
    ok_range_written = eq range_written, 2
    ok_range_total = eq range_total, 4
    ok_range_row0 = eq range_row0, 2
    ok_range_row1 = eq range_row1, 3
    ok_get_range_row_status = eq get_range_row_status, SA_DB_OK
    ok_range_fetched_id = eq range_fetched_id, 4
    ok_range_fetched_points = eq range_fetched_points, 40
    ok_project_status = eq project_status, SA_DB_OK
    ok_project_written = eq project_written, 2
    ok_project_required = eq project_required, PROJECTED_ROWS_BYTES
    ok_project_id0 = eq project_id0, 3
    ok_project_points0 = eq project_points0, 30
    ok_project_id1 = eq project_id1, 4
    ok_project_points1 = eq project_points1, 40
    ok_find_status = eq find_status, SA_DB_OK
    ok_find_found = eq found_member, 1
    ok_find_row = eq found_row, 4
    ok_get_status = eq get_status, SA_DB_OK
    ok_get_points = eq found_points, 55
    ok_get_row_key_status = eq get_row_key_status, SA_DB_OK
    ok_fetched_id = eq fetched_id, 5
    ok_fetched_plan = eq fetched_plan, 4
    ok_fetched_status = eq fetched_status, 1
    ok_fetched_points = eq fetched_points, 55
    ok_get_row_missing_status = eq get_row_missing_status, SA_DB_ERR_NOT_FOUND
    ok_handle_min_status = eq handle_min_status, SA_DB_OK
    ok_handle_min = eq handle_points_min, 10
    ok_handle_max_status = eq handle_max_status, SA_DB_OK
    ok_handle_max = eq handle_points_max, 60
    ok_update_status = eq update_status, SA_DB_OK
    ok_updated_rows = eq updated_rows, ROWS
    ok_recover_status = eq recover_status, SA_DB_OK
    ok_stale_sum_status = eq stale_handle_sum_status, SA_DB_OK
    ok_stale_sum = eq stale_handle_points_sum, 215
    ok_close_status = eq close_status, SA_DB_OK
    ok_delete_status = eq delete_status, SA_DB_OK
    ok_rows_after_delete = eq rows_after_delete, TOTAL_ROWS
    ok_delete_missing_status = eq delete_missing_status, SA_DB_ERR_NOT_FOUND
    ok_rows_after_delete_missing = eq rows_after_delete_missing, TOTAL_ROWS
    ok_open_after_status = eq open_after_status, SA_DB_OK
    ok_sum_after_status = eq sum_after_status, SA_DB_OK
    ok_sum_after = eq points_sum_after, 180
    ok_count_status = eq count_status, SA_DB_OK
    ok_count = eq plan_one_count, 2
    ok_close_after_status = eq close_after_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK
    ok_restore_status = eq restore_status, SA_DB_OK
    ok_open_restore_status = eq open_restore_status, SA_DB_OK
    ok_restore_sum_status = eq restore_sum_status, SA_DB_OK
    ok_restore_sum = eq points_sum_restore, 215
    ok_close_restore_status = eq close_restore_status, SA_DB_OK
    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_ingest
    ok03 = and ok02, ok_rows
    ok04 = and ok03, ok_create_index_status
    ok05 = and ok04, ok_insert_row_status
    ok06 = and ok05, ok_rows_after_insert
    ok06a = and ok06, ok_duplicate_insert_status
    ok06b = and ok06a, ok_rows_after_duplicate
    ok06c = and ok06b, ok_upsert_existing_status
    ok06d = and ok06c, ok_upsert_existing_inserted
    ok06e = and ok06d, ok_rows_after_upsert_existing
    ok06f = and ok06e, ok_upsert_new_status
    ok06g = and ok06f, ok_upsert_new_inserted
    ok06h = and ok06g, ok_rows_after_upsert_new
    ok07 = and ok06h, ok_snapshot_status
    ok08 = and ok07, ok_snapshot_epoch
    ok09 = and ok08, ok_open_status
    ok09a = and ok09, ok_shape_status
    ok09b = and ok09a, ok_shape_rows
    ok09c = and ok09b, ok_shape_columns
    ok09d = and ok09c, ok_shape_row_bytes
    ok09e = and ok09d, ok_shape_epoch
    ok09f = and ok09e, ok_column_info_status
    ok09g = and ok09f, ok_column_stride
    ok09h = and ok09g, ok_column_type
    ok09i = and ok09h, ok_column_name_len
    ok09j = and ok09i, ok_column_type_name_len
    ok10 = and ok09j, ok_handle_sum_status
    ok11 = and ok10, ok_handle_sum
    ok12 = and ok11, ok_handle_count_status
    ok13 = and ok12, ok_handle_count
    ok13a = and ok13, ok_range_status
    ok13b = and ok13a, ok_range_written
    ok13c = and ok13b, ok_range_total
    ok13d = and ok13c, ok_range_row0
    ok13e = and ok13d, ok_range_row1
    ok13f = and ok13e, ok_get_range_row_status
    ok13g = and ok13f, ok_range_fetched_id
    ok13h = and ok13g, ok_range_fetched_points
    ok13i = and ok13h, ok_project_status
    ok13j = and ok13i, ok_project_written
    ok13k = and ok13j, ok_project_required
    ok13l = and ok13k, ok_project_id0
    ok13m = and ok13l, ok_project_points0
    ok13n = and ok13m, ok_project_id1
    ok13o = and ok13n, ok_project_points1
    ok14 = and ok13o, ok_find_status
    ok15 = and ok14, ok_find_found
    ok16 = and ok15, ok_find_row
    ok17 = and ok16, ok_get_status
    ok18 = and ok17, ok_get_points
    ok18a = and ok18, ok_get_row_key_status
    ok18b = and ok18a, ok_fetched_id
    ok18c = and ok18b, ok_fetched_plan
    ok18d = and ok18c, ok_fetched_status
    ok18e = and ok18d, ok_fetched_points
    ok18f = and ok18e, ok_get_row_missing_status
    ok19 = and ok18f, ok_handle_min_status
    ok20 = and ok19, ok_handle_min
    ok21 = and ok20, ok_handle_max_status
    ok22 = and ok21, ok_handle_max
    ok23 = and ok22, ok_update_status
    ok24 = and ok23, ok_updated_rows
    ok25 = and ok24, ok_recover_status
    ok26 = and ok25, ok_stale_sum_status
    ok27 = and ok26, ok_stale_sum
    ok28 = and ok27, ok_close_status
    ok28a = and ok28, ok_delete_status
    ok28b = and ok28a, ok_rows_after_delete
    ok28c = and ok28b, ok_delete_missing_status
    ok28d = and ok28c, ok_rows_after_delete_missing
    ok29 = and ok28d, ok_open_after_status
    ok30 = and ok29, ok_sum_after_status
    ok31 = and ok30, ok_sum_after
    ok32 = and ok31, ok_count_status
    ok33 = and ok32, ok_count
    ok34 = and ok33, ok_close_after_status
    ok35 = and ok34, ok_verify
    ok36 = and ok35, ok_restore_status
    ok37 = and ok36, ok_open_restore_status
    ok38 = and ok37, ok_restore_sum_status
    ok39 = and ok38, ok_restore_sum
    ok = and ok39, ok_close_restore_status

    !remove_status
    !init_status
    !ingest_status
    !rows
    !create_index_status
    !insert_row_status
    !rows_after_insert
    !duplicate_insert_status
    !rows_after_duplicate
    !upsert_existing_status
    !upsert_existing_inserted
    !rows_after_upsert_existing
    !upsert_new_status
    !upsert_new_inserted
    !rows_after_upsert_new
    !snapshot_status
    !snapshot_epoch
