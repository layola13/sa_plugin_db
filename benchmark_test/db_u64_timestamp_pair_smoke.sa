@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"u64_ts_orders"
@const SCHEMA_PATH = utf8:"u64_ts_orders.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_STORE_ID_STRIDE = 8 // u64\n#def COL_POSTED_TS_STRIDE = 8 // i64 timestamp_ms\n#def COL_AMOUNT_CENTS_STRIDE = 8 // i64 decimal(2)\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 13
#def SCHEMA_PATH_LEN = 25
#def SCHEMA_LEN = 155
#def ROWS = 5
#def COL_BYTES = 40
#def ROW_BYTES = 24
#def COLUMN_COUNT = 3
#def COLUMNS_BYTES = 48
#def RANGE_ROWS_CAP = 4
#def RANGE_ROWS_BYTES = 32
#def MS_PER_DAY = 86400000
#def US_PER_DAY = 86400000000

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    store_ids = alloc COL_BYTES
    posted_ts = alloc COL_BYTES
    amounts = alloc COL_BYTES
    range_rows = alloc RANGE_ROWS_BYTES

    store store_ids+0, 7 as u64
    store store_ids+8, 7 as u64
    store store_ids+16, 7 as u64
    store store_ids+24, 8 as u64
    store store_ids+32, 7 as u64
    store posted_ts+0, 1000 as i64
    store posted_ts+8, 2000 as i64
    store posted_ts+16, 3000 as i64
    store posted_ts+24, 2500 as i64
    store posted_ts+32, 86400000 as i64
    store amounts+0, 1000 as i64
    store amounts+8, 2000 as i64
    store amounts+16, 3000 as i64
    store amounts+24, 4000 as i64
    store amounts+32, 5000 as i64

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, store_ids, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, posted_ts, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, amounts, COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_U64_I64_PAIR_INDEX index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 0, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_RANGE_U64_TIMESTAMP_MS_PAIR_HANDLE ms_status, ms_written, ms_total, range_rows, RANGE_ROWS_CAP, read_handle, 0, 1, 7, 0, 1500, 0, 3500, 0, RANGE_ROWS_CAP
    ms_row0 = load range_rows+0 as u64
    ms_row1 = load range_rows+8 as u64
    EXPAND DB_RANGE_U64_TIMESTAMP_US_PAIR_HANDLE us_status, us_written, us_total, range_rows, RANGE_ROWS_CAP, read_handle, 0, 1, 7, 0, 1500, 0, 3500, 0, RANGE_ROWS_CAP
    us_row0 = load range_rows+0 as u64
    us_row1 = load range_rows+8 as u64
    EXPAND DB_RANGE_U64_TIMESTAMP_MS_PAIR_HANDLE invalid_ms_status, invalid_ms_written, invalid_ms_total, range_rows, RANGE_ROWS_CAP, read_handle, 0, 1, 7, 0, MS_PER_DAY, 0, 0, 0, RANGE_ROWS_CAP
    EXPAND DB_RANGE_U64_TIMESTAMP_US_PAIR_HANDLE invalid_us_status, invalid_us_written, invalid_us_total, range_rows, RANGE_ROWS_CAP, read_handle, 0, 1, 7, 0, US_PER_DAY, 0, 0, 0, RANGE_ROWS_CAP

    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_index = eq index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_ms_status = eq ms_status, SA_DB_OK
    ok_ms_written = eq ms_written, 2
    ok_ms_total = eq ms_total, 2
    ok_ms_row0 = eq ms_row0, 1
    ok_ms_row1 = eq ms_row1, 2
    ok_us_status = eq us_status, SA_DB_OK
    ok_us_written = eq us_written, 2
    ok_us_total = eq us_total, 2
    ok_us_row0 = eq us_row0, 1
    ok_us_row1 = eq us_row1, 2
    ok_invalid_ms_status = eq invalid_ms_status, SA_DB_ERR_INVALID_ARGUMENT
    ok_invalid_ms_written = eq invalid_ms_written, 0
    ok_invalid_ms_total = eq invalid_ms_total, 0
    ok_invalid_us_status = eq invalid_us_status, SA_DB_ERR_INVALID_ARGUMENT
    ok_invalid_us_written = eq invalid_us_written, 0
    ok_invalid_us_total = eq invalid_us_total, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_ingest
    ok03 = and ok02, ok_index
    ok04 = and ok03, ok_open
    ok05 = and ok04, ok_ms_status
    ok06 = and ok05, ok_ms_written
    ok07 = and ok06, ok_ms_total
    ok08 = and ok07, ok_ms_row0
    ok09 = and ok08, ok_ms_row1
    ok10 = and ok09, ok_us_status
    ok11 = and ok10, ok_us_written
    ok12 = and ok11, ok_us_total
    ok13 = and ok12, ok_us_row0
    ok14 = and ok13, ok_us_row1
    ok15 = and ok14, ok_invalid_ms_status
    ok16 = and ok15, ok_invalid_ms_written
    ok17 = and ok16, ok_invalid_ms_total
    ok18 = and ok17, ok_invalid_us_status
    ok19 = and ok18, ok_invalid_us_written
    ok20 = and ok19, ok_invalid_us_total
    ok21 = and ok20, ok_close
    ok = and ok21, ok_verify

    !remove_status
    !init_status
    !ingest_status
    !index_status
    !open_status
    !read_handle
    !ms_status
    !ms_written
    !ms_total
    !ms_row0
    !ms_row1
    !us_status
    !us_written
    !us_total
    !us_row0
    !us_row1
    !invalid_ms_status
    !invalid_ms_written
    !invalid_ms_total
    !invalid_us_status
    !invalid_us_written
    !invalid_us_total
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_ingest
    !ok_index
    !ok_open
    !ok_ms_status
    !ok_ms_written
    !ok_ms_total
    !ok_ms_row0
    !ok_ms_row1
    !ok_us_status
    !ok_us_written
    !ok_us_total
    !ok_us_row0
    !ok_us_row1
    !ok_invalid_ms_status
    !ok_invalid_ms_written
    !ok_invalid_ms_total
    !ok_invalid_us_status
    !ok_invalid_us_written
    !ok_invalid_us_total
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !store_ids
    !posted_ts
    !amounts
    !range_rows
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9031)
