@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"pair_i64_write_smoke"
@const SCHEMA_PATH = utf8:"pair_i64_write_smoke.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_CUSTOMER_ID_STRIDE = 8 // u64\n#def COL_ORDER_DAY_STRIDE = 8 // i64\n#def COL_TOTAL_CENTS_STRIDE = 8 // i64\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 20
#def SCHEMA_PATH_LEN = 32
#def SCHEMA_LEN = 133
#def ROWS = 3
#def COL_BYTES = 24
#def ROW_BYTES = 24
#def COLUMN_COUNT = 3
#def COLUMNS_BYTES = 48

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    customer_ids = alloc COL_BYTES
    order_days = alloc COL_BYTES
    totals = alloc COL_BYTES
    row = alloc ROW_BYTES

    store customer_ids+0, 7 as u64
    store customer_ids+8, 7 as u64
    store customer_ids+16, 8 as u64
    store order_days+0, -5 as i64
    store order_days+8, 0 as i64
    store order_days+16, -3 as i64
    store totals+0, 1000 as i64
    store totals+8, 2000 as i64
    store totals+16, 4000 as i64

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, customer_ids, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, order_days, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, totals, COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_U64_I64_PAIR_INDEX index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 1, info

    store row+0, 7 as u64
    store row+8, 0 as i64
    store row+16, 2100 as i64
    EXPAND DB_UPDATE_ROW_U64_I64_PAIR_KEY direct_update_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 7, 0, row, ROW_BYTES, info

    store row+0, 7 as u64
    store row+8, 99 as i64
    store row+16, 9900 as i64
    EXPAND DB_UPDATE_ROW_U64_I64_PAIR_KEY direct_missing_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 7, 99, row, ROW_BYTES, info

    store row+0, 7 as u64
    store row+8, 1 as i64
    store row+16, 111 as i64
    EXPAND DB_UPDATE_ROW_U64_I64_PAIR_KEY direct_mismatch_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 7, 0, row, ROW_BYTES, info

    store row+0, 7 as u64
    store row+8, -5 as i64
    store row+16, 1100 as i64
    EXPAND DB_UPSERT_ROW_U64_I64_PAIR_KEY direct_upsert_existing_status, direct_upsert_existing_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 7, -5, row, ROW_BYTES, info

    store row+0, 7 as u64
    store row+8, 10 as i64
    store row+16, 3000 as i64
    EXPAND DB_UPSERT_ROW_U64_I64_PAIR_KEY direct_upsert_new_status, direct_upsert_new_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 7, 10, row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_direct_upsert, info

    EXPAND DB_DELETE_U64_I64_PAIR_KEY direct_delete_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 8, -3, info
    EXPAND DB_INFO_ROW_COUNT rows_after_direct_delete, info
    EXPAND DB_DELETE_U64_I64_PAIR_KEY direct_delete_missing_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 8, -3, info

    EXPAND DB_TX_BEGIN tx_begin_status, tx, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    store row+0, 7 as u64
    store row+8, 0 as i64
    store row+16, 2200 as i64
    EXPAND DB_TX_UPSERT_ROW_U64_I64_PAIR_KEY tx_upsert_existing_status, tx_upsert_existing_inserted, tx, 0, 1, 7, 0, row, ROW_BYTES, info
    store row+0, 7 as u64
    store row+8, 99 as i64
    store row+16, 9900 as i64
    EXPAND DB_TX_UPDATE_ROW_U64_I64_PAIR_KEY tx_missing_status, tx, 0, 1, 7, 99, row, ROW_BYTES, info
    store row+0, 7 as u64
    store row+8, 10 as i64
    store row+16, 3300 as i64
    EXPAND DB_TX_UPDATE_ROW_U64_I64_PAIR_KEY tx_update_status, tx, 0, 1, 7, 10, row, ROW_BYTES, info
    store row+0, 9 as u64
    store row+8, -1 as i64
    store row+16, 900 as i64
    EXPAND DB_TX_UPSERT_ROW_U64_I64_PAIR_KEY tx_upsert_new_status, tx_upsert_new_inserted, tx, 0, 1, 9, -1, row, ROW_BYTES, info
    EXPAND DB_TX_DELETE_U64_I64_PAIR_KEY tx_delete_status, tx, 0, 1, 7, -5, info
    EXPAND DB_TX_COMMIT tx_commit_status, tx, info
    EXPAND DB_INFO_ROW_COUNT rows_after_commit, info

    EXPAND DB_TX_BEGIN tx2_begin_status, tx2, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    store row+0, 99 as u64
    store row+8, -99 as i64
    store row+16, 9900 as i64
    EXPAND DB_TX_UPSERT_ROW_U64_I64_PAIR_KEY tx2_upsert_status, tx2_upsert_inserted, tx2, 0, 1, 99, -99, row, ROW_BYTES, info
    EXPAND DB_TX_ROLLBACK tx2_rollback_status, tx2

    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_FIND_U64_I64_PAIR_HANDLE find_day0_status, find_day0_found, find_day0_row, read_handle, 0, 1, 7, 0
    EXPAND DB_GET_I64_HANDLE get_day0_status, day0_total, read_handle, 2, find_day0_row
    EXPAND DB_FIND_U64_I64_PAIR_HANDLE find_day_neg5_status, find_day_neg5_found, find_day_neg5_row, read_handle, 0, 1, 7, -5
    EXPAND DB_FIND_U64_I64_PAIR_HANDLE find_day10_status, find_day10_found, find_day10_row, read_handle, 0, 1, 7, 10
    EXPAND DB_GET_I64_HANDLE get_day10_status, day10_total, read_handle, 2, find_day10_row
    EXPAND DB_FIND_U64_I64_PAIR_HANDLE find_customer9_status, find_customer9_found, find_customer9_row, read_handle, 0, 1, 9, -1
    EXPAND DB_GET_I64_HANDLE get_customer9_status, customer9_total, read_handle, 2, find_customer9_row
    EXPAND DB_FIND_U64_I64_PAIR_HANDLE find_rollback_status, find_rollback_found, find_rollback_row, read_handle, 0, 1, 99, -99
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_index = eq index_status, SA_DB_OK
    ok_direct_update = eq direct_update_status, SA_DB_OK
    ok_direct_missing = eq direct_missing_status, SA_DB_ERR_NOT_FOUND
    ok_direct_mismatch = eq direct_mismatch_status, SA_DB_ERR_INVALID_FORMAT
    ok_direct_upsert_existing = eq direct_upsert_existing_status, SA_DB_OK
    ok_direct_upsert_existing_inserted = eq direct_upsert_existing_inserted, 0
    ok_direct_upsert_new = eq direct_upsert_new_status, SA_DB_OK
    ok_direct_upsert_new_inserted = eq direct_upsert_new_inserted, 1
    ok_rows_direct_upsert = eq rows_after_direct_upsert, 4
    ok_direct_delete = eq direct_delete_status, SA_DB_OK
    ok_rows_direct_delete = eq rows_after_direct_delete, 3
    ok_direct_delete_missing = eq direct_delete_missing_status, SA_DB_ERR_NOT_FOUND
    ok_tx_begin = eq tx_begin_status, SA_DB_OK
    ok_tx_upsert_existing = eq tx_upsert_existing_status, SA_DB_OK
    ok_tx_upsert_existing_inserted = eq tx_upsert_existing_inserted, 0
    ok_tx_missing = eq tx_missing_status, SA_DB_ERR_NOT_FOUND
    ok_tx_update = eq tx_update_status, SA_DB_OK
    ok_tx_upsert_new = eq tx_upsert_new_status, SA_DB_OK
    ok_tx_upsert_new_inserted = eq tx_upsert_new_inserted, 1
    ok_tx_delete = eq tx_delete_status, SA_DB_OK
    ok_tx_commit = eq tx_commit_status, SA_DB_OK
    ok_rows_commit = eq rows_after_commit, 3
    ok_tx2_begin = eq tx2_begin_status, SA_DB_OK
    ok_tx2_upsert = eq tx2_upsert_status, SA_DB_OK
    ok_tx2_upsert_inserted = eq tx2_upsert_inserted, 1
    ok_tx2_rollback = eq tx2_rollback_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_find_day0 = eq find_day0_status, SA_DB_OK
    ok_day0_found = eq find_day0_found, 1
    ok_get_day0 = eq get_day0_status, SA_DB_OK
    ok_day0_total = eq day0_total, 2200
    ok_find_day_neg5 = eq find_day_neg5_status, SA_DB_OK
    ok_day_neg5_missing = eq find_day_neg5_found, 0
    ok_find_day10 = eq find_day10_status, SA_DB_OK
    ok_day10_found = eq find_day10_found, 1
    ok_get_day10 = eq get_day10_status, SA_DB_OK
    ok_day10_total = eq day10_total, 3300
    ok_find_customer9 = eq find_customer9_status, SA_DB_OK
    ok_customer9_found = eq find_customer9_found, 1
    ok_get_customer9 = eq get_customer9_status, SA_DB_OK
    ok_customer9_total = eq customer9_total, 900
    ok_find_rollback = eq find_rollback_status, SA_DB_OK
    ok_rollback_missing = eq find_rollback_found, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_ingest
    ok03 = and ok02, ok_index
    ok04 = and ok03, ok_direct_update
    ok05 = and ok04, ok_direct_missing
    ok06 = and ok05, ok_direct_mismatch
    ok07 = and ok06, ok_direct_upsert_existing
    ok08 = and ok07, ok_direct_upsert_existing_inserted
    ok09 = and ok08, ok_direct_upsert_new
    ok10 = and ok09, ok_direct_upsert_new_inserted
    ok11 = and ok10, ok_rows_direct_upsert
    ok12 = and ok11, ok_direct_delete
    ok13 = and ok12, ok_rows_direct_delete
    ok14 = and ok13, ok_direct_delete_missing
    ok15 = and ok14, ok_tx_begin
    ok16 = and ok15, ok_tx_upsert_existing
    ok17 = and ok16, ok_tx_upsert_existing_inserted
    ok18 = and ok17, ok_tx_missing
    ok19 = and ok18, ok_tx_update
    ok20 = and ok19, ok_tx_upsert_new
    ok21 = and ok20, ok_tx_upsert_new_inserted
    ok22 = and ok21, ok_tx_delete
    ok23 = and ok22, ok_tx_commit
    ok24 = and ok23, ok_rows_commit
    ok25 = and ok24, ok_tx2_begin
    ok26 = and ok25, ok_tx2_upsert
    ok27 = and ok26, ok_tx2_upsert_inserted
    ok28 = and ok27, ok_tx2_rollback
    ok29 = and ok28, ok_open
    ok30 = and ok29, ok_find_day0
    ok31 = and ok30, ok_day0_found
    ok32 = and ok31, ok_get_day0
    ok33 = and ok32, ok_day0_total
    ok34 = and ok33, ok_find_day_neg5
    ok35 = and ok34, ok_day_neg5_missing
    ok36 = and ok35, ok_find_day10
    ok37 = and ok36, ok_day10_found
    ok38 = and ok37, ok_get_day10
    ok39 = and ok38, ok_day10_total
    ok40 = and ok39, ok_find_customer9
    ok41 = and ok40, ok_customer9_found
    ok42 = and ok41, ok_get_customer9
    ok43 = and ok42, ok_customer9_total
    ok44 = and ok43, ok_find_rollback
    ok45 = and ok44, ok_rollback_missing
    ok46 = and ok45, ok_close
    ok = and ok46, ok_verify

    !remove_status
    !init_status
    !ingest_status
    !index_status
    !direct_update_status
    !direct_missing_status
    !direct_mismatch_status
    !direct_upsert_existing_status
    !direct_upsert_existing_inserted
    !direct_upsert_new_status
    !direct_upsert_new_inserted
    !rows_after_direct_upsert
    !direct_delete_status
    !rows_after_direct_delete
    !direct_delete_missing_status
    !tx_begin_status
    !tx
    !tx_upsert_existing_status
    !tx_upsert_existing_inserted
    !tx_missing_status
    !tx_update_status
    !tx_upsert_new_status
    !tx_upsert_new_inserted
    !tx_delete_status
    !tx_commit_status
    !rows_after_commit
    !tx2_begin_status
    !tx2
    !tx2_upsert_status
    !tx2_upsert_inserted
    !tx2_rollback_status
    !open_status
    !read_handle
    !find_day0_status
    !find_day0_found
    !find_day0_row
    !get_day0_status
    !day0_total
    !find_day_neg5_status
    !find_day_neg5_found
    !find_day_neg5_row
    !find_day10_status
    !find_day10_found
    !find_day10_row
    !get_day10_status
    !day10_total
    !find_customer9_status
    !find_customer9_found
    !find_customer9_row
    !get_customer9_status
    !customer9_total
    !find_rollback_status
    !find_rollback_found
    !find_rollback_row
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_ingest
    !ok_index
    !ok_direct_update
    !ok_direct_missing
    !ok_direct_mismatch
    !ok_direct_upsert_existing
    !ok_direct_upsert_existing_inserted
    !ok_direct_upsert_new
    !ok_direct_upsert_new_inserted
    !ok_rows_direct_upsert
    !ok_direct_delete
    !ok_rows_direct_delete
    !ok_direct_delete_missing
    !ok_tx_begin
    !ok_tx_upsert_existing
    !ok_tx_upsert_existing_inserted
    !ok_tx_missing
    !ok_tx_update
    !ok_tx_upsert_new
    !ok_tx_upsert_new_inserted
    !ok_tx_delete
    !ok_tx_commit
    !ok_rows_commit
    !ok_tx2_begin
    !ok_tx2_upsert
    !ok_tx2_upsert_inserted
    !ok_tx2_rollback
    !ok_open
    !ok_find_day0
    !ok_day0_found
    !ok_get_day0
    !ok_day0_total
    !ok_find_day_neg5
    !ok_day_neg5_missing
    !ok_find_day10
    !ok_day10_found
    !ok_get_day10
    !ok_day10_total
    !ok_find_customer9
    !ok_customer9_found
    !ok_get_customer9
    !ok_customer9_total
    !ok_find_rollback
    !ok_rollback_missing
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !ok30
    !ok31
    !ok32
    !ok33
    !ok34
    !ok35
    !ok36
    !ok37
    !ok38
    !ok39
    !ok40
    !ok41
    !ok42
    !ok43
    !ok44
    !ok45
    !ok46
    !customer_ids
    !order_days
    !totals
    !row
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9033)
