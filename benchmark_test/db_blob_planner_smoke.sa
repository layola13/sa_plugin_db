@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"blob_planner_orders"
@const SCHEMA_PATH = utf8:"blob_planner_orders.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_STATUS_STRIDE = 8 // u64\n#def COL_DUE_DAY_STRIDE = 8 // i64 date\n#def COL_DOC_TYPE_STRIDE = 8 // blob_handle\n"
@const STORE = utf8:"doc_type"
@const VALUE_INVOICE = utf8:"invoice"
@const VALUE_ORDER = utf8:"order"
@const VALUE_CREDIT = utf8:"credit"

#def ROOT_LEN = 1
#def TABLE_LEN = 19
#def SCHEMA_PATH_LEN = 31
#def SCHEMA_LEN = 166
#def STORE_LEN = 8
#def VALUE_INVOICE_LEN = 7
#def VALUE_ORDER_LEN = 5
#def VALUE_CREDIT_LEN = 6
#def ROW_BYTES = 32
#def ROWS_CAP = 6
#def ROWS_BYTES = 48

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    plan_info = stack_alloc SaDbPlanInfo_SIZE
    plan3_info = stack_alloc SaDbPlan3Info_SIZE
    row = alloc ROW_BYTES
    plan_rows = alloc ROWS_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_BLOB_PUT put_invoice_status, invoice_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_INVOICE, VALUE_INVOICE_LEN, info
    EXPAND DB_BLOB_PUT put_order_status, order_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_ORDER, VALUE_ORDER_LEN, info
    EXPAND DB_BLOB_PUT put_credit_status, credit_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_CREDIT, VALUE_CREDIT_LEN, info

    store row+0, 100 as u64
    store row+8, 1 as u64
    store row+16, -5 as i64
    store row+24, invoice_id as u64
    EXPAND DB_INSERT_ROW insert0_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 101 as u64
    store row+8, 2 as u64
    store row+16, 0 as i64
    store row+24, order_id as u64
    EXPAND DB_INSERT_ROW insert1_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 102 as u64
    store row+8, 2 as u64
    store row+16, 10 as i64
    store row+24, invoice_id as u64
    EXPAND DB_INSERT_ROW insert2_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 103 as u64
    store row+8, 2 as u64
    store row+16, -3 as i64
    store row+24, order_id as u64
    EXPAND DB_INSERT_ROW insert3_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 104 as u64
    store row+8, 1 as u64
    store row+16, 20 as i64
    store row+24, credit_id as u64
    EXPAND DB_INSERT_ROW insert4_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 105 as u64
    store row+8, 2 as u64
    store row+16, 25 as i64
    store row+24, invoice_id as u64
    EXPAND DB_INSERT_ROW insert5_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info

    EXPAND DB_CREATE_U64_INDEX status_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, 0, info
    EXPAND DB_CREATE_I64_INDEX due_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 2, 0, info
    EXPAND DB_CREATE_BLOB_EQ_INDEX blob_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 3, STORE, STORE_LEN, 0, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_PLAN_U64_BLOB_EQ_HANDLE status_order_status, plan_rows, ROWS_CAP, plan_info, read_handle, 1, 2, 2, 3, STORE, STORE_LEN, VALUE_ORDER, VALUE_ORDER_LEN, 0, ROWS_CAP
    EXPAND DB_PLAN_INFO_WRITTEN status_order_written, plan_info
    EXPAND DB_PLAN_INFO_TOTAL status_order_total, plan_info
    EXPAND DB_PLAN_INFO_FIRST_PREDICATE status_order_first_predicate, plan_info
    EXPAND DB_PLAN_INFO_FIRST_TOTAL status_order_first_total, plan_info
    EXPAND DB_PLAN_INFO_SECOND_TOTAL status_order_second_total, plan_info
    status_order_row0 = load plan_rows+0 as u64
    status_order_row1 = load plan_rows+8 as u64

    EXPAND DB_PLAN_U64_BLOB_EQ_HANDLE status_order_page_status, plan_rows, ROWS_CAP, plan_info, read_handle, 1, 2, 2, 3, STORE, STORE_LEN, VALUE_ORDER, VALUE_ORDER_LEN, 1, 1
    EXPAND DB_PLAN_INFO_WRITTEN status_order_page_written, plan_info
    EXPAND DB_PLAN_INFO_TOTAL status_order_page_total, plan_info
    status_order_page_row0 = load plan_rows+0 as u64

    EXPAND DB_PLAN_U64_BLOB_EQ_HANDLE status_invoice_status, plan_rows, ROWS_CAP, plan_info, read_handle, 1, 1, 1, 3, STORE, STORE_LEN, VALUE_INVOICE, VALUE_INVOICE_LEN, 0, ROWS_CAP
    EXPAND DB_PLAN_INFO_WRITTEN status_invoice_written, plan_info
    EXPAND DB_PLAN_INFO_TOTAL status_invoice_total, plan_info
    EXPAND DB_PLAN_INFO_FIRST_PREDICATE status_invoice_first_predicate, plan_info
    EXPAND DB_PLAN_INFO_FIRST_TOTAL status_invoice_first_total, plan_info
    EXPAND DB_PLAN_INFO_SECOND_TOTAL status_invoice_second_total, plan_info
    status_invoice_row0 = load plan_rows+0 as u64

    EXPAND DB_PLAN_I64_BLOB_EQ_HANDLE due_order_status, plan_rows, ROWS_CAP, plan_info, read_handle, 2, 0, 20, 3, STORE, STORE_LEN, VALUE_ORDER, VALUE_ORDER_LEN, 0, ROWS_CAP
    EXPAND DB_PLAN_INFO_WRITTEN due_order_written, plan_info
    EXPAND DB_PLAN_INFO_TOTAL due_order_total, plan_info
    EXPAND DB_PLAN_INFO_FIRST_PREDICATE due_order_first_predicate, plan_info
    EXPAND DB_PLAN_INFO_FIRST_TOTAL due_order_first_total, plan_info
    EXPAND DB_PLAN_INFO_SECOND_TOTAL due_order_second_total, plan_info
    due_order_row0 = load plan_rows+0 as u64

    EXPAND DB_PLAN_I64_BLOB_EQ_HANDLE due_invoice_status, plan_rows, ROWS_CAP, plan_info, read_handle, 2, 20, 25, 3, STORE, STORE_LEN, VALUE_INVOICE, VALUE_INVOICE_LEN, 0, ROWS_CAP
    EXPAND DB_PLAN_INFO_WRITTEN due_invoice_written, plan_info
    EXPAND DB_PLAN_INFO_TOTAL due_invoice_total, plan_info
    EXPAND DB_PLAN_INFO_FIRST_PREDICATE due_invoice_first_predicate, plan_info
    EXPAND DB_PLAN_INFO_FIRST_TOTAL due_invoice_first_total, plan_info
    EXPAND DB_PLAN_INFO_SECOND_TOTAL due_invoice_second_total, plan_info
    due_invoice_row0 = load plan_rows+0 as u64

    EXPAND DB_PLAN_U64_I64_BLOB_EQ_HANDLE three_status, plan_rows, ROWS_CAP, plan3_info, read_handle, 1, 2, 2, 2, 0, 20, 3, STORE, STORE_LEN, VALUE_INVOICE, VALUE_INVOICE_LEN, 0, ROWS_CAP
    EXPAND DB_PLAN3_INFO_WRITTEN three_written, plan3_info
    EXPAND DB_PLAN3_INFO_TOTAL three_total, plan3_info
    EXPAND DB_PLAN3_INFO_FIRST_PREDICATE three_first_predicate, plan3_info
    EXPAND DB_PLAN3_INFO_FIRST_TOTAL three_first_total, plan3_info
    EXPAND DB_PLAN3_INFO_SECOND_PREDICATE three_second_predicate, plan3_info
    EXPAND DB_PLAN3_INFO_SECOND_TOTAL three_second_total, plan3_info
    EXPAND DB_PLAN3_INFO_THIRD_PREDICATE three_third_predicate, plan3_info
    EXPAND DB_PLAN3_INFO_THIRD_TOTAL three_third_total, plan3_info
    three_row0 = load plan_rows+0 as u64

    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_put_invoice = eq put_invoice_status, SA_DB_OK
    ok_put_order = eq put_order_status, SA_DB_OK
    ok_put_credit = eq put_credit_status, SA_DB_OK
    ok_insert0 = eq insert0_status, SA_DB_OK
    ok_insert1 = eq insert1_status, SA_DB_OK
    ok_insert2 = eq insert2_status, SA_DB_OK
    ok_insert3 = eq insert3_status, SA_DB_OK
    ok_insert4 = eq insert4_status, SA_DB_OK
    ok_insert5 = eq insert5_status, SA_DB_OK
    ok_status_index = eq status_index_status, SA_DB_OK
    ok_due_index = eq due_index_status, SA_DB_OK
    ok_blob_index = eq blob_index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_status_order_status = eq status_order_status, SA_DB_OK
    ok_status_order_written = eq status_order_written, 2
    ok_status_order_total = eq status_order_total, 2
    ok_status_order_first_predicate = eq status_order_first_predicate, 2
    ok_status_order_first_total = eq status_order_first_total, 2
    ok_status_order_second_total = eq status_order_second_total, 4
    ok_status_order_row0 = eq status_order_row0, 1
    ok_status_order_row1 = eq status_order_row1, 3
    ok_status_order_page_status = eq status_order_page_status, SA_DB_OK
    ok_status_order_page_written = eq status_order_page_written, 1
    ok_status_order_page_total = eq status_order_page_total, 2
    ok_status_order_page_row0 = eq status_order_page_row0, 3
    ok_status_invoice_status = eq status_invoice_status, SA_DB_OK
    ok_status_invoice_written = eq status_invoice_written, 1
    ok_status_invoice_total = eq status_invoice_total, 1
    ok_status_invoice_first_predicate = eq status_invoice_first_predicate, 1
    ok_status_invoice_first_total = eq status_invoice_first_total, 2
    ok_status_invoice_second_total = eq status_invoice_second_total, 3
    ok_status_invoice_row0 = eq status_invoice_row0, 0
    ok_due_order_status = eq due_order_status, SA_DB_OK
    ok_due_order_written = eq due_order_written, 1
    ok_due_order_total = eq due_order_total, 1
    ok_due_order_first_predicate = eq due_order_first_predicate, 2
    ok_due_order_first_total = eq due_order_first_total, 2
    ok_due_order_second_total = eq due_order_second_total, 3
    ok_due_order_row0 = eq due_order_row0, 1
    ok_due_invoice_status = eq due_invoice_status, SA_DB_OK
    ok_due_invoice_written = eq due_invoice_written, 1
    ok_due_invoice_total = eq due_invoice_total, 1
    ok_due_invoice_first_predicate = eq due_invoice_first_predicate, 1
    ok_due_invoice_first_total = eq due_invoice_first_total, 2
    ok_due_invoice_second_total = eq due_invoice_second_total, 3
    ok_due_invoice_row0 = eq due_invoice_row0, 5
    ok_three_status = eq three_status, SA_DB_OK
    ok_three_written = eq three_written, 1
    ok_three_total = eq three_total, 1
    ok_three_first_predicate = eq three_first_predicate, 2
    ok_three_first_total = eq three_first_total, 3
    ok_three_second_predicate = eq three_second_predicate, 3
    ok_three_second_total = eq three_second_total, 3
    ok_three_third_predicate = eq three_third_predicate, 1
    ok_three_third_total = eq three_third_total, 4
    ok_three_row0 = eq three_row0, 2
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_put_invoice
    ok03 = and ok02, ok_put_order
    ok04 = and ok03, ok_put_credit
    ok05 = and ok04, ok_insert0
    ok06 = and ok05, ok_insert1
    ok07 = and ok06, ok_insert2
    ok08 = and ok07, ok_insert3
    ok09 = and ok08, ok_insert4
    ok10 = and ok09, ok_insert5
    ok11 = and ok10, ok_status_index
    ok12 = and ok11, ok_due_index
    ok13 = and ok12, ok_blob_index
    ok14 = and ok13, ok_open
    ok15 = and ok14, ok_status_order_status
    ok16 = and ok15, ok_status_order_written
    ok17 = and ok16, ok_status_order_total
    ok18 = and ok17, ok_status_order_first_predicate
    ok19 = and ok18, ok_status_order_first_total
    ok20 = and ok19, ok_status_order_second_total
    ok21 = and ok20, ok_status_order_row0
    ok22 = and ok21, ok_status_order_row1
    ok23 = and ok22, ok_status_order_page_status
    ok24 = and ok23, ok_status_order_page_written
    ok25 = and ok24, ok_status_order_page_total
    ok26 = and ok25, ok_status_order_page_row0
    ok27 = and ok26, ok_status_invoice_status
    ok28 = and ok27, ok_status_invoice_written
    ok29 = and ok28, ok_status_invoice_total
    ok30 = and ok29, ok_status_invoice_first_predicate
    ok31 = and ok30, ok_status_invoice_first_total
    ok32 = and ok31, ok_status_invoice_second_total
    ok33 = and ok32, ok_status_invoice_row0
    ok34 = and ok33, ok_due_order_status
    ok35 = and ok34, ok_due_order_written
    ok36 = and ok35, ok_due_order_total
    ok37 = and ok36, ok_due_order_first_predicate
    ok38 = and ok37, ok_due_order_first_total
    ok39 = and ok38, ok_due_order_second_total
    ok40 = and ok39, ok_due_order_row0
    ok41 = and ok40, ok_due_invoice_status
    ok42 = and ok41, ok_due_invoice_written
    ok43 = and ok42, ok_due_invoice_total
    ok44 = and ok43, ok_due_invoice_first_predicate
    ok45 = and ok44, ok_due_invoice_first_total
    ok46 = and ok45, ok_due_invoice_second_total
    ok47 = and ok46, ok_due_invoice_row0
    ok48 = and ok47, ok_three_status
    ok49 = and ok48, ok_three_written
    ok50 = and ok49, ok_three_total
    ok51 = and ok50, ok_three_first_predicate
    ok52 = and ok51, ok_three_first_total
    ok53 = and ok52, ok_three_second_predicate
    ok54 = and ok53, ok_three_second_total
    ok55 = and ok54, ok_three_third_predicate
    ok56 = and ok55, ok_three_third_total
    ok57 = and ok56, ok_three_row0
    ok58 = and ok57, ok_close
    ok = and ok58, ok_verify

    !remove_status
    !init_status
    !put_invoice_status
    !put_order_status
    !put_credit_status
    !invoice_id
    !order_id
    !credit_id
    !insert0_status
    !insert1_status
    !insert2_status
    !insert3_status
    !insert4_status
    !insert5_status
    !status_index_status
    !due_index_status
    !blob_index_status
    !open_status
    !read_handle
    !status_order_status
    !status_order_written
    !status_order_total
    !status_order_first_predicate
    !status_order_first_total
    !status_order_second_total
    !status_order_row0
    !status_order_row1
    !status_order_page_status
    !status_order_page_written
    !status_order_page_total
    !status_order_page_row0
    !status_invoice_status
    !status_invoice_written
    !status_invoice_total
    !status_invoice_first_predicate
    !status_invoice_first_total
    !status_invoice_second_total
    !status_invoice_row0
    !due_order_status
    !due_order_written
    !due_order_total
    !due_order_first_predicate
    !due_order_first_total
    !due_order_second_total
    !due_order_row0
    !due_invoice_status
    !due_invoice_written
    !due_invoice_total
    !due_invoice_first_predicate
    !due_invoice_first_total
    !due_invoice_second_total
    !due_invoice_row0
    !three_status
    !three_written
    !three_total
    !three_first_predicate
    !three_first_total
    !three_second_predicate
    !three_second_total
    !three_third_predicate
    !three_third_total
    !three_row0
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_put_invoice
    !ok_put_order
    !ok_put_credit
    !ok_insert0
    !ok_insert1
    !ok_insert2
    !ok_insert3
    !ok_insert4
    !ok_insert5
    !ok_status_index
    !ok_due_index
    !ok_blob_index
    !ok_open
    !ok_status_order_status
    !ok_status_order_written
    !ok_status_order_total
    !ok_status_order_first_predicate
    !ok_status_order_first_total
    !ok_status_order_second_total
    !ok_status_order_row0
    !ok_status_order_row1
    !ok_status_order_page_status
    !ok_status_order_page_written
    !ok_status_order_page_total
    !ok_status_order_page_row0
    !ok_status_invoice_status
    !ok_status_invoice_written
    !ok_status_invoice_total
    !ok_status_invoice_first_predicate
    !ok_status_invoice_first_total
    !ok_status_invoice_second_total
    !ok_status_invoice_row0
    !ok_due_order_status
    !ok_due_order_written
    !ok_due_order_total
    !ok_due_order_first_predicate
    !ok_due_order_first_total
