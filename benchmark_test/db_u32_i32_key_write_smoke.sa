@import "db.sal"

@const ROOT = utf8:"."
@const TABLE_U32 = utf8:"u32_row_write_smoke"
@const TABLE_I32 = utf8:"i32_row_write_smoke"
@const SCHEMA_U32_PATH = utf8:"u32_row_write_smoke.sadb-schema"
@const SCHEMA_I32_PATH = utf8:"i32_row_write_smoke.sadb-schema"
@const SCHEMA_U32 = utf8:"#def MAX_ROWS = 8\n#def COL_CHANNEL_ID_STRIDE = 4 // u32\n#def COL_TOTAL_CENTS_STRIDE = 8 // i64 decimal(2)\n"
@const SCHEMA_I32 = utf8:"#def MAX_ROWS = 8\n#def COL_ADJUSTMENT_STRIDE = 4 // i32\n#def COL_TOTAL_CENTS_STRIDE = 8 // i64 decimal(2)\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 19
#def SCHEMA_PATH_LEN = 31
#def SCHEMA_LEN = 106
#def ROWS = 3
#def KEY_BYTES = 12
#def VALUE_BYTES = 24
#def ROW_BYTES = 12
#def COLUMN_COUNT = 2
#def COLUMNS_BYTES = 32

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    u32_keys = alloc KEY_BYTES
    u32_totals = alloc VALUE_BYTES
    i32_keys = alloc KEY_BYTES
    i32_totals = alloc VALUE_BYTES
    row = alloc ROW_BYTES

    store u32_keys+0, 10 as u32
    store u32_keys+4, 20 as u32
    store u32_keys+8, 30 as u32
    store u32_totals+0, 1000 as i64
    store u32_totals+8, 2000 as i64
    store u32_totals+16, 3000 as i64

    EXPAND DB_REMOVE_TABLE u32_remove_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA u32_init_status, ROOT, ROOT_LEN, SCHEMA_U32_PATH, SCHEMA_PATH_LEN, SCHEMA_U32, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, u32_keys, KEY_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, u32_totals, VALUE_BYTES
    EXPAND DB_INGEST_COLUMNS u32_ingest_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_U32_INDEX u32_index_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, 0, 1, info

    store row+0, 20 as u32
    store row+4, 2200 as i64
    EXPAND DB_UPDATE_ROW_U32_KEY u32_direct_update_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, 0, 20, row, ROW_BYTES, info
    store row+0, 10 as u32
    store row+4, 1100 as i64
    EXPAND DB_UPSERT_ROW_U32_KEY u32_direct_upsert_existing_status, u32_direct_upsert_existing_inserted, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, 0, 10, row, ROW_BYTES, info
    store row+0, 40 as u32
    store row+4, 4000 as i64
    EXPAND DB_UPSERT_ROW_U32_KEY u32_direct_upsert_new_status, u32_direct_upsert_new_inserted, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, 0, 40, row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT u32_rows_after_upsert, info
    EXPAND DB_DELETE_U32_KEY u32_direct_delete_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, 0, 30, info
    EXPAND DB_INFO_ROW_COUNT u32_rows_after_delete, info

    EXPAND DB_TX_BEGIN u32_tx_begin_status, u32_tx, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN
    store row+0, 20 as u32
    store row+4, 2500 as i64
    EXPAND DB_TX_UPSERT_ROW_U32_KEY u32_tx_upsert_existing_status, u32_tx_upsert_existing_inserted, u32_tx, 0, 20, row, ROW_BYTES, info
    store row+0, 40 as u32
    store row+4, 4400 as i64
    EXPAND DB_TX_UPDATE_ROW_U32_KEY u32_tx_update_status, u32_tx, 0, 40, row, ROW_BYTES, info
    store row+0, 50 as u32
    store row+4, 5000 as i64
    EXPAND DB_TX_UPSERT_ROW_U32_KEY u32_tx_upsert_new_status, u32_tx_upsert_new_inserted, u32_tx, 0, 50, row, ROW_BYTES, info
    EXPAND DB_TX_DELETE_U32_KEY u32_tx_delete_status, u32_tx, 0, 10, info
    EXPAND DB_TX_COMMIT u32_tx_commit_status, u32_tx, info
    EXPAND DB_INFO_ROW_COUNT u32_rows_after_commit, info

    EXPAND DB_TX_BEGIN u32_tx2_begin_status, u32_tx2, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN
    store row+0, 99 as u32
    store row+4, 9900 as i64
    EXPAND DB_TX_UPSERT_ROW_U32_KEY u32_tx2_upsert_status, u32_tx2_upsert_inserted, u32_tx2, 0, 99, row, ROW_BYTES, info
    EXPAND DB_TX_ROLLBACK u32_tx2_rollback_status, u32_tx2

    EXPAND DB_OPEN_READ_TABLE u32_open_status, u32_read, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN
    EXPAND DB_FIND_U32_HANDLE u32_find20_status, u32_find20_found, u32_find20_row, u32_read, 0, 20
    EXPAND DB_GET_I64_HANDLE u32_get20_status, u32_total20, u32_read, 1, u32_find20_row
    EXPAND DB_FIND_U32_HANDLE u32_find50_status, u32_find50_found, u32_find50_row, u32_read, 0, 50
    EXPAND DB_GET_I64_HANDLE u32_get50_status, u32_total50, u32_read, 1, u32_find50_row
    EXPAND DB_FIND_U32_HANDLE u32_find10_status, u32_find10_found, u32_find10_row, u32_read, 0, 10
    EXPAND DB_FIND_U32_HANDLE u32_find99_status, u32_find99_found, u32_find99_row, u32_read, 0, 99
    EXPAND DB_CLOSE_READ_TABLE u32_close_status, u32_read
    EXPAND DB_VERIFY u32_verify_status, ROOT, ROOT_LEN, TABLE_U32, TABLE_LEN, info

    store i32_keys+0, -5 as i32
    store i32_keys+4, 0 as i32
    store i32_keys+8, 10 as i32
    store i32_totals+0, 1000 as i64
    store i32_totals+8, 2000 as i64
    store i32_totals+16, 3000 as i64

    EXPAND DB_REMOVE_TABLE i32_remove_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA i32_init_status, ROOT, ROOT_LEN, SCHEMA_I32_PATH, SCHEMA_PATH_LEN, SCHEMA_I32, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, i32_keys, KEY_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, i32_totals, VALUE_BYTES
    EXPAND DB_INGEST_COLUMNS i32_ingest_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_I32_INDEX i32_index_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, 0, 1, info

    store row+0, 0 as i32
    store row+4, 2100 as i64
    EXPAND DB_UPDATE_ROW_I32_KEY i32_direct_update_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, 0, 0, row, ROW_BYTES, info
    store row+0, -5 as i32
    store row+4, 1100 as i64
    EXPAND DB_UPSERT_ROW_I32_KEY i32_direct_upsert_existing_status, i32_direct_upsert_existing_inserted, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, 0, -5, row, ROW_BYTES, info
    store row+0, -10 as i32
    store row+4, 900 as i64
    EXPAND DB_UPSERT_ROW_I32_KEY i32_direct_upsert_new_status, i32_direct_upsert_new_inserted, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, 0, -10, row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT i32_rows_after_upsert, info
    EXPAND DB_DELETE_I32_KEY i32_direct_delete_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, 0, 10, info
    EXPAND DB_INFO_ROW_COUNT i32_rows_after_delete, info

    EXPAND DB_TX_BEGIN i32_tx_begin_status, i32_tx, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN
    store row+0, 0 as i32
    store row+4, 2500 as i64
    EXPAND DB_TX_UPSERT_ROW_I32_KEY i32_tx_upsert_existing_status, i32_tx_upsert_existing_inserted, i32_tx, 0, 0, row, ROW_BYTES, info
    store row+0, -10 as i32
    store row+4, 1000 as i64
    EXPAND DB_TX_UPDATE_ROW_I32_KEY i32_tx_update_status, i32_tx, 0, -10, row, ROW_BYTES, info
    store row+0, 20 as i32
    store row+4, 2000 as i64
    EXPAND DB_TX_UPSERT_ROW_I32_KEY i32_tx_upsert_new_status, i32_tx_upsert_new_inserted, i32_tx, 0, 20, row, ROW_BYTES, info
    EXPAND DB_TX_DELETE_I32_KEY i32_tx_delete_status, i32_tx, 0, -5, info
    EXPAND DB_TX_COMMIT i32_tx_commit_status, i32_tx, info
    EXPAND DB_INFO_ROW_COUNT i32_rows_after_commit, info

    EXPAND DB_TX_BEGIN i32_tx2_begin_status, i32_tx2, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN
    store row+0, 99 as i32
    store row+4, 9900 as i64
    EXPAND DB_TX_UPSERT_ROW_I32_KEY i32_tx2_upsert_status, i32_tx2_upsert_inserted, i32_tx2, 0, 99, row, ROW_BYTES, info
    EXPAND DB_TX_ROLLBACK i32_tx2_rollback_status, i32_tx2

    EXPAND DB_OPEN_READ_TABLE i32_open_status, i32_read, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN
    EXPAND DB_FIND_I32_HANDLE i32_find0_status, i32_find0_found, i32_find0_row, i32_read, 0, 0
    EXPAND DB_GET_I64_HANDLE i32_get0_status, i32_total0, i32_read, 1, i32_find0_row
    EXPAND DB_FIND_I32_HANDLE i32_find20_status, i32_find20_found, i32_find20_row, i32_read, 0, 20
    EXPAND DB_GET_I64_HANDLE i32_get20_status, i32_total20, i32_read, 1, i32_find20_row
    EXPAND DB_FIND_I32_HANDLE i32_findneg5_status, i32_findneg5_found, i32_findneg5_row, i32_read, 0, -5
    EXPAND DB_FIND_I32_HANDLE i32_find99_status, i32_find99_found, i32_find99_row, i32_read, 0, 99
    EXPAND DB_CLOSE_READ_TABLE i32_close_status, i32_read
    EXPAND DB_VERIFY i32_verify_status, ROOT, ROOT_LEN, TABLE_I32, TABLE_LEN, info

    ok01 = eq u32_remove_status, SA_DB_OK
    ok02 = eq u32_init_status, SA_DB_OK
    ok03 = eq u32_ingest_status, SA_DB_OK
    ok04 = eq u32_index_status, SA_DB_OK
    ok05 = eq u32_direct_update_status, SA_DB_OK
    ok06 = eq u32_direct_upsert_existing_status, SA_DB_OK
    ok07 = eq u32_direct_upsert_existing_inserted, 0
    ok08 = eq u32_direct_upsert_new_status, SA_DB_OK
    ok09 = eq u32_direct_upsert_new_inserted, 1
    ok10 = eq u32_rows_after_upsert, 4
    ok11 = eq u32_direct_delete_status, SA_DB_OK
    ok12 = eq u32_rows_after_delete, 3
    ok13 = eq u32_tx_begin_status, SA_DB_OK
    ok14 = eq u32_tx_upsert_existing_status, SA_DB_OK
    ok15 = eq u32_tx_upsert_existing_inserted, 0
    ok16 = eq u32_tx_update_status, SA_DB_OK
    ok17 = eq u32_tx_upsert_new_status, SA_DB_OK
    ok18 = eq u32_tx_upsert_new_inserted, 1
    ok19 = eq u32_tx_delete_status, SA_DB_OK
    ok20 = eq u32_tx_commit_status, SA_DB_OK
    ok21 = eq u32_rows_after_commit, 3
    ok22 = eq u32_tx2_begin_status, SA_DB_OK
    ok23 = eq u32_tx2_upsert_status, SA_DB_OK
    ok24 = eq u32_tx2_upsert_inserted, 1
    ok25 = eq u32_tx2_rollback_status, SA_DB_OK
    ok26 = eq u32_open_status, SA_DB_OK
    ok27 = eq u32_find20_status, SA_DB_OK
    ok28 = eq u32_find20_found, 1
    ok29 = eq u32_get20_status, SA_DB_OK
    ok30 = eq u32_total20, 2500
    ok31 = eq u32_find50_status, SA_DB_OK
    ok32 = eq u32_find50_found, 1
    ok33 = eq u32_get50_status, SA_DB_OK
    ok34 = eq u32_total50, 5000
    ok35 = eq u32_find10_status, SA_DB_OK
    ok36 = eq u32_find10_found, 0
    ok37 = eq u32_find99_status, SA_DB_OK
    ok38 = eq u32_find99_found, 0
    ok39 = eq u32_close_status, SA_DB_OK
    ok40 = eq u32_verify_status, SA_DB_OK
    ok41 = eq i32_remove_status, SA_DB_OK
    ok42 = eq i32_init_status, SA_DB_OK
    ok43 = eq i32_ingest_status, SA_DB_OK
    ok44 = eq i32_index_status, SA_DB_OK
    ok45 = eq i32_direct_update_status, SA_DB_OK
    ok46 = eq i32_direct_upsert_existing_status, SA_DB_OK
    ok47 = eq i32_direct_upsert_existing_inserted, 0
    ok48 = eq i32_direct_upsert_new_status, SA_DB_OK
    ok49 = eq i32_direct_upsert_new_inserted, 1
    ok50 = eq i32_rows_after_upsert, 4
    ok51 = eq i32_direct_delete_status, SA_DB_OK
    ok52 = eq i32_rows_after_delete, 3
    ok53 = eq i32_tx_begin_status, SA_DB_OK
    ok54 = eq i32_tx_upsert_existing_status, SA_DB_OK
    ok55 = eq i32_tx_upsert_existing_inserted, 0
    ok56 = eq i32_tx_update_status, SA_DB_OK
    ok57 = eq i32_tx_upsert_new_status, SA_DB_OK
    ok58 = eq i32_tx_upsert_new_inserted, 1
    ok59 = eq i32_tx_delete_status, SA_DB_OK
    ok60 = eq i32_tx_commit_status, SA_DB_OK
    ok61 = eq i32_rows_after_commit, 3
    ok62 = eq i32_tx2_begin_status, SA_DB_OK
    ok63 = eq i32_tx2_upsert_status, SA_DB_OK
    ok64 = eq i32_tx2_upsert_inserted, 1
    ok65 = eq i32_tx2_rollback_status, SA_DB_OK
    ok66 = eq i32_open_status, SA_DB_OK
    ok67 = eq i32_find0_status, SA_DB_OK
    ok68 = eq i32_find0_found, 1
    ok69 = eq i32_get0_status, SA_DB_OK
    ok70 = eq i32_total0, 2500
    ok71 = eq i32_find20_status, SA_DB_OK
    ok72 = eq i32_find20_found, 1
    ok73 = eq i32_get20_status, SA_DB_OK
    ok74 = eq i32_total20, 2000
    ok75 = eq i32_findneg5_status, SA_DB_OK
    ok76 = eq i32_findneg5_found, 0
    ok77 = eq i32_find99_status, SA_DB_OK
    ok78 = eq i32_find99_found, 0
    ok79 = eq i32_close_status, SA_DB_OK
    ok80 = eq i32_verify_status, SA_DB_OK

    pass01 = and ok01, ok02
    pass02 = and pass01, ok03
    pass03 = and pass02, ok04
    pass04 = and pass03, ok05
    pass05 = and pass04, ok06
    pass06 = and pass05, ok07
    pass07 = and pass06, ok08
    pass08 = and pass07, ok09
    pass09 = and pass08, ok10
    pass10 = and pass09, ok11
    pass11 = and pass10, ok12
    pass12 = and pass11, ok13
    pass13 = and pass12, ok14
    pass14 = and pass13, ok15
    pass15 = and pass14, ok16
    pass16 = and pass15, ok17
    pass17 = and pass16, ok18
