    ok23 = and ok22, ok_u8_max_status
    ok24 = and ok23, ok_u8_max
    ok25 = and ok24, ok_i8_count_status
    ok26 = and ok25, ok_i8_lt_count
    ok27 = and ok26, ok_i8_find_status
    ok28 = and ok27, ok_i8_found
    ok29 = and ok28, ok_i8_row
