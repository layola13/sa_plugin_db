    !null_ptr
    return ok

@insert_invoices(db: ptr, null_ptr: ptr) -> u64:
L_ENTRY:
    stmt_slot = stack_alloc 8
    i_slot = stack_alloc 8
    ok_slot = stack_alloc 8
    prepare_status = call @sqlite3_prepare_v2(*db, *SQL_INSERT_INVOICES, -1, *stmt_slot, *null_ptr)
    stmt = load stmt_slot+0 as ptr
    ok_prepare = eq prepare_status, SQLITE_OK
    store ok_slot+0, ok_prepare as u64
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, INVOICE_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    id_value = add i, 1
    order_value = add i, 1
    status_bit = and i, 1
    status_value = add status_bit, 1
    due_offset = and i, 63
    due_value = add BASE_DAY, due_offset
    amount_value = mul id_value, 100
    bind1 = call @sqlite3_bind_int64(*stmt, 1, id_value)
    bind2 = call @sqlite3_bind_int64(*stmt, 2, order_value)
    bind3 = call @sqlite3_bind_int64(*stmt, 3, status_value)
    bind4 = call @sqlite3_bind_int64(*stmt, 4, due_value)
    bind5 = call @sqlite3_bind_int64(*stmt, 5, amount_value)
    step_status = call @sqlite3_step(*stmt)
    reset_status = call @sqlite3_reset(*stmt)
    clear_status = call @sqlite3_clear_bindings(*stmt)
    ok_bind1 = eq bind1, SQLITE_OK
    ok_bind2 = eq bind2, SQLITE_OK
    ok_bind3 = eq bind3, SQLITE_OK
    ok_bind4 = eq bind4, SQLITE_OK
    ok_bind5 = eq bind5, SQLITE_OK
    ok_step = eq step_status, SQLITE_DONE
    ok_reset = eq reset_status, SQLITE_OK
    ok_clear = eq clear_status, SQLITE_OK
    ok01 = and ok_bind1, ok_bind2
    ok02 = and ok_bind3, ok_bind4
    ok03 = and ok01, ok02
    ok04 = and ok03, ok_bind5
    ok05 = and ok04, ok_step
    ok06 = and ok05, ok_reset
    ok_row = and ok06, ok_clear
    ok_acc = load ok_slot+0 as u64
    ok_next = and ok_acc, ok_row
    next_i = add i, 1
    store ok_slot+0, ok_next as u64
    store i_slot+0, next_i as u64
    !i
    !cond
    !id_value
    !order_value
    !status_bit
    !status_value
    !due_offset
    !due_value
    !amount_value
    !bind1
    !bind2
    !bind3
    !bind4
    !bind5
    !step_status
    !reset_status
    !clear_status
    !ok_bind1
    !ok_bind2
    !ok_bind3
    !ok_bind4
    !ok_bind5
    !ok_step
    !ok_reset
    !ok_clear
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok_row
    !ok_acc
    !ok_next
    !next_i
    jmp L_COND

L_DONE:
    finalize_status = call @sqlite3_finalize(*stmt)
    ok_finalize = eq finalize_status, SQLITE_OK
    ok_acc = load ok_slot+0 as u64
    ok = and ok_acc, ok_finalize
    !i
    !cond
    !prepare_status
    !stmt
    !ok_prepare
    !finalize_status
    !ok_finalize
    !ok_acc
    !db
    !null_ptr
    return ok

@ffi_wrapper sqlite_erp_workflow_bench_impl() -> i32:
L_ENTRY:
    db_slot = stack_alloc 8
    stmt_slot = stack_alloc 8
    null_slot = stack_alloc 8
    project_i_slot = stack_alloc 8
    store null_slot+0, 0 as ptr
    null_ptr = load null_slot+0 as ptr
    remove_file_status = call @sa_fs_remove_file(&DB_PATH_FS, DB_PATH_FS_LEN)
    !remove_file_status

    t_init0 = call @sa_time_instant_ns()
    open_status = call @sqlite3_open_v2(*DB_PATH_C, *db_slot, SQLITE_OPEN_READWRITE_CREATE, *null_ptr)
    db = load db_slot+0 as ptr
    pragma_status = call @sqlite3_exec(*db, *SQL_PRAGMA, *null_ptr, *null_ptr, *null_ptr)
    create_status = call @sqlite3_exec(*db, *SQL_CREATE, *null_ptr, *null_ptr, *null_ptr)
    t_init1 = call @sa_time_instant_ns()
    sqlite_erp_init_ns = sub t_init1, t_init0

    t_ingest0 = call @sa_time_instant_ns()
    begin_status = call @sqlite3_exec(*db, *SQL_BEGIN, *null_ptr, *null_ptr, *null_ptr)
    customers_ok = call @insert_customers(db, null_ptr)
    products_ok = call @insert_products(db, null_ptr)
    orders_ok = call @insert_orders(db, null_ptr)
    lines_ok = call @insert_lines(db, null_ptr)
    inventory_ok = call @insert_inventory(db, null_ptr)
    invoices_ok = call @insert_invoices(db, null_ptr)
    commit_status = call @sqlite3_exec(*db, *SQL_COMMIT, *null_ptr, *null_ptr, *null_ptr)
    t_ingest1 = call @sa_time_instant_ns()
    sqlite_erp_ingest_ns = sub t_ingest1, t_ingest0

    t_index0 = call @sa_time_instant_ns()
    index_status = call @sqlite3_exec(*db, *SQL_INDEX, *null_ptr, *null_ptr, *null_ptr)
    t_index1 = call @sa_time_instant_ns()
    sqlite_erp_index_ns = sub t_index1, t_index0

    t_lines0 = call @sa_time_instant_ns()
    EXPAND SQLITE_COUNT_QUERY order_line_count_ok, order_line_total, db, null_ptr, SQL_ORDER_LINES
    t_lines1 = call @sa_time_instant_ns()
    sqlite_erp_order_lines_ns = sub t_lines1, t_lines0

    t_project0 = call @sa_time_instant_ns()
    project_prepare_status = call @sqlite3_prepare_v2(*db, *SQL_PROJECT_LINES, -1, *stmt_slot, *null_ptr)
    project_stmt = load stmt_slot+0 as ptr
    store project_i_slot+0, 0 as u64
    project_ok_slot = stack_alloc 8
    store project_ok_slot+0, 1 as u64
    first_product_slot = stack_alloc 8
    first_qty_slot = stack_alloc 8
    first_net_slot = stack_alloc 8
    store first_product_slot+0, 0 as u64
    store first_qty_slot+0, 0 as u64
    store first_net_slot+0, 0 as u64
    ok_project_prepare = eq project_prepare_status, SQLITE_OK
    store project_ok_slot+0, ok_project_prepare as u64
    jmp L_PROJECT_COND

L_PROJECT_COND:
    project_i = load project_i_slot+0 as u64
    project_cond = ult project_i, EXPECTED_ORDER_LINES
    br project_cond -> L_PROJECT_BODY, L_PROJECT_DONE

L_PROJECT_BODY:
    project_step = call @sqlite3_step(*project_stmt)
    product_value = call @sqlite3_column_int64(*project_stmt, 0)
    qty_value = call @sqlite3_column_int64(*project_stmt, 1)
    net_value = call @sqlite3_column_int64(*project_stmt, 2)
    ok_project_step = eq project_step, SQLITE_ROW
    is_first_project = eq project_i, 0
    br is_first_project -> L_PROJECT_FIRST, L_PROJECT_AFTER_FIRST

L_PROJECT_FIRST:
    store first_product_slot+0, product_value as u64
    store first_qty_slot+0, qty_value as u64
    store first_net_slot+0, net_value as u64
    jmp L_PROJECT_AFTER_FIRST

L_PROJECT_AFTER_FIRST:
    project_ok_acc = load project_ok_slot+0 as u64
    project_ok_next = and project_ok_acc, ok_project_step
    next_project_i = add project_i, 1
    store project_ok_slot+0, project_ok_next as u64
    store project_i_slot+0, next_project_i as u64
    !project_i
    !project_cond
    !project_step
    !product_value
    !qty_value
    !net_value
    !ok_project_step
    !is_first_project
    !project_ok_acc
    !project_ok_next
    !next_project_i
    jmp L_PROJECT_COND

L_PROJECT_DONE:
    project_finalize_status = call @sqlite3_finalize(*project_stmt)
    ok_project_finalize = eq project_finalize_status, SQLITE_OK
    project_ok_acc_final = load project_ok_slot+0 as u64
    project_ok = and project_ok_acc_final, ok_project_finalize
    project_written_rows = load project_i_slot+0 as u64
    project_first_product = load first_product_slot+0 as u64
    project_first_qty = load first_qty_slot+0 as u64
    project_first_net = load first_net_slot+0 as u64
    t_project1 = call @sa_time_instant_ns()
    sqlite_erp_project_ns = sub t_project1, t_project0

    t_customer0 = call @sa_time_instant_ns()
    EXPAND SQLITE_COUNT_QUERY customer_orders_ok, customer_order_total, db, null_ptr, SQL_CUSTOMER_ORDERS
    t_customer1 = call @sa_time_instant_ns()
    sqlite_erp_customer_orders_ns = sub t_customer1, t_customer0

    t_due0 = call @sa_time_instant_ns()
    EXPAND SQLITE_COUNT_QUERY due_invoices_ok, due_invoice_total, db, null_ptr, SQL_DUE_INVOICES
    EXPAND SQLITE_COUNT_QUERY paid_invoices_ok, paid_invoice_count, db, null_ptr, SQL_PAID_INVOICES
    t_due1 = call @sa_time_instant_ns()
    sqlite_erp_due_invoices_ns = sub t_due1, t_due0

    t_inventory0 = call @sa_time_instant_ns()
    EXPAND SQLITE_COUNT_QUERY inventory_ok_query, inventory_total, db, null_ptr, SQL_INVENTORY
    t_inventory1 = call @sa_time_instant_ns()
    sqlite_erp_inventory_ns = sub t_inventory1, t_inventory0

    t_verify0 = call @sa_time_instant_ns()
    check_prepare_status = call @sqlite3_prepare_v2(*db, *SQL_CHECK, -1, *stmt_slot, *null_ptr)
    check_stmt = load stmt_slot+0 as ptr
    check_step_status = call @sqlite3_step(*check_stmt)
    check_finalize_status = call @sqlite3_finalize(*check_stmt)
    t_verify1 = call @sa_time_instant_ns()
    sqlite_erp_verify_ns = sub t_verify1, t_verify0
    close_status = call @sqlite3_close(*db)

    EXPAND PRINT_U64_LINE SQLITE_ERP_INIT, SQLITE_ERP_INIT_LEN, sqlite_erp_init_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_INGEST, SQLITE_ERP_INGEST_LEN, sqlite_erp_ingest_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_INDEX, SQLITE_ERP_INDEX_LEN, sqlite_erp_index_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_ORDER_LINES, SQLITE_ERP_ORDER_LINES_LEN, sqlite_erp_order_lines_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_PROJECT, SQLITE_ERP_PROJECT_LEN, sqlite_erp_project_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_CUSTOMER_ORDERS, SQLITE_ERP_CUSTOMER_ORDERS_LEN, sqlite_erp_customer_orders_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_DUE_INVOICES, SQLITE_ERP_DUE_INVOICES_LEN, sqlite_erp_due_invoices_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_INVENTORY, SQLITE_ERP_INVENTORY_LEN, sqlite_erp_inventory_ns
    EXPAND PRINT_U64_LINE SQLITE_ERP_VERIFY, SQLITE_ERP_VERIFY_LEN, sqlite_erp_verify_ns
    EXPAND PRINT_U64_LINE ORDER_LINE_TOTAL, ORDER_LINE_TOTAL_LEN, order_line_total
    EXPAND PRINT_U64_LINE CUSTOMER_ORDER_TOTAL, CUSTOMER_ORDER_TOTAL_LEN, customer_order_total
    EXPAND PRINT_U64_LINE DUE_INVOICE_TOTAL, DUE_INVOICE_TOTAL_LEN, due_invoice_total
    EXPAND PRINT_U64_LINE INVENTORY_MOVE_TOTAL, INVENTORY_MOVE_TOTAL_LEN, inventory_total
    EXPAND PRINT_U64_LINE PROJECT_WRITTEN_ROWS, PROJECT_WRITTEN_ROWS_LEN, project_written_rows
    EXPAND PRINT_U64_LINE PAID_INVOICE_COUNT, PAID_INVOICE_COUNT_LEN, paid_invoice_count

    ok_open = eq open_status, SQLITE_OK
    ok_pragma = eq pragma_status, SQLITE_OK
    ok_create = eq create_status, SQLITE_OK
    ok_begin = eq begin_status, SQLITE_OK
    ok_customers = eq customers_ok, 1
    ok_products = eq products_ok, 1
    ok_orders = eq orders_ok, 1
    ok_lines = eq lines_ok, 1
    ok_inventory_insert = eq inventory_ok, 1
    ok_invoices = eq invoices_ok, 1
    ok_commit = eq commit_status, SQLITE_OK
    ok_index = eq index_status, SQLITE_OK
    ok_order_line_count = eq order_line_count_ok, 1
    ok_order_line_total = eq order_line_total, EXPECTED_ORDER_LINES
    ok_project = eq project_ok, 1
    ok_project_written = eq project_written_rows, EXPECTED_ORDER_LINES
    ok_project_product = eq project_first_product, EXPECTED_PROJECT_FIRST_PRODUCT
    ok_project_qty = eq project_first_qty, EXPECTED_PROJECT_FIRST_QTY
    ok_project_net = eq project_first_net, EXPECTED_PROJECT_FIRST_NET
    ok_customer_count = eq customer_orders_ok, 1
    ok_customer_total = eq customer_order_total, EXPECTED_CUSTOMER_ORDERS
    ok_due_count = eq due_invoices_ok, 1
    ok_due_total = eq due_invoice_total, EXPECTED_DUE_INVOICES
    ok_paid_count_status = eq paid_invoices_ok, 1
    ok_paid_count = eq paid_invoice_count, EXPECTED_PAID_INVOICES
    ok_inventory_count = eq inventory_ok_query, 1
    ok_inventory_total = eq inventory_total, EXPECTED_INVENTORY_MOVES
    ok_check_prepare = eq check_prepare_status, SQLITE_OK
    ok_check_step = eq check_step_status, SQLITE_ROW
    ok_check_finalize = eq check_finalize_status, SQLITE_OK
    ok_close = eq close_status, SQLITE_OK

    ok01 = and ok_open, ok_pragma
    ok02 = and ok01, ok_create
    ok03 = and ok02, ok_begin
    ok04 = and ok03, ok_customers
    ok05 = and ok04, ok_products
    ok06 = and ok05, ok_orders
    ok07 = and ok06, ok_lines
    ok08 = and ok07, ok_inventory_insert
    ok09 = and ok08, ok_invoices
    ok10 = and ok09, ok_commit
    ok11 = and ok10, ok_index
    ok12 = and ok11, ok_order_line_count
    ok13 = and ok12, ok_order_line_total
    ok14 = and ok13, ok_project
    ok15 = and ok14, ok_project_written
    ok16 = and ok15, ok_project_product
    ok17 = and ok16, ok_project_qty
    ok18 = and ok17, ok_project_net
    ok19 = and ok18, ok_customer_count
    ok20 = and ok19, ok_customer_total
    ok21 = and ok20, ok_due_count
    ok22 = and ok21, ok_due_total
    ok23 = and ok22, ok_paid_count_status
    ok24 = and ok23, ok_paid_count
    ok25 = and ok24, ok_inventory_count
    ok26 = and ok25, ok_inventory_total
    ok27 = and ok26, ok_check_prepare
    ok28 = and ok27, ok_check_step
    ok29 = and ok28, ok_check_finalize
    ok = and ok29, ok_close

    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9301)

@main() -> i32:
L_MAIN:
    code = call @sqlite_erp_workflow_bench_impl()
    return code
