    !finalize_status
    !ok_finalize
    !ok_acc
    !db
    !null_ptr
    return ok

@insert_lines(db: ptr, null_ptr: ptr) -> u64:
L_ENTRY:
    stmt_slot = stack_alloc 8
    i_slot = stack_alloc 8
    ok_slot = stack_alloc 8
    prepare_status = call @sqlite3_prepare_v2(*db, *SQL_INSERT_LINES, -1, *stmt_slot, *null_ptr)
    stmt = load stmt_slot+0 as ptr
    ok_prepare = eq prepare_status, SQLITE_OK
    store ok_slot+0, ok_prepare as u64
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, LINE_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    order_base = lshr i, 2
    order_value = add order_base, 1
    line_low = and i, 3
    line_value = add line_low, 1
    product_low = and i, 511
    product_value = add product_low, 1
    qty_low = and i, 7
    qty_value = add qty_low, 1
    net_value = mul qty_value, 250
    bind1 = call @sqlite3_bind_int64(*stmt, 1, order_value)
    bind2 = call @sqlite3_bind_int64(*stmt, 2, line_value)
    bind3 = call @sqlite3_bind_int64(*stmt, 3, product_value)
    bind4 = call @sqlite3_bind_int64(*stmt, 4, qty_value)
    bind5 = call @sqlite3_bind_int64(*stmt, 5, net_value)
    step_status = call @sqlite3_step(*stmt)
    reset_status = call @sqlite3_reset(*stmt)
    clear_status = call @sqlite3_clear_bindings(*stmt)
    ok_bind1 = eq bind1, SQLITE_OK
    ok_bind2 = eq bind2, SQLITE_OK
    ok_bind3 = eq bind3, SQLITE_OK
    ok_bind4 = eq bind4, SQLITE_OK
    ok_bind5 = eq bind5, SQLITE_OK
    ok_step = eq step_status, SQLITE_DONE
    ok_reset = eq reset_status, SQLITE_OK
    ok_clear = eq clear_status, SQLITE_OK
    ok01 = and ok_bind1, ok_bind2
    ok02 = and ok_bind3, ok_bind4
    ok03 = and ok01, ok02
    ok04 = and ok03, ok_bind5
    ok05 = and ok04, ok_step
    ok06 = and ok05, ok_reset
    ok_row = and ok06, ok_clear
    ok_acc = load ok_slot+0 as u64
    ok_next = and ok_acc, ok_row
    next_i = add i, 1
    store ok_slot+0, ok_next as u64
    store i_slot+0, next_i as u64
    !i
    !cond
    !order_base
    !order_value
    !line_low
    !line_value
    !product_low
    !product_value
    !qty_low
    !qty_value
    !net_value
    !bind1
    !bind2
    !bind3
    !bind4
    !bind5
    !step_status
    !reset_status
    !clear_status
    !ok_bind1
    !ok_bind2
    !ok_bind3
    !ok_bind4
    !ok_bind5
    !ok_step
    !ok_reset
    !ok_clear
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok_row
    !ok_acc
    !ok_next
    !next_i
    jmp L_COND

L_DONE:
    finalize_status = call @sqlite3_finalize(*stmt)
    ok_finalize = eq finalize_status, SQLITE_OK
    ok_acc = load ok_slot+0 as u64
    ok = and ok_acc, ok_finalize
    !i
    !cond
    !prepare_status
    !stmt
    !ok_prepare
    !finalize_status
    !ok_finalize
    !ok_acc
    !db
    !null_ptr
    return ok

