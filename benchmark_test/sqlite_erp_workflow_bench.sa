    ok_next = and ok_acc, ok_row
    next_i = add i, 1
    store ok_slot+0, ok_next as u64
    store i_slot+0, next_i as u64
    !i
    !cond
    !id_value
    !customer_low
    !customer_value
    !status_bit
    !status_value
    !day_offset
    !day_value
    !bind1
    !bind2
    !bind3
    !bind4
    !step_status
    !reset_status
    !clear_status
    !ok_bind1
    !ok_bind2
    !ok_bind3
    !ok_bind4
    !ok_step
    !ok_reset
    !ok_clear
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok_row
    !ok_acc
    !ok_next
    !next_i
    jmp L_COND

L_DONE:
    finalize_status = call @sqlite3_finalize(*stmt)
    ok_finalize = eq finalize_status, SQLITE_OK
    ok_acc = load ok_slot+0 as u64
