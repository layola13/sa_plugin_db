@import "sa_std/fmt.sai"
@import "sa_std/fs.sai"
@import "sa_std/io/print.sai"
@import "sa_std/time.sai"

@extern sqlite3_open_v2(*filename: ptr, *out_db: ptr, flags: i32, *vfs: ptr) -> i32
@extern sqlite3_close(*db: ptr) -> i32
@extern sqlite3_exec(*db: ptr, *sql: ptr, *callback: ptr, *arg: ptr, *errmsg: ptr) -> i32
@extern sqlite3_prepare_v2(*db: ptr, *sql: ptr, nbyte: i32, *out_stmt: ptr, *tail: ptr) -> i32
@extern sqlite3_bind_int64(*stmt: ptr, idx: i32, value: u64) -> i32
@extern sqlite3_step(*stmt: ptr) -> i32
@extern sqlite3_reset(*stmt: ptr) -> i32
@extern sqlite3_clear_bindings(*stmt: ptr) -> i32
@extern sqlite3_finalize(*stmt: ptr) -> i32
@extern sqlite3_column_int64(*stmt: ptr, col: i32) -> u64

@const DB_PATH_FS = utf8:"sqlite_erp_workflow.db"
@const DB_PATH_C = utf8:"sqlite_erp_workflow.db\0"
@const SQL_PRAGMA = utf8:"PRAGMA journal_mode=OFF; PRAGMA synchronous=OFF; PRAGMA temp_store=MEMORY;\0"
@const SQL_CREATE = utf8:"CREATE TABLE customers(id INTEGER PRIMARY KEY, tier INTEGER, credit_cents INTEGER); CREATE TABLE products(id INTEGER PRIMARY KEY, category INTEGER, price_cents INTEGER); CREATE TABLE orders(id INTEGER PRIMARY KEY, customer_id INTEGER, status INTEGER, order_day INTEGER); CREATE TABLE order_lines(order_id INTEGER, line_no INTEGER, product_id INTEGER, qty INTEGER, net_cents INTEGER, PRIMARY KEY(order_id, line_no)); CREATE TABLE inventory(product_id INTEGER, move_seq INTEGER, qty_delta INTEGER, PRIMARY KEY(product_id, move_seq)); CREATE TABLE invoices(id INTEGER PRIMARY KEY, order_id INTEGER UNIQUE, status INTEGER, due_day INTEGER, amount_cents INTEGER);\0"
@const SQL_INDEX = utf8:"CREATE INDEX idx_orders_customer_day ON orders(customer_id, order_day); CREATE INDEX idx_lines_product ON order_lines(product_id); CREATE INDEX idx_invoices_status_due ON invoices(status, due_day);\0"
@const SQL_BEGIN = utf8:"BEGIN TRANSACTION;\0"
@const SQL_COMMIT = utf8:"COMMIT;\0"
@const SQL_INSERT_CUSTOMERS = utf8:"INSERT INTO customers(id, tier, credit_cents) VALUES(?, ?, ?);\0"
@const SQL_INSERT_PRODUCTS = utf8:"INSERT INTO products(id, category, price_cents) VALUES(?, ?, ?);\0"
@const SQL_INSERT_ORDERS = utf8:"INSERT INTO orders(id, customer_id, status, order_day) VALUES(?, ?, ?, ?);\0"
@const SQL_INSERT_LINES = utf8:"INSERT INTO order_lines(order_id, line_no, product_id, qty, net_cents) VALUES(?, ?, ?, ?, ?);\0"
@const SQL_INSERT_INVENTORY = utf8:"INSERT INTO inventory(product_id, move_seq, qty_delta) VALUES(?, ?, ?);\0"
@const SQL_INSERT_INVOICES = utf8:"INSERT INTO invoices(id, order_id, status, due_day, amount_cents) VALUES(?, ?, ?, ?, ?);\0"
@const SQL_ORDER_LINES = utf8:"SELECT COUNT(*) FROM order_lines WHERE order_id = 1234;\0"
@const SQL_PROJECT_LINES = utf8:"SELECT product_id, qty, net_cents FROM order_lines WHERE order_id = 1234 ORDER BY line_no;\0"
@const SQL_CUSTOMER_ORDERS = utf8:"SELECT COUNT(*) FROM orders WHERE customer_id = 17 AND order_day BETWEEN 20464 AND 20473;\0"
@const SQL_DUE_INVOICES = utf8:"SELECT COUNT(*) FROM invoices WHERE status = 1 AND due_day BETWEEN 20464 AND 20473;\0"
@const SQL_PAID_INVOICES = utf8:"SELECT COUNT(*) FROM invoices WHERE status = 1;\0"
@const SQL_INVENTORY = utf8:"SELECT COUNT(*) FROM inventory WHERE product_id = 42;\0"
@const SQL_CHECK = utf8:"PRAGMA integrity_check;\0"
@const NL = utf8:"\n"

@const SQLITE_ERP_INIT = utf8:"sqlite_erp_init_ns="
@const SQLITE_ERP_INGEST = utf8:"sqlite_erp_ingest_ns="
@const SQLITE_ERP_INDEX = utf8:"sqlite_erp_index_ns="
@const SQLITE_ERP_ORDER_LINES = utf8:"sqlite_erp_order_lines_ns="
@const SQLITE_ERP_CUSTOMER_ORDERS = utf8:"sqlite_erp_customer_orders_ns="
@const SQLITE_ERP_DUE_INVOICES = utf8:"sqlite_erp_due_invoices_ns="
@const SQLITE_ERP_INVENTORY = utf8:"sqlite_erp_inventory_ns="
@const SQLITE_ERP_PROJECT = utf8:"sqlite_erp_project_ns="
@const SQLITE_ERP_VERIFY = utf8:"sqlite_erp_verify_ns="
@const ORDER_LINE_TOTAL = utf8:"order_line_total="
@const CUSTOMER_ORDER_TOTAL = utf8:"customer_order_total="
@const DUE_INVOICE_TOTAL = utf8:"due_invoice_total="
@const INVENTORY_MOVE_TOTAL = utf8:"inventory_move_total="
@const PROJECT_WRITTEN_ROWS = utf8:"project_written_rows="
@const PAID_INVOICE_COUNT = utf8:"paid_invoice_count="

#def DB_PATH_FS_LEN = 22
#def SQLITE_OPEN_READWRITE_CREATE = 6
#def SQLITE_OK = 0
#def SQLITE_ROW = 100
#def SQLITE_DONE = 101
#def CUSTOMER_ROWS = 1024
#def PRODUCT_ROWS = 512
#def ORDER_ROWS = 8192
#def LINE_ROWS = 32768
#def INVENTORY_ROWS = 16384
#def INVOICE_ROWS = 8192
#def BASE_DAY = 20454
#def EXPECTED_CUSTOMER_ORDERS = 8
#def EXPECTED_ORDER_LINES = 4
#def EXPECTED_INVENTORY_MOVES = 32
#def EXPECTED_DUE_INVOICES = 640
#def EXPECTED_PAID_INVOICES = 4096
#def EXPECTED_PROJECT_FIRST_PRODUCT = 325
#def EXPECTED_PROJECT_FIRST_QTY = 5
#def EXPECTED_PROJECT_FIRST_NET = 1250
#def FMT_BUF_BYTES = 32

#def SQLITE_ERP_INIT_LEN = 19
#def SQLITE_ERP_INGEST_LEN = 21
#def SQLITE_ERP_INDEX_LEN = 20
#def SQLITE_ERP_ORDER_LINES_LEN = 26
#def SQLITE_ERP_CUSTOMER_ORDERS_LEN = 30
#def SQLITE_ERP_DUE_INVOICES_LEN = 27
#def SQLITE_ERP_INVENTORY_LEN = 24
#def SQLITE_ERP_PROJECT_LEN = 22
#def SQLITE_ERP_VERIFY_LEN = 21
#def ORDER_LINE_TOTAL_LEN = 17
#def CUSTOMER_ORDER_TOTAL_LEN = 21
#def DUE_INVOICE_TOTAL_LEN = 18
#def INVENTORY_MOVE_TOTAL_LEN = 21
#def PROJECT_WRITTEN_ROWS_LEN = 21
#def PAID_INVOICE_COUNT_LEN = 19

[MACRO] PRINT_U64_LINE %label, %label_len, %value
    __fmt_buf_%value = stack_alloc FMT_BUF_BYTES
    __fmt_len_slot_%value = stack_alloc 8
    __fmt_status_%value = call @sa_fmt_u64_into(%value, 10, __fmt_buf_%value, FMT_BUF_BYTES, &__fmt_len_slot_%value)
    __fmt_len_%value = load __fmt_len_slot_%value+0 as u64
    call @sa_print_bytes(&%label, %label_len)
    call @sa_print_bytes(&__fmt_buf_%value, __fmt_len_%value)
    call @sa_print_bytes(&NL, 1)
    !__fmt_status_%value
    !__fmt_len_%value
[END_MACRO]

[MACRO] SQLITE_COUNT_QUERY %out_ok, %out_value, %db, %null_ptr, %sql
    __count_stmt_slot_%out_value = stack_alloc 8
    __count_prepare_%out_value = call @sqlite3_prepare_v2(*%db, *%sql, -1, *__count_stmt_slot_%out_value, *%null_ptr)
    __count_stmt_%out_value = load __count_stmt_slot_%out_value+0 as ptr
    __count_step_%out_value = call @sqlite3_step(*__count_stmt_%out_value)
    %out_value = call @sqlite3_column_int64(*__count_stmt_%out_value, 0)
    __count_finalize_%out_value = call @sqlite3_finalize(*__count_stmt_%out_value)
    __count_ok_prepare_%out_value = eq __count_prepare_%out_value, SQLITE_OK
    __count_ok_step_%out_value = eq __count_step_%out_value, SQLITE_ROW
    __count_ok_finalize_%out_value = eq __count_finalize_%out_value, SQLITE_OK
    __count_ok01_%out_value = and __count_ok_prepare_%out_value, __count_ok_step_%out_value
    %out_ok = and __count_ok01_%out_value, __count_ok_finalize_%out_value
    !__count_prepare_%out_value
    !__count_stmt_%out_value
    !__count_step_%out_value
    !__count_finalize_%out_value
    !__count_ok_prepare_%out_value
    !__count_ok_step_%out_value
    !__count_ok_finalize_%out_value
    !__count_ok01_%out_value
[END_MACRO]

@insert_customers(db: ptr, null_ptr: ptr) -> u64:
L_ENTRY:
    stmt_slot = stack_alloc 8
    i_slot = stack_alloc 8
    ok_slot = stack_alloc 8
    prepare_status = call @sqlite3_prepare_v2(*db, *SQL_INSERT_CUSTOMERS, -1, *stmt_slot, *null_ptr)
    stmt = load stmt_slot+0 as ptr
    ok_prepare = eq prepare_status, SQLITE_OK
    store ok_slot+0, ok_prepare as u64
    store i_slot+0, 0 as u64
    jmp L_COND

L_COND:
    i = load i_slot+0 as u64
    cond = ult i, CUSTOMER_ROWS
    br cond -> L_BODY, L_DONE

L_BODY:
    id_value = add i, 1
    tier_low = and i, 3
    tier_value = add tier_low, 1
    credit_value = mul id_value, 100
    bind1 = call @sqlite3_bind_int64(*stmt, 1, id_value)
    bind2 = call @sqlite3_bind_int64(*stmt, 2, tier_value)
    bind3 = call @sqlite3_bind_int64(*stmt, 3, credit_value)
    step_status = call @sqlite3_step(*stmt)
    reset_status = call @sqlite3_reset(*stmt)
    clear_status = call @sqlite3_clear_bindings(*stmt)
    ok_bind1 = eq bind1, SQLITE_OK
    ok_bind2 = eq bind2, SQLITE_OK
    ok_bind3 = eq bind3, SQLITE_OK
    ok_step = eq step_status, SQLITE_DONE
    ok_reset = eq reset_status, SQLITE_OK
    ok_clear = eq clear_status, SQLITE_OK
    ok01 = and ok_bind1, ok_bind2
    ok02 = and ok01, ok_bind3
    ok03 = and ok02, ok_step
    ok04 = and ok03, ok_reset
    ok_row = and ok04, ok_clear
    ok_acc = load ok_slot+0 as u64
    ok_next = and ok_acc, ok_row
    next_i = add i, 1
    store ok_slot+0, ok_next as u64
    store i_slot+0, next_i as u64
    !i
    !cond
    !id_value
    !tier_low
    !tier_value
    !credit_value
    !bind1
    !bind2
    !bind3
    !step_status
    !reset_status
    !clear_status
    !ok_bind1
    !ok_bind2
    !ok_bind3
    !ok_step
    !ok_reset
    !ok_clear
    !ok01
    !ok02
    !ok03
    !ok04
    !ok_row
    !ok_acc
    !ok_next
    !next_i
    jmp L_COND

L_DONE:
    finalize_status = call @sqlite3_finalize(*stmt)
    ok_finalize = eq finalize_status, SQLITE_OK
    ok_acc = load ok_slot+0 as u64
    ok = and ok_acc, ok_finalize
    !i
    !cond
    !prepare_status
    !stmt
    !ok_prepare
    !finalize_status
    !ok_finalize
    !ok_acc
    !db
    !null_ptr
    return ok

