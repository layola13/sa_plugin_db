@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"blob_token_items"
@const SCHEMA_PATH = utf8:"blob_token_items.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_NOTE_STRIDE = 8 // blob_handle\n"
@const STORE = utf8:"notes"
@const VALUE_A = utf8:"Blue Widget SKU-001"
@const VALUE_B = utf8:"red widget sku_002"
@const VALUE_C = utf8:"invoice paid customer"
@const TOKEN_WIDGET = utf8:"WIDGET"
@const TOKEN_PAID = utf8:"paid"
@const TOKEN_INVALID = utf8:"two words"

#def ROOT_LEN = 1
#def TABLE_LEN = 16
#def SCHEMA_PATH_LEN = 28
#def SCHEMA_LEN = 88
#def STORE_LEN = 5
#def VALUE_A_LEN = 19
#def VALUE_B_LEN = 18
#def VALUE_C_LEN = 21
#def TOKEN_WIDGET_LEN = 6
#def TOKEN_PAID_LEN = 4
#def TOKEN_INVALID_LEN = 9
#def ROW_BYTES = 16
#def FILTER_ROWS_CAP = 4
#def FILTER_ROWS_BYTES = 32

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    row = alloc ROW_BYTES
    filter_rows = alloc FILTER_ROWS_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info

    EXPAND DB_BLOB_PUT put_a_status, blob_a_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_A, VALUE_A_LEN, info
    EXPAND DB_BLOB_PUT put_b_status, blob_b_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_B, VALUE_B_LEN, info
    EXPAND DB_BLOB_PUT put_c_status, blob_c_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_C, VALUE_C_LEN, info

    store row+0, 100 as u64
    store row+8, blob_a_id as u64
    EXPAND DB_INSERT_ROW insert_a_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 101 as u64
    store row+8, blob_b_id as u64
    EXPAND DB_INSERT_ROW insert_b_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 102 as u64
    store row+8, blob_c_id as u64
    EXPAND DB_INSERT_ROW insert_c_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info

    EXPAND DB_CREATE_BLOB_TOKEN_INDEX token_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_FILTER_BLOB_TOKEN_HANDLE widget_status, widget_written, widget_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, TOKEN_WIDGET, TOKEN_WIDGET_LEN, 0, FILTER_ROWS_CAP
    widget_row0 = load filter_rows+0 as u64
    widget_row1 = load filter_rows+8 as u64
    EXPAND DB_FILTER_BLOB_TOKEN_HANDLE widget_page_status, widget_page_written, widget_page_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, TOKEN_WIDGET, TOKEN_WIDGET_LEN, 1, 1
    widget_page_row0 = load filter_rows+0 as u64
    EXPAND DB_FILTER_BLOB_TOKEN_HANDLE paid_status, paid_written, paid_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, TOKEN_PAID, TOKEN_PAID_LEN, 0, FILTER_ROWS_CAP
    paid_row0 = load filter_rows+0 as u64
    EXPAND DB_FILTER_BLOB_TOKEN_HANDLE invalid_status, invalid_written, invalid_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, TOKEN_INVALID, TOKEN_INVALID_LEN, 0, FILTER_ROWS_CAP
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_put_a = eq put_a_status, SA_DB_OK
    ok_put_b = eq put_b_status, SA_DB_OK
    ok_put_c = eq put_c_status, SA_DB_OK
    ok_blob_a = eq blob_a_id, 1
    ok_blob_b = eq blob_b_id, 2
    ok_blob_c = eq blob_c_id, 3
    ok_insert_a = eq insert_a_status, SA_DB_OK
    ok_insert_b = eq insert_b_status, SA_DB_OK
    ok_insert_c = eq insert_c_status, SA_DB_OK
    ok_token_index = eq token_index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_widget_status = eq widget_status, SA_DB_OK
    ok_widget_written = eq widget_written, 2
    ok_widget_total = eq widget_total, 2
    ok_widget_row0 = eq widget_row0, 0
    ok_widget_row1 = eq widget_row1, 1
    ok_widget_page_status = eq widget_page_status, SA_DB_OK
    ok_widget_page_written = eq widget_page_written, 1
    ok_widget_page_total = eq widget_page_total, 2
    ok_widget_page_row0 = eq widget_page_row0, 1
    ok_paid_status = eq paid_status, SA_DB_OK
    ok_paid_written = eq paid_written, 1
    ok_paid_total = eq paid_total, 1
    ok_paid_row0 = eq paid_row0, 2
    ok_invalid_status = eq invalid_status, SA_DB_ERR_INVALID_FORMAT
    ok_invalid_written = eq invalid_written, 0
    ok_invalid_total = eq invalid_total, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_put_a
    ok03 = and ok02, ok_put_b
    ok04 = and ok03, ok_put_c
    ok05 = and ok04, ok_blob_a
    ok06 = and ok05, ok_blob_b
    ok07 = and ok06, ok_blob_c
    ok08 = and ok07, ok_insert_a
    ok09 = and ok08, ok_insert_b
    ok10 = and ok09, ok_insert_c
    ok11 = and ok10, ok_token_index
    ok12 = and ok11, ok_open
    ok13 = and ok12, ok_widget_status
    ok14 = and ok13, ok_widget_written
    ok15 = and ok14, ok_widget_total
    ok16 = and ok15, ok_widget_row0
    ok17 = and ok16, ok_widget_row1
    ok18 = and ok17, ok_widget_page_status
    ok19 = and ok18, ok_widget_page_written
    ok20 = and ok19, ok_widget_page_total
    ok21 = and ok20, ok_widget_page_row0
    ok22 = and ok21, ok_paid_status
    ok23 = and ok22, ok_paid_written
    ok24 = and ok23, ok_paid_total
    ok25 = and ok24, ok_paid_row0
    ok26 = and ok25, ok_invalid_status
    ok27 = and ok26, ok_invalid_written
    ok28 = and ok27, ok_invalid_total
    ok29 = and ok28, ok_close
    ok = and ok29, ok_verify

    !remove_status
    !init_status
    !put_a_status
    !blob_a_id
    !put_b_status
    !blob_b_id
    !put_c_status
    !blob_c_id
    !insert_a_status
    !insert_b_status
    !insert_c_status
    !token_index_status
    !open_status
    !read_handle
    !widget_status
    !widget_written
    !widget_total
    !widget_row0
    !widget_row1
    !widget_page_status
    !widget_page_written
    !widget_page_total
    !widget_page_row0
    !paid_status
    !paid_written
    !paid_total
    !paid_row0
    !invalid_status
    !invalid_written
    !invalid_total
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_put_a
    !ok_put_b
    !ok_put_c
    !ok_blob_a
    !ok_blob_b
    !ok_blob_c
    !ok_insert_a
    !ok_insert_b
    !ok_insert_c
    !ok_token_index
    !ok_open
    !ok_widget_status
    !ok_widget_written
    !ok_widget_total
    !ok_widget_row0
    !ok_widget_row1
    !ok_widget_page_status
    !ok_widget_page_written
    !ok_widget_page_total
    !ok_widget_page_row0
    !ok_paid_status
    !ok_paid_written
    !ok_paid_total
    !ok_paid_row0
    !ok_invalid_status
    !ok_invalid_written
    !ok_invalid_total
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !row
    !filter_rows
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9016)
