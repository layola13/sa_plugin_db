[END_MACRO]

[MACRO] DB_COLUMN_INPUT_SET %columns, %index, %data, %len
    __db_col_off_%columns_%index = mul %index, SaDbColumnInput_SIZE
    __db_col_ptr_%columns_%index = ptr_add %columns, __db_col_off_%columns_%index
    store __db_col_ptr_%columns_%index+SaDbColumnInput_data, %data as ptr
    store __db_col_ptr_%columns_%index+SaDbColumnInput_len, %len as u64
    !__db_col_ptr_%columns_%index
    !__db_col_off_%columns_%index
[END_MACRO]

[MACRO] DB_INFO_ROW_COUNT %out_rows, %info
    %out_rows = load %info+SaDbTableInfo_row_count as u64
[END_MACRO]

[MACRO] DB_INFO_SEGMENT_COUNT %out_segments, %info
    %out_segments = load %info+SaDbTableInfo_segment_count as u64
