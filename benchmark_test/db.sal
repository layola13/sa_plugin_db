[MACRO] DB_STATUS_IS_OK %out_bool, %status
    %out_bool = eq %status, SA_DB_OK
[END_MACRO]

[MACRO] DB_DECIMAL_FROM_PARTS %out_status, %out_value, %negative, %whole, %fraction, %scale
    __db_decimal_value_slot_%out_value = stack_alloc 8
    %out_status = call @sa_db_decimal_from_parts(%negative, %whole, %fraction, %scale, &__db_decimal_value_slot_%out_value)
    %out_value = load __db_decimal_value_slot_%out_value+0 as i64
[END_MACRO]

[MACRO] DB_DECIMAL_TO_PARTS %out_status, %out_negative, %out_whole, %out_fraction, %value, %scale
    __db_decimal_negative_slot_%out_negative = stack_alloc 4
    __db_decimal_whole_slot_%out_whole = stack_alloc 8
    __db_decimal_fraction_slot_%out_fraction = stack_alloc 8
    %out_status = call @sa_db_decimal_to_parts(%value, %scale, &__db_decimal_negative_slot_%out_negative, &__db_decimal_whole_slot_%out_whole, &__db_decimal_fraction_slot_%out_fraction)
    %out_negative = load __db_decimal_negative_slot_%out_negative+0 as u32
    %out_whole = load __db_decimal_whole_slot_%out_whole+0 as u64
    %out_fraction = load __db_decimal_fraction_slot_%out_fraction+0 as u64
[END_MACRO]

[MACRO] DB_DATE_FROM_YMD %out_status, %out_days, %year, %month, %day
    __db_date_days_slot_%out_days = stack_alloc 8
    %out_status = call @sa_db_date_from_ymd(%year, %month, %day, &__db_date_days_slot_%out_days)
    %out_days = load __db_date_days_slot_%out_days+0 as i64
[END_MACRO]

[MACRO] DB_DATE_TO_YMD %out_status, %out_year, %out_month, %out_day, %days
    __db_date_year_slot_%out_year = stack_alloc 8
    __db_date_month_slot_%out_month = stack_alloc 4
    __db_date_day_slot_%out_day = stack_alloc 4
    %out_status = call @sa_db_date_to_ymd(%days, &__db_date_year_slot_%out_year, &__db_date_month_slot_%out_month, &__db_date_day_slot_%out_day)
    %out_year = load __db_date_year_slot_%out_year+0 as i64
    %out_month = load __db_date_month_slot_%out_month+0 as u32
    %out_day = load __db_date_day_slot_%out_day+0 as u32
[END_MACRO]

