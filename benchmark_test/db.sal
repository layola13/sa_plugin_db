    %out_status = call @sa_db_upsert_row_u64_key(&%root, %root_len, &%table_name, %table_name_len, %column_index, %expected, &%row, %row_len, &__db_upsert_inserted_slot_%out_inserted, &%out_info)
    %out_inserted = load __db_upsert_inserted_slot_%out_inserted+0 as u64
[END_MACRO]

