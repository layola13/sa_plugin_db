@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"candidate_filters"
@const SCHEMA_PATH = utf8:"candidate_filters.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_CUSTOMER_ID_STRIDE = 8 // u64\n#def COL_ORDER_DAY_STRIDE = 8 // i64 date\n#def COL_STATUS_ID_STRIDE = 8 // u64\n#def COL_POSTED_STRIDE = 1 // u8 bool\n#def COL_TOTAL_CENTS_STRIDE = 8 // i64 decimal(2)\n#def COL_POSTED_MS_STRIDE = 8 // i64 timestamp_ms\n#def COL_POSTED_US_STRIDE = 8 // i64 timestamp_us\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 17
#def SCHEMA_PATH_LEN = 29
#def SCHEMA_LEN = 324
#def ROWS = 6
#def U64_COL_BYTES = 48
#def I64_COL_BYTES = 48
#def BOOL_COL_BYTES = 6
#def NULL_BITMAP_BYTES = 1
#def COLUMN_COUNT = 7
#def COLUMNS_BYTES = 112
#def ROWS_CAP = 6
#def ROWS_BYTES = 48

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    customer_ids = alloc U64_COL_BYTES
    order_days = alloc I64_COL_BYTES
    status_ids = alloc U64_COL_BYTES
    posted = alloc BOOL_COL_BYTES
    totals = alloc I64_COL_BYTES
    posted_ms = alloc I64_COL_BYTES
    posted_us = alloc I64_COL_BYTES
    null_bitmap = alloc NULL_BITMAP_BYTES
    candidate_rows = alloc ROWS_BYTES
    status_rows = alloc ROWS_BYTES
    date_rows = alloc ROWS_BYTES
    final_rows = alloc ROWS_BYTES

    store customer_ids+0, 7 as u64
    store customer_ids+8, 7 as u64
    store customer_ids+16, 7 as u64
    store customer_ids+24, 8 as u64
    store customer_ids+32, 7 as u64
    store customer_ids+40, 7 as u64
    store order_days+0, -5 as i64
    store order_days+8, 0 as i64
    store order_days+16, 10 as i64
    store order_days+24, -3 as i64
    store order_days+32, 20 as i64
    store order_days+40, 25 as i64
    store status_ids+0, 1 as u64
    store status_ids+8, 2 as u64
    store status_ids+16, 2 as u64
    store status_ids+24, 2 as u64
    store status_ids+32, 1 as u64
    store status_ids+40, 2 as u64
    store posted+0, 1 as u8
    store posted+1, 1 as u8
    store posted+2, 0 as u8
    store posted+3, 1 as u8
    store posted+4, 1 as u8
    store posted+5, 1 as u8
    store totals+0, 1000 as i64
    store totals+8, 2000 as i64
    store totals+16, 3000 as i64
    store totals+24, 4000 as i64
    store totals+32, 5000 as i64
    store totals+40, 7000 as i64
    store posted_ms+0, 0 as i64
    store posted_ms+8, 1000 as i64
    store posted_ms+16, 2000 as i64
    store posted_ms+24, 86400000 as i64
    store posted_ms+32, 86400001 as i64
    store posted_ms+40, 172800000 as i64
    store posted_us+0, 0 as i64
    store posted_us+8, 1000 as i64
    store posted_us+16, 2000 as i64
    store posted_us+24, 86400000000 as i64
    store posted_us+32, 86400000001 as i64
    store posted_us+40, 172800000000 as i64

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, customer_ids, U64_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, order_days, I64_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, status_ids, U64_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 3, posted, BOOL_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 4, totals, I64_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 5, posted_ms, I64_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 6, posted_us, I64_COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_U64_I64_PAIR_INDEX index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 0, 1, 1, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_RANGE_U64_I64_PAIR_HANDLE candidate_status, candidate_written, candidate_total, candidate_rows, ROWS_CAP, read_handle, 0, 1, 7, -5, 25, 0, ROWS_CAP
    EXPAND DB_FILTER_ROWS_DATE_RANGE_HANDLE date_filter_status, date_written, date_total, date_rows, ROWS_CAP, read_handle, 1, candidate_rows, candidate_written, 1970, 1, 1, 1970, 1, 21, 0, ROWS_CAP
    date_row0 = load date_rows+0 as u64
    date_row1 = load date_rows+8 as u64
    date_row2 = load date_rows+16 as u64
    EXPAND DB_FILTER_ROWS_U64_RANGE_HANDLE status_filter_status, status_written, status_total, status_rows, ROWS_CAP, read_handle, 2, candidate_rows, candidate_written, 2, 2, 0, ROWS_CAP
    status_row0 = load status_rows+0 as u64
    status_row1 = load status_rows+8 as u64
    status_row2 = load status_rows+16 as u64
    EXPAND DB_INTERSECT_ROWS_HANDLE intersect_status, intersect_written, intersect_total, final_rows, ROWS_CAP, read_handle, status_rows, status_written, date_rows, date_written, 0, ROWS_CAP
    intersect_row0 = load final_rows+0 as u64
    intersect_row1 = load final_rows+8 as u64
    EXPAND DB_UNION_ROWS_HANDLE row_union_status, row_union_written, row_union_total, final_rows, ROWS_CAP, read_handle, status_rows, status_written, date_rows, date_written, 0, ROWS_CAP
    row_union_row0 = load final_rows+0 as u64
    row_union_row1 = load final_rows+8 as u64
    row_union_row2 = load final_rows+16 as u64
    row_union_row3 = load final_rows+24 as u64
    EXPAND DB_EXCEPT_ROWS_HANDLE row_except_status, row_except_written, row_except_total, final_rows, ROWS_CAP, read_handle, status_rows, status_written, date_rows, date_written, 0, ROWS_CAP
    row_except_row0 = load final_rows+0 as u64
    EXPAND DB_STATS_ROWS_U64_HANDLE status_stats_status, status_stats_count, status_stats_sum, status_stats_min, status_stats_max, read_handle, 2, status_rows, status_written
    EXPAND DB_STATS_ROWS_I64_HANDLE amount_stats_status, amount_stats_count, amount_stats_sum, amount_stats_min, amount_stats_max, read_handle, 4, status_rows, status_written
    EXPAND DB_SORT_ROWS_U64_HANDLE status_sort_status, status_sort_written, status_sort_total, final_rows, ROWS_CAP, read_handle, 2, candidate_rows, candidate_written, 1, 0, ROWS_CAP
    status_sort_row0 = load final_rows+0 as u64
    status_sort_row1 = load final_rows+8 as u64
    status_sort_row2 = load final_rows+16 as u64
    status_sort_row3 = load final_rows+24 as u64
    status_sort_row4 = load final_rows+32 as u64
    EXPAND DB_SORT_ROWS_I64_HANDLE amount_sort_status, amount_sort_written, amount_sort_total, final_rows, ROWS_CAP, read_handle, 4, status_rows, status_written, 1, 0, ROWS_CAP
    amount_sort_row0 = load final_rows+0 as u64
    amount_sort_row1 = load final_rows+8 as u64
    amount_sort_row2 = load final_rows+16 as u64
    EXPAND DB_SORT_ROWS_I64_HANDLE amount_page_status, amount_page_written, amount_page_total, final_rows, ROWS_CAP, read_handle, 4, status_rows, status_written, 1, 1, 1
    amount_page_row0 = load final_rows+0 as u64
    EXPAND DB_FILTER_ROWS_I64_RANGE_HANDLE amount_filter_status, amount_written, amount_total, final_rows, ROWS_CAP, read_handle, 4, status_rows, status_written, 1500, 5500, 0, ROWS_CAP
    amount_row0 = load final_rows+0 as u64
    amount_row1 = load final_rows+8 as u64
    EXPAND DB_FILTER_ROWS_DECIMAL_I64_RANGE_HANDLE decimal_filter_status, decimal_written, decimal_total, final_rows, ROWS_CAP, read_handle, 4, status_rows, status_written, 2, 0, 15, 0, 0, 55, 0, 0, ROWS_CAP
    decimal_row0 = load final_rows+0 as u64
    decimal_row1 = load final_rows+8 as u64
    EXPAND DB_FILTER_ROWS_TIMESTAMP_MS_RANGE_HANDLE timestamp_ms_filter_status, timestamp_ms_written, timestamp_ms_total, final_rows, ROWS_CAP, read_handle, 5, status_rows, status_written, 0, 0, 0, 3000, 0, ROWS_CAP
    timestamp_ms_row0 = load final_rows+0 as u64
    timestamp_ms_row1 = load final_rows+8 as u64
    EXPAND DB_FILTER_ROWS_TIMESTAMP_US_RANGE_HANDLE timestamp_us_filter_status, timestamp_us_written, timestamp_us_total, final_rows, ROWS_CAP, read_handle, 6, status_rows, status_written, 0, 0, 0, 3000, 0, ROWS_CAP
    timestamp_us_row0 = load final_rows+0 as u64
    timestamp_us_row1 = load final_rows+8 as u64
    EXPAND DB_FILTER_ROWS_BOOL_HANDLE posted_filter_status, posted_written, posted_total, final_rows, ROWS_CAP, read_handle, 3, status_rows, status_written, 1, 0, ROWS_CAP
    posted_row0 = load final_rows+0 as u64
    posted_row1 = load final_rows+8 as u64
    EXPAND DB_NULL_BITMAP_CLEAR null_clear_status, null_bitmap, NULL_BITMAP_BYTES
    EXPAND DB_NULL_BITMAP_SET null_set_row1_status, null_bitmap, NULL_BITMAP_BYTES, 1, 1
    EXPAND DB_NULL_BITMAP_SET null_set_row5_status, null_bitmap, NULL_BITMAP_BYTES, 5, 1
    EXPAND DB_FILTER_ROWS_U64_RANGE_NULL_BITMAP_HANDLE null_u64_status, null_u64_written, null_u64_total, final_rows, ROWS_CAP, read_handle, 2, candidate_rows, candidate_written, 2, 2, null_bitmap, NULL_BITMAP_BYTES, 1, 0, ROWS_CAP
    null_u64_row0 = load final_rows+0 as u64
    null_u64_row1 = load final_rows+8 as u64
    EXPAND DB_FILTER_ROWS_I64_RANGE_NULL_BITMAP_HANDLE null_i64_status, null_i64_written, null_i64_total, final_rows, ROWS_CAP, read_handle, 4, status_rows, status_written, 1500, 5500, null_bitmap, NULL_BITMAP_BYTES, 0, 0, ROWS_CAP
    null_i64_row0 = load final_rows+0 as u64
    EXPAND DB_FILTER_ROWS_BOOL_HANDLE invalid_bool_status, invalid_bool_written, invalid_bool_total, final_rows, ROWS_CAP, read_handle, 3, status_rows, status_written, 2, 0, ROWS_CAP

    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_index = eq index_status, SA_DB_OK
