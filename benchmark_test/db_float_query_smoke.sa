@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"float_items"
@const SCHEMA_PATH = utf8:"float_items.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_QTY_STRIDE = 4 // f32\n#def COL_WEIGHT_STRIDE = 8 // f64\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 11
#def SCHEMA_PATH_LEN = 23
#def SCHEMA_LEN = 113
#def ROWS = 5
#def COLUMN_COUNT = 3
#def ID_COL_BYTES = 40
#def F32_COL_BYTES = 20
#def F64_COL_BYTES = 40
#def COLUMNS_BYTES = 48
#def RANGE_ROWS_CAP = 3
#def RANGE_ROWS_BYTES = 24
#def ALL_ROWS_CAP = 5
#def ALL_ROWS_BYTES = 40

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    id_col = alloc ID_COL_BYTES
    f32_col = alloc F32_COL_BYTES
    f64_col = alloc F64_COL_BYTES
    range_rows = alloc RANGE_ROWS_BYTES
    candidate_rows = alloc ALL_ROWS_BYTES
    sort_rows = alloc ALL_ROWS_BYTES

    store id_col+0, 1 as u64
    store id_col+8, 2 as u64
    store id_col+16, 3 as u64
    store id_col+24, 4 as u64
    store id_col+32, 5 as u64
    store f32_col+0, 1.5 as f32
    store f32_col+4, -2.25 as f32
    store f32_col+8, 0.0 as f32
    store f32_col+12, -0.0 as f32
    store f32_col+16, 9.75 as f32
    store f64_col+0, 10.5 as f64
    store f64_col+8, -3.25 as f64
    store f64_col+16, 2.0 as f64
    store f64_col+24, 2.0 as f64
    store f64_col+32, 100.125 as f64

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, id_col, ID_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, f32_col, F32_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, f64_col, F64_COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_F32_INDEX f32_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, 0, info
    EXPAND DB_CREATE_F64_INDEX f64_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 2, 0, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_COUNT_F32_CMP_HANDLE f32_count_status, f32_zero_count, read_handle, 1, SA_DB_CMP_EQ, 0.0
    EXPAND DB_FIND_F32_HANDLE f32_find_status, f32_found, f32_row, read_handle, 1, 1.5
    EXPAND DB_RANGE_F32_HANDLE f32_range_status, f32_range_written, f32_range_total, range_rows, RANGE_ROWS_CAP, read_handle, 1, -0.0, 1.5, 0, 3
    f32_range_row0 = load range_rows+0 as u64
    f32_range_row1 = load range_rows+8 as u64
    f32_range_row2 = load range_rows+16 as u64
    EXPAND DB_GET_F32_HANDLE f32_get_status, f32_value, read_handle, 1, f32_row
    EXPAND DB_MIN_F32_HANDLE f32_min_status, f32_min, read_handle, 1
    EXPAND DB_MAX_F32_HANDLE f32_max_status, f32_max, read_handle, 1

    EXPAND DB_COUNT_F64_CMP_HANDLE f64_count_status, f64_gt_count, read_handle, 2, SA_DB_CMP_GT, 10.0
    EXPAND DB_FIND_F64_HANDLE f64_find_status, f64_found, f64_row, read_handle, 2, -3.25
    EXPAND DB_RANGE_F64_HANDLE f64_range_status, f64_range_written, f64_range_total, range_rows, RANGE_ROWS_CAP, read_handle, 2, 2.0, 10.5, 1, 2
    f64_range_row0 = load range_rows+0 as u64
    f64_range_row1 = load range_rows+8 as u64
    EXPAND DB_GET_F64_HANDLE f64_get_status, f64_value, read_handle, 2, f64_row
    EXPAND DB_MIN_F64_HANDLE f64_min_status, f64_min, read_handle, 2
    EXPAND DB_MAX_F64_HANDLE f64_max_status, f64_max, read_handle, 2

    store candidate_rows+0, 2 as u64
    store candidate_rows+8, 3 as u64
    store candidate_rows+16, 0 as u64
    store candidate_rows+24, 1 as u64
    store candidate_rows+32, 4 as u64
    EXPAND DB_FILTER_ROWS_F32_RANGE_HANDLE f32_filter_status, f32_filter_written, f32_filter_total, range_rows, RANGE_ROWS_CAP, read_handle, 1, candidate_rows, ALL_ROWS_CAP, -0.0, 1.5, 0, 3
    f32_filter_row0 = load range_rows+0 as u64
    f32_filter_row1 = load range_rows+8 as u64
    f32_filter_row2 = load range_rows+16 as u64

    store candidate_rows+0, 1 as u64
    store candidate_rows+8, 2 as u64
    store candidate_rows+16, 3 as u64
    store candidate_rows+24, 0 as u64
    store candidate_rows+32, 4 as u64
    EXPAND DB_FILTER_ROWS_F64_RANGE_HANDLE f64_filter_status, f64_filter_written, f64_filter_total, range_rows, RANGE_ROWS_CAP, read_handle, 2, candidate_rows, ALL_ROWS_CAP, 2.0, 10.5, 1, 2
    f64_filter_row0 = load range_rows+0 as u64
    f64_filter_row1 = load range_rows+8 as u64

    store candidate_rows+0, 0 as u64
    store candidate_rows+8, 1 as u64
    store candidate_rows+16, 2 as u64
    store candidate_rows+24, 3 as u64
    store candidate_rows+32, 4 as u64
    EXPAND DB_SORT_ROWS_F32_HANDLE f32_sort_status, f32_sort_written, f32_sort_total, sort_rows, ALL_ROWS_CAP, read_handle, 1, candidate_rows, ALL_ROWS_CAP, 1, 0, 5
    f32_sort_row0 = load sort_rows+0 as u64
    f32_sort_row1 = load sort_rows+8 as u64
    f32_sort_row2 = load sort_rows+16 as u64
    f32_sort_row3 = load sort_rows+24 as u64
    f32_sort_row4 = load sort_rows+32 as u64
    EXPAND DB_SORT_ROWS_F64_HANDLE f64_sort_status, f64_sort_written, f64_sort_total, sort_rows, ALL_ROWS_CAP, read_handle, 2, candidate_rows, ALL_ROWS_CAP, 0, 0, 5
    f64_sort_row0 = load sort_rows+0 as u64
    f64_sort_row1 = load sort_rows+8 as u64
    f64_sort_row2 = load sort_rows+16 as u64
    f64_sort_row3 = load sort_rows+24 as u64
    f64_sort_row4 = load sort_rows+32 as u64
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_f32_index = eq f32_index_status, SA_DB_OK
    ok_f64_index = eq f64_index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_f32_count_status = eq f32_count_status, SA_DB_OK
    ok_f32_zero_count = eq f32_zero_count, 2
    ok_f32_find_status = eq f32_find_status, SA_DB_OK
    ok_f32_found = eq f32_found, 1
    ok_f32_row = eq f32_row, 0
    ok_f32_range_status = eq f32_range_status, SA_DB_OK
    ok_f32_range_written = eq f32_range_written, 3
    ok_f32_range_total = eq f32_range_total, 3
    ok_f32_range_row0 = eq f32_range_row0, 2
    ok_f32_range_row1 = eq f32_range_row1, 3
    ok_f32_range_row2 = eq f32_range_row2, 0
    ok_f32_get_status = eq f32_get_status, SA_DB_OK
    ok_f32_value = fcmp_eq f32_value, 1.5
    ok_f32_min_status = eq f32_min_status, SA_DB_OK
    ok_f32_min = fcmp_eq f32_min, -2.25
    ok_f32_max_status = eq f32_max_status, SA_DB_OK
    ok_f32_max = fcmp_eq f32_max, 9.75
    ok_f64_count_status = eq f64_count_status, SA_DB_OK
    ok_f64_gt_count = eq f64_gt_count, 2
    ok_f64_find_status = eq f64_find_status, SA_DB_OK
    ok_f64_found = eq f64_found, 1
    ok_f64_row = eq f64_row, 1
    ok_f64_range_status = eq f64_range_status, SA_DB_OK
    ok_f64_range_written = eq f64_range_written, 2
    ok_f64_range_total = eq f64_range_total, 3
    ok_f64_range_row0 = eq f64_range_row0, 3
    ok_f64_range_row1 = eq f64_range_row1, 0
    ok_f64_get_status = eq f64_get_status, SA_DB_OK
    ok_f64_value = fcmp_eq f64_value, -3.25
    ok_f64_min_status = eq f64_min_status, SA_DB_OK
    ok_f64_min = fcmp_eq f64_min, -3.25
    ok_f64_max_status = eq f64_max_status, SA_DB_OK
    ok_f64_max = fcmp_eq f64_max, 100.125
    ok_f32_filter_status = eq f32_filter_status, SA_DB_OK
    ok_f32_filter_written = eq f32_filter_written, 3
    ok_f32_filter_total = eq f32_filter_total, 3
    ok_f32_filter_row0 = eq f32_filter_row0, 2
    ok_f32_filter_row1 = eq f32_filter_row1, 3
    ok_f32_filter_row2 = eq f32_filter_row2, 0
    ok_f64_filter_status = eq f64_filter_status, SA_DB_OK
    ok_f64_filter_written = eq f64_filter_written, 2
    ok_f64_filter_total = eq f64_filter_total, 3
    ok_f64_filter_row0 = eq f64_filter_row0, 3
    ok_f64_filter_row1 = eq f64_filter_row1, 0
    ok_f32_sort_status = eq f32_sort_status, SA_DB_OK
    ok_f32_sort_written = eq f32_sort_written, 5
    ok_f32_sort_total = eq f32_sort_total, 5
    ok_f32_sort_row0 = eq f32_sort_row0, 4
    ok_f32_sort_row1 = eq f32_sort_row1, 0
    ok_f32_sort_row2 = eq f32_sort_row2, 2
    ok_f32_sort_row3 = eq f32_sort_row3, 3
    ok_f32_sort_row4 = eq f32_sort_row4, 1
    ok_f64_sort_status = eq f64_sort_status, SA_DB_OK
    ok_f64_sort_written = eq f64_sort_written, 5
    ok_f64_sort_total = eq f64_sort_total, 5
    ok_f64_sort_row0 = eq f64_sort_row0, 1
    ok_f64_sort_row1 = eq f64_sort_row1, 2
    ok_f64_sort_row2 = eq f64_sort_row2, 3
    ok_f64_sort_row3 = eq f64_sort_row3, 0
    ok_f64_sort_row4 = eq f64_sort_row4, 4
    ok_close = eq close_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_ingest
    ok03 = and ok02, ok_f32_index
    ok04 = and ok03, ok_f64_index
    ok05 = and ok04, ok_open
    ok06 = and ok05, ok_f32_count_status
    ok07 = and ok06, ok_f32_zero_count
    ok08 = and ok07, ok_f32_find_status
    ok09 = and ok08, ok_f32_found
    ok10 = and ok09, ok_f32_row
    ok11 = and ok10, ok_f32_range_status
    ok12 = and ok11, ok_f32_range_written
    ok13 = and ok12, ok_f32_range_total
    ok14 = and ok13, ok_f32_range_row0
    ok15 = and ok14, ok_f32_range_row1
    ok16 = and ok15, ok_f32_range_row2
    ok17 = and ok16, ok_f32_get_status
    ok18 = and ok17, ok_f32_value
    ok19 = and ok18, ok_f32_min_status
    ok20 = and ok19, ok_f32_min
    ok21 = and ok20, ok_f32_max_status
    ok22 = and ok21, ok_f32_max
    ok23 = and ok22, ok_f64_count_status
    ok24 = and ok23, ok_f64_gt_count
    ok25 = and ok24, ok_f64_find_status
    ok26 = and ok25, ok_f64_found
    ok27 = and ok26, ok_f64_row
    ok28 = and ok27, ok_f64_range_status
    ok29 = and ok28, ok_f64_range_written
    ok30 = and ok29, ok_f64_range_total
    ok31 = and ok30, ok_f64_range_row0
    ok32 = and ok31, ok_f64_range_row1
    ok33 = and ok32, ok_f64_get_status
    ok34 = and ok33, ok_f64_value
    ok35 = and ok34, ok_f64_min_status
    ok36 = and ok35, ok_f64_min
    ok37 = and ok36, ok_f64_max_status
    ok38 = and ok37, ok_f64_max
    ok39 = and ok38, ok_f32_filter_status
    ok40 = and ok39, ok_f32_filter_written
    ok41 = and ok40, ok_f32_filter_total
    ok42 = and ok41, ok_f32_filter_row0
    ok43 = and ok42, ok_f32_filter_row1
    ok44 = and ok43, ok_f32_filter_row2
    ok45 = and ok44, ok_f64_filter_status
    ok46 = and ok45, ok_f64_filter_written
    ok47 = and ok46, ok_f64_filter_total
    ok48 = and ok47, ok_f64_filter_row0
    ok49 = and ok48, ok_f64_filter_row1
    ok50 = and ok49, ok_f32_sort_status
    ok51 = and ok50, ok_f32_sort_written
    ok52 = and ok51, ok_f32_sort_total
    ok53 = and ok52, ok_f32_sort_row0
    ok54 = and ok53, ok_f32_sort_row1
    ok55 = and ok54, ok_f32_sort_row2
    ok56 = and ok55, ok_f32_sort_row3
    ok57 = and ok56, ok_f32_sort_row4
    ok58 = and ok57, ok_f64_sort_status
    ok59 = and ok58, ok_f64_sort_written
    ok60 = and ok59, ok_f64_sort_total
    ok61 = and ok60, ok_f64_sort_row0
    ok62 = and ok61, ok_f64_sort_row1
    ok63 = and ok62, ok_f64_sort_row2
    ok64 = and ok63, ok_f64_sort_row3
    ok65 = and ok64, ok_f64_sort_row4
    ok = and ok65, ok_close

    !remove_status
    !init_status
    !ingest_status
    !f32_index_status
    !f64_index_status
    !open_status
    !f32_count_status
    !f32_zero_count
    !f32_find_status
    !f32_found
    !f32_row
    !f32_range_status
    !f32_range_written
    !f32_range_total
    !f32_range_row0
    !f32_range_row1
    !f32_range_row2
    !f32_get_status
    !f32_value
    !f32_min_status
    !f32_min
    !f32_max_status
    !f32_max
    !f64_count_status
    !f64_gt_count
    !f64_find_status
    !f64_found
    !f64_row
    !f64_range_status
    !f64_range_written
    !f64_range_total
    !f64_range_row0
    !f64_range_row1
    !f64_get_status
    !f64_value
    !f64_min_status
    !f64_min
    !f64_max_status
    !f64_max
    !f32_filter_status
    !f32_filter_written
    !f32_filter_total
    !f32_filter_row0
    !f32_filter_row1
    !f32_filter_row2
    !f64_filter_status
    !f64_filter_written
    !f64_filter_total
    !f64_filter_row0
    !f64_filter_row1
    !f32_sort_status
    !f32_sort_written
    !f32_sort_total
    !f32_sort_row0
    !f32_sort_row1
    !f32_sort_row2
    !f32_sort_row3
    !f32_sort_row4
    !f64_sort_status
    !f64_sort_written
    !f64_sort_total
    !f64_sort_row0
    !f64_sort_row1
    !f64_sort_row2
    !f64_sort_row3
    !f64_sort_row4
    !close_status
    !read_handle
    !ok_remove
    !ok_init
    !ok_ingest
    !ok_f32_index
    !ok_f64_index
    !ok_open
    !ok_f32_count_status
    !ok_f32_zero_count
    !ok_f32_find_status
    !ok_f32_found
    !ok_f32_row
    !ok_f32_range_status
    !ok_f32_range_written
    !ok_f32_range_total
    !ok_f32_range_row0
    !ok_f32_range_row1
    !ok_f32_range_row2
    !ok_f32_get_status
    !ok_f32_value
    !ok_f32_min_status
    !ok_f32_min
    !ok_f32_max_status
    !ok_f32_max
    !ok_f64_count_status
    !ok_f64_gt_count
    !ok_f64_find_status
    !ok_f64_found
    !ok_f64_row
    !ok_f64_range_status
    !ok_f64_range_written
    !ok_f64_range_total
    !ok_f64_range_row0
    !ok_f64_range_row1
    !ok_f64_get_status
    !ok_f64_value
    !ok_f64_min_status
    !ok_f64_min
    !ok_f64_max_status
    !ok_f64_max
    !ok_f32_filter_status
    !ok_f32_filter_written
    !ok_f32_filter_total
    !ok_f32_filter_row0
    !ok_f32_filter_row1
    !ok_f32_filter_row2
    !ok_f64_filter_status
    !ok_f64_filter_written
    !ok_f64_filter_total
    !ok_f64_filter_row0
    !ok_f64_filter_row1
    !ok_f32_sort_status
    !ok_f32_sort_written
    !ok_f32_sort_total
    !ok_f32_sort_row0
    !ok_f32_sort_row1
    !ok_f32_sort_row2
    !ok_f32_sort_row3
    !ok_f32_sort_row4
    !ok_f64_sort_status
    !ok_f64_sort_written
    !ok_f64_sort_total
    !ok_f64_sort_row0
    !ok_f64_sort_row1
    !ok_f64_sort_row2
    !ok_f64_sort_row3
    !ok_f64_sort_row4
    !ok_close
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !ok30
    !ok31
    !ok32
    !ok33
    !ok34
    !ok35
    !ok36
    !ok37
    !ok38
    !ok39
    !ok40
    !ok41
    !ok42
    !ok43
    !ok44
    !ok45
    !ok46
    !ok47
    !ok48
    !ok49
    !ok50
    !ok51
    !ok52
    !ok53
    !ok54
    !ok55
    !ok56
    !ok57
    !ok58
    !ok59
    !ok60
    !ok61
    !ok62
    !ok63
    !ok64
    !ok65
    !id_col
    !f32_col
    !f64_col
    !range_rows
    !candidate_rows
    !sort_rows
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9010)
