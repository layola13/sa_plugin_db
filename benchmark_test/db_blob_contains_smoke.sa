@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"blob_contains_items"
@const SCHEMA_PATH = utf8:"blob_contains_items.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_NOTE_STRIDE = 8 // blob_handle\n"
@const STORE = utf8:"notes"
@const VALUE_A = utf8:"Blue Widget SKU-001"
@const VALUE_B = utf8:"red widget sku_002"
@const VALUE_C = utf8:"invoice paid customer"
@const VALUE_D = utf8:"manual customer WID-GAP note"
@const NEEDLE_SKU = utf8:"dget SKU"
@const NEEDLE_CUSTOMER = utf8:"customer"
@const NEEDLE_SHORT = utf8:"ed"
@const NEEDLE_MISSING = utf8:"absent"

#def ROOT_LEN = 1
#def TABLE_LEN = 19
#def SCHEMA_PATH_LEN = 31
#def SCHEMA_LEN = 88
#def STORE_LEN = 5
#def VALUE_A_LEN = 19
#def VALUE_B_LEN = 18
#def VALUE_C_LEN = 21
#def VALUE_D_LEN = 28
#def NEEDLE_SKU_LEN = 8
#def NEEDLE_CUSTOMER_LEN = 8
#def NEEDLE_SHORT_LEN = 2
#def NEEDLE_MISSING_LEN = 6
#def ROW_BYTES = 16
#def FILTER_ROWS_CAP = 4
#def FILTER_ROWS_BYTES = 32

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    row = alloc ROW_BYTES
    filter_rows = alloc FILTER_ROWS_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info

    EXPAND DB_BLOB_PUT put_a_status, blob_a_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_A, VALUE_A_LEN, info
    EXPAND DB_BLOB_PUT put_b_status, blob_b_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_B, VALUE_B_LEN, info
    EXPAND DB_BLOB_PUT put_c_status, blob_c_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_C, VALUE_C_LEN, info
    EXPAND DB_BLOB_PUT put_d_status, blob_d_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, VALUE_D, VALUE_D_LEN, info

    store row+0, 100 as u64
    store row+8, blob_a_id as u64
    EXPAND DB_INSERT_ROW insert_a_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 101 as u64
    store row+8, blob_b_id as u64
    EXPAND DB_INSERT_ROW insert_b_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 102 as u64
    store row+8, blob_c_id as u64
    EXPAND DB_INSERT_ROW insert_c_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 103 as u64
    store row+8, blob_d_id as u64
    EXPAND DB_INSERT_ROW insert_d_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info

    EXPAND DB_CREATE_BLOB_CONTAINS_INDEX contains_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_FILTER_BLOB_CONTAINS_HANDLE sku_status, sku_written, sku_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, NEEDLE_SKU, NEEDLE_SKU_LEN, 0, FILTER_ROWS_CAP
    sku_row0 = load filter_rows+0 as u64
    EXPAND DB_FILTER_BLOB_CONTAINS_HANDLE customer_status, customer_written, customer_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, NEEDLE_CUSTOMER, NEEDLE_CUSTOMER_LEN, 0, FILTER_ROWS_CAP
    customer_row0 = load filter_rows+0 as u64
    customer_row1 = load filter_rows+8 as u64
    EXPAND DB_FILTER_BLOB_CONTAINS_HANDLE customer_page_status, customer_page_written, customer_page_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, NEEDLE_CUSTOMER, NEEDLE_CUSTOMER_LEN, 1, 1
    customer_page_row0 = load filter_rows+0 as u64
    EXPAND DB_FILTER_BLOB_CONTAINS_HANDLE short_status, short_written, short_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, NEEDLE_SHORT, NEEDLE_SHORT_LEN, 0, FILTER_ROWS_CAP
    short_row0 = load filter_rows+0 as u64
    EXPAND DB_FILTER_BLOB_CONTAINS_HANDLE missing_status, missing_written, missing_total, filter_rows, FILTER_ROWS_CAP, read_handle, 1, STORE, STORE_LEN, NEEDLE_MISSING, NEEDLE_MISSING_LEN, 0, FILTER_ROWS_CAP
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_put_a = eq put_a_status, SA_DB_OK
    ok_put_b = eq put_b_status, SA_DB_OK
    ok_put_c = eq put_c_status, SA_DB_OK
    ok_put_d = eq put_d_status, SA_DB_OK
    ok_blob_a = eq blob_a_id, 1
    ok_blob_b = eq blob_b_id, 2
    ok_blob_c = eq blob_c_id, 3
    ok_blob_d = eq blob_d_id, 4
    ok_insert_a = eq insert_a_status, SA_DB_OK
    ok_insert_b = eq insert_b_status, SA_DB_OK
    ok_insert_c = eq insert_c_status, SA_DB_OK
    ok_insert_d = eq insert_d_status, SA_DB_OK
    ok_contains_index = eq contains_index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_sku_status = eq sku_status, SA_DB_OK
    ok_sku_written = eq sku_written, 1
    ok_sku_total = eq sku_total, 1
    ok_sku_row0 = eq sku_row0, 0
    ok_customer_status = eq customer_status, SA_DB_OK
    ok_customer_written = eq customer_written, 2
    ok_customer_total = eq customer_total, 2
    ok_customer_row0 = eq customer_row0, 2
    ok_customer_row1 = eq customer_row1, 3
    ok_customer_page_status = eq customer_page_status, SA_DB_OK
    ok_customer_page_written = eq customer_page_written, 1
    ok_customer_page_total = eq customer_page_total, 2
    ok_customer_page_row0 = eq customer_page_row0, 3
    ok_short_status = eq short_status, SA_DB_OK
    ok_short_written = eq short_written, 1
    ok_short_total = eq short_total, 1
    ok_short_row0 = eq short_row0, 1
    ok_missing_status = eq missing_status, SA_DB_OK
    ok_missing_written = eq missing_written, 0
    ok_missing_total = eq missing_total, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_put_a
    ok03 = and ok02, ok_put_b
    ok04 = and ok03, ok_put_c
    ok05 = and ok04, ok_put_d
    ok06 = and ok05, ok_blob_a
    ok07 = and ok06, ok_blob_b
    ok08 = and ok07, ok_blob_c
    ok09 = and ok08, ok_blob_d
    ok10 = and ok09, ok_insert_a
    ok11 = and ok10, ok_insert_b
    ok12 = and ok11, ok_insert_c
    ok13 = and ok12, ok_insert_d
    ok14 = and ok13, ok_contains_index
    ok15 = and ok14, ok_open
    ok16 = and ok15, ok_sku_status
    ok17 = and ok16, ok_sku_written
    ok18 = and ok17, ok_sku_total
    ok19 = and ok18, ok_sku_row0
    ok20 = and ok19, ok_customer_status
    ok21 = and ok20, ok_customer_written
    ok22 = and ok21, ok_customer_total
    ok23 = and ok22, ok_customer_row0
    ok24 = and ok23, ok_customer_row1
    ok25 = and ok24, ok_customer_page_status
    ok26 = and ok25, ok_customer_page_written
    ok27 = and ok26, ok_customer_page_total
    ok28 = and ok27, ok_customer_page_row0
    ok29 = and ok28, ok_short_status
    ok30 = and ok29, ok_short_written
    ok31 = and ok30, ok_short_total
    ok32 = and ok31, ok_short_row0
    ok33 = and ok32, ok_missing_status
    ok34 = and ok33, ok_missing_written
    ok35 = and ok34, ok_missing_total
    ok36 = and ok35, ok_close
    ok = and ok36, ok_verify

    !remove_status
    !init_status
    !put_a_status
    !blob_a_id
    !put_b_status
    !blob_b_id
    !put_c_status
    !blob_c_id
    !put_d_status
    !blob_d_id
    !insert_a_status
    !insert_b_status
    !insert_c_status
    !insert_d_status
    !contains_index_status
    !open_status
    !read_handle
    !sku_status
    !sku_written
    !sku_total
    !sku_row0
    !customer_status
    !customer_written
    !customer_total
    !customer_row0
    !customer_row1
    !customer_page_status
    !customer_page_written
    !customer_page_total
    !customer_page_row0
    !short_status
    !short_written
    !short_total
    !short_row0
    !missing_status
    !missing_written
    !missing_total
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_put_a
    !ok_put_b
    !ok_put_c
    !ok_put_d
    !ok_blob_a
    !ok_blob_b
    !ok_blob_c
    !ok_blob_d
    !ok_insert_a
    !ok_insert_b
    !ok_insert_c
    !ok_insert_d
    !ok_contains_index
    !ok_open
    !ok_sku_status
    !ok_sku_written
    !ok_sku_total
    !ok_sku_row0
    !ok_customer_status
    !ok_customer_written
    !ok_customer_total
    !ok_customer_row0
    !ok_customer_row1
    !ok_customer_page_status
    !ok_customer_page_written
    !ok_customer_page_total
    !ok_customer_page_row0
    !ok_short_status
    !ok_short_written
    !ok_short_total
    !ok_short_row0
    !ok_missing_status
    !ok_missing_written
    !ok_missing_total
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !ok30
    !ok31
    !ok32
    !ok33
    !ok34
    !ok35
    !ok36
    !row
    !filter_rows
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9016)
