@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"blob_key_write_smoke"
@const SCHEMA_PATH = utf8:"blob_key_write_smoke.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_CODE_STRIDE = 8 // blob_handle\n#def COL_POINTS_STRIDE = 8 // u64\n"
@const STORE = utf8:"codes"
@const CODE_A = utf8:"CUST-001"
@const CODE_B = utf8:"CUST-002"
@const CODE_C = utf8:"CUST-003"
@const CODE_D = utf8:"CUST-004"
@const CODE_E = utf8:"CUST-005"
@const CODE_F = utf8:"CUST-006"

#def ROOT_LEN = 1
#def TABLE_LEN = 20
#def SCHEMA_PATH_LEN = 32
#def SCHEMA_LEN = 122
#def STORE_LEN = 5
#def CODE_LEN = 8
#def ROW_BYTES = 24

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    row = alloc ROW_BYTES
    fetched_row = alloc ROW_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_BLOB_PUT put_a_status, code_a_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, CODE_A, CODE_LEN, info
    EXPAND DB_BLOB_PUT put_b_status, code_b_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, CODE_B, CODE_LEN, info
    EXPAND DB_BLOB_PUT put_c_status, code_c_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, CODE_C, CODE_LEN, info
    EXPAND DB_BLOB_PUT put_e_status, code_e_id, ROOT, ROOT_LEN, TABLE, TABLE_LEN, STORE, STORE_LEN, CODE_E, CODE_LEN, info

    store row+0, 1 as u64
    store row+8, code_a_id as u64
    store row+16, 100 as u64
    EXPAND DB_INSERT_ROW insert_a_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 2 as u64
    store row+8, code_b_id as u64
    store row+16, 200 as u64
    EXPAND DB_INSERT_ROW insert_b_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    EXPAND DB_CREATE_BLOB_EQ_INDEX index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, 1, info

    store row+0, 2 as u64
    store row+8, code_b_id as u64
    store row+16, 250 as u64
    EXPAND DB_UPDATE_ROW_BLOB_EQ_KEY direct_update_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, row, ROW_BYTES, info

    store row+0, 3 as u64
    store row+8, code_c_id as u64
    store row+16, 300 as u64
    EXPAND DB_UPDATE_ROW_BLOB_EQ_KEY direct_missing_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_C, CODE_LEN, row, ROW_BYTES, info

    store row+0, 2 as u64
    store row+8, code_a_id as u64
    store row+16, 251 as u64
    EXPAND DB_UPDATE_ROW_BLOB_EQ_KEY direct_mismatch_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, row, ROW_BYTES, info

    store row+0, 2 as u64
    store row+8, code_b_id as u64
    store row+16, 260 as u64
    EXPAND DB_UPSERT_ROW_BLOB_EQ_KEY direct_upsert_existing_status, direct_upsert_existing_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, row, ROW_BYTES, info

    store row+0, 3 as u64
    store row+8, code_c_id as u64
    store row+16, 300 as u64
    EXPAND DB_UPSERT_ROW_BLOB_EQ_KEY direct_upsert_new_status, direct_upsert_new_inserted, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_C, CODE_LEN, row, ROW_BYTES, info
    EXPAND DB_INFO_ROW_COUNT rows_after_direct_upsert, info

    EXPAND DB_DELETE_BLOB_EQ_KEY direct_delete_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_A, CODE_LEN, info
    EXPAND DB_INFO_ROW_COUNT rows_after_direct_delete, info
    EXPAND DB_DELETE_BLOB_EQ_KEY direct_delete_missing_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, STORE, STORE_LEN, CODE_A, CODE_LEN, info

    EXPAND DB_TX_BEGIN tx_begin_status, tx, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    store row+0, 2 as u64
    store row+8, code_b_id as u64
    store row+16, 270 as u64
    EXPAND DB_TX_UPSERT_ROW_BLOB_EQ_KEY tx_upsert_existing_status, tx_upsert_existing_inserted, tx, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, row, ROW_BYTES, info
    store row+0, 5 as u64
    store row+8, code_e_id as u64
    store row+16, 500 as u64
    EXPAND DB_TX_UPDATE_ROW_BLOB_EQ_KEY tx_missing_status, tx, 1, STORE, STORE_LEN, CODE_E, CODE_LEN, row, ROW_BYTES, info
    store row+0, 3 as u64
    store row+8, code_c_id as u64
    store row+16, 330 as u64
    EXPAND DB_TX_UPDATE_ROW_BLOB_EQ_KEY tx_update_status, tx, 1, STORE, STORE_LEN, CODE_C, CODE_LEN, row, ROW_BYTES, info
    EXPAND DB_TX_BLOB_PUT tx_blob_d_status, code_d_id, tx, STORE, STORE_LEN, CODE_D, CODE_LEN, info
    store row+0, 4 as u64
    store row+8, code_d_id as u64
    store row+16, 400 as u64
    EXPAND DB_TX_UPSERT_ROW_BLOB_EQ_KEY tx_upsert_new_status, tx_upsert_new_inserted, tx, 1, STORE, STORE_LEN, CODE_D, CODE_LEN, row, ROW_BYTES, info
    EXPAND DB_TX_DELETE_BLOB_EQ_KEY tx_delete_status, tx, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, info
    EXPAND DB_TX_COMMIT tx_commit_status, tx, info
    EXPAND DB_INFO_ROW_COUNT rows_after_commit, info

    EXPAND DB_TX_BEGIN tx2_begin_status, tx2, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_TX_BLOB_PUT tx2_blob_f_status, code_f_id, tx2, STORE, STORE_LEN, CODE_F, CODE_LEN, info
    store row+0, 6 as u64
    store row+8, code_f_id as u64
    store row+16, 600 as u64
    EXPAND DB_TX_UPSERT_ROW_BLOB_EQ_KEY tx2_upsert_status, tx2_upsert_inserted, tx2, 1, STORE, STORE_LEN, CODE_F, CODE_LEN, row, ROW_BYTES, info
    EXPAND DB_TX_ROLLBACK tx2_rollback_status, tx2

    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_GET_ROW_BLOB_EQ_KEY_HANDLE get_c_status, read_handle, 1, STORE, STORE_LEN, CODE_C, CODE_LEN, fetched_row, ROW_BYTES
    fetched_c_id = load fetched_row+0 as u64
    fetched_c_code = load fetched_row+8 as u64
    fetched_c_points = load fetched_row+16 as u64
    EXPAND DB_GET_ROW_BLOB_EQ_KEY_HANDLE get_d_status, read_handle, 1, STORE, STORE_LEN, CODE_D, CODE_LEN, fetched_row, ROW_BYTES
    fetched_d_id = load fetched_row+0 as u64
    fetched_d_code = load fetched_row+8 as u64
    fetched_d_points = load fetched_row+16 as u64
    EXPAND DB_GET_ROW_BLOB_EQ_KEY_HANDLE missing_a_status, read_handle, 1, STORE, STORE_LEN, CODE_A, CODE_LEN, fetched_row, ROW_BYTES
    EXPAND DB_GET_ROW_BLOB_EQ_KEY_HANDLE missing_b_status, read_handle, 1, STORE, STORE_LEN, CODE_B, CODE_LEN, fetched_row, ROW_BYTES
    EXPAND DB_GET_ROW_BLOB_EQ_KEY_HANDLE missing_f_status, read_handle, 1, STORE, STORE_LEN, CODE_F, CODE_LEN, fetched_row, ROW_BYTES
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_put_a = eq put_a_status, SA_DB_OK
    ok_put_b = eq put_b_status, SA_DB_OK
    ok_put_c = eq put_c_status, SA_DB_OK
    ok_put_e = eq put_e_status, SA_DB_OK
    ok_code_a = eq code_a_id, 1
    ok_code_b = eq code_b_id, 2
    ok_code_c = eq code_c_id, 3
    ok_code_e = eq code_e_id, 4
    ok_insert_a = eq insert_a_status, SA_DB_OK
    ok_insert_b = eq insert_b_status, SA_DB_OK
    ok_index = eq index_status, SA_DB_OK
    ok_direct_update = eq direct_update_status, SA_DB_OK
    ok_direct_missing = eq direct_missing_status, SA_DB_ERR_NOT_FOUND
    ok_direct_mismatch = eq direct_mismatch_status, SA_DB_ERR_INVALID_FORMAT
    ok_direct_upsert_existing = eq direct_upsert_existing_status, SA_DB_OK
    ok_direct_upsert_existing_inserted = eq direct_upsert_existing_inserted, 0
    ok_direct_upsert_new = eq direct_upsert_new_status, SA_DB_OK
    ok_direct_upsert_new_inserted = eq direct_upsert_new_inserted, 1
    ok_rows_direct_upsert = eq rows_after_direct_upsert, 3
    ok_direct_delete = eq direct_delete_status, SA_DB_OK
    ok_rows_direct_delete = eq rows_after_direct_delete, 2
    ok_direct_delete_missing = eq direct_delete_missing_status, SA_DB_ERR_NOT_FOUND
    ok_tx_begin = eq tx_begin_status, SA_DB_OK
    ok_tx_upsert_existing = eq tx_upsert_existing_status, SA_DB_OK
    ok_tx_upsert_existing_inserted = eq tx_upsert_existing_inserted, 0
    ok_tx_missing = eq tx_missing_status, SA_DB_ERR_NOT_FOUND
    ok_tx_update = eq tx_update_status, SA_DB_OK
    ok_tx_blob_d = eq tx_blob_d_status, SA_DB_OK
    ok_code_d = eq code_d_id, 5
    ok_tx_upsert_new = eq tx_upsert_new_status, SA_DB_OK
    ok_tx_upsert_new_inserted = eq tx_upsert_new_inserted, 1
    ok_tx_delete = eq tx_delete_status, SA_DB_OK
    ok_tx_commit = eq tx_commit_status, SA_DB_OK
    ok_rows_commit = eq rows_after_commit, 2
    ok_tx2_begin = eq tx2_begin_status, SA_DB_OK
    ok_tx2_blob_f = eq tx2_blob_f_status, SA_DB_OK
    ok_code_f = eq code_f_id, 6
    ok_tx2_upsert = eq tx2_upsert_status, SA_DB_OK
    ok_tx2_upsert_inserted = eq tx2_upsert_inserted, 1
    ok_tx2_rollback = eq tx2_rollback_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_get_c = eq get_c_status, SA_DB_OK
    ok_fetched_c_id = eq fetched_c_id, 3
    ok_fetched_c_code = eq fetched_c_code, code_c_id
    ok_fetched_c_points = eq fetched_c_points, 330
    ok_get_d = eq get_d_status, SA_DB_OK
    ok_fetched_d_id = eq fetched_d_id, 4
    ok_fetched_d_code = eq fetched_d_code, code_d_id
    ok_fetched_d_points = eq fetched_d_points, 400
    ok_missing_a = eq missing_a_status, SA_DB_ERR_NOT_FOUND
    ok_missing_b = eq missing_b_status, SA_DB_ERR_NOT_FOUND
    ok_missing_f = eq missing_f_status, SA_DB_ERR_NOT_FOUND
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_put_a
    ok03 = and ok02, ok_put_b
    ok04 = and ok03, ok_put_c
    ok05 = and ok04, ok_put_e
    ok06 = and ok05, ok_code_a
    ok07 = and ok06, ok_code_b
    ok08 = and ok07, ok_code_c
    ok09 = and ok08, ok_code_e
    ok10 = and ok09, ok_insert_a
    ok11 = and ok10, ok_insert_b
    ok12 = and ok11, ok_index
    ok13 = and ok12, ok_direct_update
    ok14 = and ok13, ok_direct_missing
    ok15 = and ok14, ok_direct_mismatch
    ok16 = and ok15, ok_direct_upsert_existing
    ok17 = and ok16, ok_direct_upsert_existing_inserted
    ok18 = and ok17, ok_direct_upsert_new
    ok19 = and ok18, ok_direct_upsert_new_inserted
    ok20 = and ok19, ok_rows_direct_upsert
    ok21 = and ok20, ok_direct_delete
    ok22 = and ok21, ok_rows_direct_delete
    ok23 = and ok22, ok_direct_delete_missing
    ok24 = and ok23, ok_tx_begin
    ok25 = and ok24, ok_tx_upsert_existing
    ok26 = and ok25, ok_tx_upsert_existing_inserted
    ok27 = and ok26, ok_tx_missing
    ok28 = and ok27, ok_tx_update
    ok29 = and ok28, ok_tx_blob_d
    ok30 = and ok29, ok_code_d
    ok31 = and ok30, ok_tx_upsert_new
    ok32 = and ok31, ok_tx_upsert_new_inserted
    ok33 = and ok32, ok_tx_delete
    ok34 = and ok33, ok_tx_commit
    ok35 = and ok34, ok_rows_commit
    ok36 = and ok35, ok_tx2_begin
    ok37 = and ok36, ok_tx2_blob_f
    ok38 = and ok37, ok_code_f
    ok39 = and ok38, ok_tx2_upsert
    ok40 = and ok39, ok_tx2_upsert_inserted
    ok41 = and ok40, ok_tx2_rollback
    ok42 = and ok41, ok_open
    ok43 = and ok42, ok_get_c
    ok44 = and ok43, ok_fetched_c_id
    ok45 = and ok44, ok_fetched_c_code
    ok46 = and ok45, ok_fetched_c_points
    ok47 = and ok46, ok_get_d
    ok48 = and ok47, ok_fetched_d_id
    ok49 = and ok48, ok_fetched_d_code
    ok50 = and ok49, ok_fetched_d_points
    ok51 = and ok50, ok_missing_a
    ok52 = and ok51, ok_missing_b
    ok53 = and ok52, ok_missing_f
    ok54 = and ok53, ok_close
    ok = and ok54, ok_verify

    !remove_status
    !init_status
    !put_a_status
    !put_b_status
    !put_c_status
    !put_e_status
    !code_a_id
    !code_b_id
    !code_c_id
    !code_e_id
    !insert_a_status
    !insert_b_status
    !index_status
    !direct_update_status
    !direct_missing_status
    !direct_mismatch_status
    !direct_upsert_existing_status
    !direct_upsert_existing_inserted
    !direct_upsert_new_status
    !direct_upsert_new_inserted
    !rows_after_direct_upsert
    !direct_delete_status
    !rows_after_direct_delete
    !direct_delete_missing_status
    !tx_begin_status
    !tx
    !tx_upsert_existing_status
    !tx_upsert_existing_inserted
    !tx_missing_status
    !tx_update_status
    !tx_blob_d_status
    !code_d_id
    !tx_upsert_new_status
    !tx_upsert_new_inserted
    !tx_delete_status
    !tx_commit_status
    !rows_after_commit
    !tx2_begin_status
    !tx2
    !tx2_blob_f_status
    !code_f_id
    !tx2_upsert_status
    !tx2_upsert_inserted
    !tx2_rollback_status
    !open_status
    !read_handle
    !get_c_status
    !fetched_c_id
    !fetched_c_code
    !fetched_c_points
    !get_d_status
    !fetched_d_id
    !fetched_d_code
    !fetched_d_points
    !missing_a_status
    !missing_b_status
    !missing_f_status
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_put_a
    !ok_put_b
    !ok_put_c
    !ok_put_e
    !ok_code_a
    !ok_code_b
    !ok_code_c
    !ok_code_e
    !ok_insert_a
    !ok_insert_b
    !ok_index
    !ok_direct_update
    !ok_direct_missing
    !ok_direct_mismatch
    !ok_direct_upsert_existing
    !ok_direct_upsert_existing_inserted
    !ok_direct_upsert_new
    !ok_direct_upsert_new_inserted
    !ok_rows_direct_upsert
    !ok_direct_delete
    !ok_rows_direct_delete
    !ok_direct_delete_missing
    !ok_tx_begin
    !ok_tx_upsert_existing
    !ok_tx_upsert_existing_inserted
    !ok_tx_missing
    !ok_tx_update
    !ok_tx_blob_d
    !ok_code_d
    !ok_tx_upsert_new
    !ok_tx_upsert_new_inserted
    !ok_tx_delete
    !ok_tx_commit
    !ok_rows_commit
    !ok_tx2_begin
    !ok_tx2_blob_f
    !ok_code_f
    !ok_tx2_upsert
    !ok_tx2_upsert_inserted
    !ok_tx2_rollback
    !ok_open
    !ok_get_c
    !ok_fetched_c_id
    !ok_fetched_c_code
    !ok_fetched_c_points
    !ok_get_d
    !ok_fetched_d_id
    !ok_fetched_d_code
    !ok_fetched_d_points
    !ok_missing_a
    !ok_missing_b
    !ok_missing_f
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !ok30
    !ok31
    !ok32
    !ok33
    !ok34
    !ok35
    !ok36
    !ok37
    !ok38
    !ok39
    !ok40
    !ok41
    !ok42
    !ok43
    !ok44
    !ok45
    !ok46
    !ok47
    !ok48
    !ok49
    !ok50
    !ok51
    !ok52
    !ok53
    !ok54
    !row
    !fetched_row
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9045)
