@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"group_stats_orders"
@const SCHEMA_PATH = utf8:"group_stats_orders.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_CUSTOMER_STRIDE = 8 // u64\n#def COL_AMOUNT_STRIDE = 8 // i64\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 18
#def SCHEMA_PATH_LEN = 30
#def SCHEMA_LEN = 88
#def ROW_BYTES = 16
#def GROUP_CAP = 3
#def GROUP_BYTES = 24
#def CANDIDATE_ROWS = 3
#def CANDIDATE_BYTES = 24

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    row = alloc ROW_BYTES
    group_keys = alloc GROUP_BYTES
    group_counts = alloc GROUP_BYTES
    group_sums = alloc GROUP_BYTES
    group_mins = alloc GROUP_BYTES
    group_maxs = alloc GROUP_BYTES
    candidate_rows = alloc CANDIDATE_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info

    store row+0, 1 as u64
    store row+8, 10 as i64
    EXPAND DB_INSERT_ROW insert0_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 2 as u64
    store row+8, -5 as i64
    EXPAND DB_INSERT_ROW insert1_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 1 as u64
    store row+8, 20 as i64
    EXPAND DB_INSERT_ROW insert2_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 3 as u64
    store row+8, 7 as i64
    EXPAND DB_INSERT_ROW insert3_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 2 as u64
    store row+8, 15 as i64
    EXPAND DB_INSERT_ROW insert4_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info

    store candidate_rows+0, 1 as u64
    store candidate_rows+8, 2 as u64
    store candidate_rows+16, 4 as u64

    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_GROUP_STATS_I64_BY_U64_HANDLE stats_status, stats_written, stats_total, group_keys, group_counts, group_sums, group_mins, group_maxs, GROUP_CAP, read_handle, 0, 1, 0, GROUP_CAP
    stats_key0 = load group_keys+0 as u64
    stats_count0 = load group_counts+0 as u64
    stats_sum0 = load group_sums+0 as i64
    stats_min0 = load group_mins+0 as i64
    stats_max0 = load group_maxs+0 as i64
    stats_key1 = load group_keys+8 as u64
    stats_min1 = load group_mins+8 as i64
    stats_max1 = load group_maxs+8 as i64

    EXPAND DB_GROUP_STATS_I64_BY_U64_SORTED_HANDLE sorted_status, sorted_written, sorted_total, group_keys, group_counts, group_sums, group_mins, group_maxs, GROUP_CAP, read_handle, 0, 1, 3, 0, 0, 2
    sorted_key0 = load group_keys+0 as u64
    sorted_min0 = load group_mins+0 as i64
    sorted_max0 = load group_maxs+0 as i64
    sorted_key1 = load group_keys+8 as u64
    sorted_min1 = load group_mins+8 as i64
    sorted_max1 = load group_maxs+8 as i64

    EXPAND DB_GROUP_ROWS_STATS_I64_BY_U64_HANDLE candidate_status, candidate_written, candidate_total, group_keys, group_counts, group_sums, group_mins, group_maxs, GROUP_CAP, read_handle, 0, 1, candidate_rows, CANDIDATE_ROWS, 0, GROUP_CAP
    candidate_key0 = load group_keys+0 as u64
    candidate_count0 = load group_counts+0 as u64
    candidate_sum0 = load group_sums+0 as i64
    candidate_min0 = load group_mins+0 as i64
    candidate_max0 = load group_maxs+0 as i64
    candidate_key1 = load group_keys+8 as u64
    candidate_min1 = load group_mins+8 as i64
    candidate_max1 = load group_maxs+8 as i64

    EXPAND DB_GROUP_ROWS_STATS_I64_BY_U64_SORTED_HANDLE sorted_candidate_status, sorted_candidate_written, sorted_candidate_total, group_keys, group_counts, group_sums, group_mins, group_maxs, GROUP_CAP, read_handle, 0, 1, candidate_rows, CANDIDATE_ROWS, 4, 1, 0, GROUP_CAP
    sorted_candidate_key0 = load group_keys+0 as u64
    sorted_candidate_max0 = load group_maxs+0 as i64
    sorted_candidate_key1 = load group_keys+8 as u64
    sorted_candidate_max1 = load group_maxs+8 as i64

    EXPAND DB_GROUP_ROWS_STATS_I64_BY_U64_HANDLE empty_status, empty_written, empty_total, group_keys, group_counts, group_sums, group_mins, group_maxs, 0, read_handle, 0, 1, candidate_rows, 0, 0, 0
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_insert0 = eq insert0_status, SA_DB_OK
    ok_insert1 = eq insert1_status, SA_DB_OK
    ok_insert2 = eq insert2_status, SA_DB_OK
    ok_insert3 = eq insert3_status, SA_DB_OK
    ok_insert4 = eq insert4_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_stats_status = eq stats_status, SA_DB_OK
    ok_stats_written = eq stats_written, 3
    ok_stats_total = eq stats_total, 3
    ok_stats_key0 = eq stats_key0, 1
    ok_stats_count0 = eq stats_count0, 2
    ok_stats_sum0 = eq stats_sum0, 30
    ok_stats_min0 = eq stats_min0, 10
    ok_stats_max0 = eq stats_max0, 20
    ok_stats_key1 = eq stats_key1, 2
    ok_stats_min1 = eq stats_min1, -5
    ok_stats_max1 = eq stats_max1, 15
    ok_sorted_status = eq sorted_status, SA_DB_OK
    ok_sorted_written = eq sorted_written, 2
    ok_sorted_total = eq sorted_total, 3
    ok_sorted_key0 = eq sorted_key0, 2
    ok_sorted_min0 = eq sorted_min0, -5
    ok_sorted_max0 = eq sorted_max0, 15
    ok_sorted_key1 = eq sorted_key1, 3
    ok_sorted_min1 = eq sorted_min1, 7
    ok_sorted_max1 = eq sorted_max1, 7
    ok_candidate_status = eq candidate_status, SA_DB_OK
    ok_candidate_written = eq candidate_written, 2
    ok_candidate_total = eq candidate_total, 2
    ok_candidate_key0 = eq candidate_key0, 2
    ok_candidate_count0 = eq candidate_count0, 2
    ok_candidate_sum0 = eq candidate_sum0, 10
    ok_candidate_min0 = eq candidate_min0, -5
    ok_candidate_max0 = eq candidate_max0, 15
    ok_candidate_key1 = eq candidate_key1, 1
    ok_candidate_min1 = eq candidate_min1, 20
    ok_candidate_max1 = eq candidate_max1, 20
    ok_sorted_candidate_status = eq sorted_candidate_status, SA_DB_OK
    ok_sorted_candidate_written = eq sorted_candidate_written, 2
    ok_sorted_candidate_total = eq sorted_candidate_total, 2
    ok_sorted_candidate_key0 = eq sorted_candidate_key0, 1
    ok_sorted_candidate_max0 = eq sorted_candidate_max0, 20
    ok_sorted_candidate_key1 = eq sorted_candidate_key1, 2
    ok_sorted_candidate_max1 = eq sorted_candidate_max1, 15
    ok_empty_status = eq empty_status, SA_DB_OK
    ok_empty_written = eq empty_written, 0
    ok_empty_total = eq empty_total, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_insert0
    ok03 = and ok02, ok_insert1
    ok04 = and ok03, ok_insert2
    ok05 = and ok04, ok_insert3
    ok06 = and ok05, ok_insert4
    ok07 = and ok06, ok_open
    ok08 = and ok07, ok_stats_status
    ok09 = and ok08, ok_stats_written
    ok10 = and ok09, ok_stats_total
    ok11 = and ok10, ok_stats_key0
    ok12 = and ok11, ok_stats_count0
    ok13 = and ok12, ok_stats_sum0
    ok14 = and ok13, ok_stats_min0
    ok15 = and ok14, ok_stats_max0
    ok16 = and ok15, ok_stats_key1
    ok17 = and ok16, ok_stats_min1
    ok18 = and ok17, ok_stats_max1
    ok19 = and ok18, ok_sorted_status
    ok20 = and ok19, ok_sorted_written
    ok21 = and ok20, ok_sorted_total
    ok22 = and ok21, ok_sorted_key0
    ok23 = and ok22, ok_sorted_min0
    ok24 = and ok23, ok_sorted_max0
    ok25 = and ok24, ok_sorted_key1
    ok26 = and ok25, ok_sorted_min1
    ok27 = and ok26, ok_sorted_max1
    ok28 = and ok27, ok_candidate_status
    ok29 = and ok28, ok_candidate_written
    ok30 = and ok29, ok_candidate_total
    ok31 = and ok30, ok_candidate_key0
    ok32 = and ok31, ok_candidate_count0
    ok33 = and ok32, ok_candidate_sum0
    ok34 = and ok33, ok_candidate_min0
    ok35 = and ok34, ok_candidate_max0
    ok36 = and ok35, ok_candidate_key1
    ok37 = and ok36, ok_candidate_min1
    ok38 = and ok37, ok_candidate_max1
    ok39 = and ok38, ok_sorted_candidate_status
    ok40 = and ok39, ok_sorted_candidate_written
    ok41 = and ok40, ok_sorted_candidate_total
    ok42 = and ok41, ok_sorted_candidate_key0
    ok43 = and ok42, ok_sorted_candidate_max0
    ok44 = and ok43, ok_sorted_candidate_key1
    ok45 = and ok44, ok_sorted_candidate_max1
    ok46 = and ok45, ok_empty_status
    ok47 = and ok46, ok_empty_written
    ok48 = and ok47, ok_empty_total
    ok49 = and ok48, ok_close
    ok = and ok49, ok_verify

    !remove_status
    !init_status
    !insert0_status
    !insert1_status
    !insert2_status
    !insert3_status
    !insert4_status
    !open_status
    !read_handle
    !stats_status
    !stats_written
    !stats_total
    !stats_key0
    !stats_count0
    !stats_sum0
    !stats_min0
    !stats_max0
    !stats_key1
    !stats_min1
    !stats_max1
    !sorted_status
    !sorted_written
    !sorted_total
    !sorted_key0
    !sorted_min0
    !sorted_max0
    !sorted_key1
    !sorted_min1
    !sorted_max1
    !candidate_status
    !candidate_written
    !candidate_total
    !candidate_key0
    !candidate_count0
    !candidate_sum0
    !candidate_min0
    !candidate_max0
    !candidate_key1
    !candidate_min1
    !candidate_max1
    !sorted_candidate_status
    !sorted_candidate_written
    !sorted_candidate_total
    !sorted_candidate_key0
    !sorted_candidate_max0
    !sorted_candidate_key1
    !sorted_candidate_max1
    !empty_status
    !empty_written
    !empty_total
    !close_status
    !verify_status
    !ok_remove
    !ok_init
    !ok_insert0
    !ok_insert1
    !ok_insert2
    !ok_insert3
    !ok_insert4
    !ok_open
    !ok_stats_status
    !ok_stats_written
    !ok_stats_total
    !ok_stats_key0
    !ok_stats_count0
    !ok_stats_sum0
    !ok_stats_min0
    !ok_stats_max0
    !ok_stats_key1
    !ok_stats_min1
    !ok_stats_max1
    !ok_sorted_status
    !ok_sorted_written
    !ok_sorted_total
    !ok_sorted_key0
    !ok_sorted_min0
    !ok_sorted_max0
    !ok_sorted_key1
    !ok_sorted_min1
    !ok_sorted_max1
    !ok_candidate_status
    !ok_candidate_written
    !ok_candidate_total
    !ok_candidate_key0
    !ok_candidate_count0
    !ok_candidate_sum0
    !ok_candidate_min0
    !ok_candidate_max0
    !ok_candidate_key1
    !ok_candidate_min1
    !ok_candidate_max1
    !ok_sorted_candidate_status
    !ok_sorted_candidate_written
    !ok_sorted_candidate_total
    !ok_sorted_candidate_key0
    !ok_sorted_candidate_max0
    !ok_sorted_candidate_key1
    !ok_sorted_candidate_max1
    !ok_empty_status
    !ok_empty_written
    !ok_empty_total
    !ok_close
    !ok_verify
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !ok17
    !ok18
    !ok19
    !ok20
    !ok21
    !ok22
    !ok23
    !ok24
    !ok25
    !ok26
    !ok27
    !ok28
    !ok29
    !ok30
    !ok31
    !ok32
    !ok33
    !ok34
    !ok35
    !ok36
    !ok37
    !ok38
    !ok39
    !ok40
    !ok41
    !ok42
    !ok43
    !ok44
    !ok45
    !ok46
    !ok47
    !ok48
    !ok49
    !row
    !group_keys
    !group_counts
    !group_sums
    !group_mins
    !group_maxs
    !candidate_rows
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9028)
