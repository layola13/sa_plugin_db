    !amount_not_null_row0
    !due_feb_not_null_status
    !due_feb_not_null_written
    !due_feb_not_null_total
    !due_feb_not_null_row0
    !due_feb_null_status
    !due_feb_null_written
    !due_feb_null_total
    !due_feb_null_row0
    !due_invalid_status
    !due_invalid_written
    !due_invalid_total
    !close_status
    !ok_amount_100_status
    !ok_amount_100
    !ok_amount_neg_1_status
    !ok_amount_neg_1
    !ok_amount_42_status
    !ok_amount_42
    !ok_amount_5_status
    !ok_amount_5
    !ok_due_jan_status
    !ok_due_feb10_status
    !ok_due_feb20_status
    !ok_due_mar_status
    !ok_amount_null_clear_status
    !ok_due_null_clear_status
    !ok_remove
    !ok_init
    !ok_ingest
    !ok_amount_index
