@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"typed_orders"
@const SCHEMA_PATH = utf8:"typed_orders.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_ID_STRIDE = 8 // u64\n#def COL_AMOUNT_STRIDE = 8 // i64 decimal(2) nullable\n#def COL_DUE_DATE_STRIDE = 8 // i64 date nullable\n#def COL_AMOUNT_NULLS_STRIDE = 1 // u8 null_bitmap\n#def COL_DUE_DATE_NULLS_STRIDE = 1 // u8 null_bitmap\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 12
#def SCHEMA_PATH_LEN = 24
#def SCHEMA_LEN = 256
#def ROWS = 4
#def COLUMN_COUNT = 5
#def COL_BYTES = 32
#def NULL_COL_BYTES = 4
#def COLUMNS_BYTES = 80
#def RANGE_ROWS_CAP = 4
#def RANGE_ROWS_BYTES = 32
#def NULL_BITMAP_BYTES = 1

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    logical_info = stack_alloc SaDbColumnLogicalInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    id_col = alloc COL_BYTES
    amount_col = alloc COL_BYTES
    due_date_col = alloc COL_BYTES
    amount_null_col = alloc NULL_COL_BYTES
    due_date_null_col = alloc NULL_COL_BYTES
    range_rows = alloc RANGE_ROWS_BYTES
    amount_nulls = alloc NULL_BITMAP_BYTES
    due_date_nulls = alloc NULL_BITMAP_BYTES

    store id_col+0, 1 as u64
    store id_col+8, 2 as u64
    store id_col+16, 3 as u64
    store id_col+24, 4 as u64

    EXPAND DB_DECIMAL_FROM_PARTS amount_100_status, amount_100, 0, 100, 0, 2
    EXPAND DB_DECIMAL_FROM_PARTS amount_neg_1_status, amount_neg_1, 1, 1, 0, 2
    EXPAND DB_DECIMAL_FROM_PARTS amount_42_status, amount_42, 0, 42, 50, 2
    EXPAND DB_DECIMAL_FROM_PARTS amount_5_status, amount_5, 0, 5, 25, 2
    store amount_col+0, amount_100 as i64
    store amount_col+8, amount_neg_1 as i64
    store amount_col+16, amount_42 as i64
    store amount_col+24, amount_5 as i64

    EXPAND DB_DATE_FROM_YMD due_jan_status, due_jan, 2024, 1, 15
    EXPAND DB_DATE_FROM_YMD due_feb10_status, due_feb10, 2024, 2, 10
    EXPAND DB_DATE_FROM_YMD due_feb20_status, due_feb20, 2024, 2, 20
    EXPAND DB_DATE_FROM_YMD due_mar_status, due_mar, 2024, 3, 1
    store due_date_col+0, due_jan as i64
    store due_date_col+8, due_feb10 as i64
    store due_date_col+16, due_feb20 as i64
    store due_date_col+24, due_mar as i64

    store amount_null_col+0, 0 as u8
    store amount_null_col+1, 0 as u8
    store amount_null_col+2, 1 as u8
    store amount_null_col+3, 0 as u8
    store due_date_null_col+0, 0 as u8
    store due_date_null_col+1, 0 as u8
    store due_date_null_col+2, 1 as u8
    store due_date_null_col+3, 0 as u8

    EXPAND DB_NULL_BITMAP_CLEAR amount_null_clear_status, amount_nulls, NULL_BITMAP_BYTES
    EXPAND DB_NULL_BITMAP_CLEAR due_null_clear_status, due_date_nulls, NULL_BITMAP_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    EXPAND DB_COLUMN_INPUT_SET columns, 0, id_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, amount_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, due_date_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 3, amount_null_col, NULL_COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 4, due_date_null_col, NULL_COL_BYTES
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    EXPAND DB_CREATE_I64_INDEX amount_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 1, 0, info
    EXPAND DB_CREATE_I64_INDEX due_index_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 2, 0, info
    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN

    EXPAND DB_COLUMN_LOGICAL_INFO_HANDLE amount_logical_status, read_handle, 1, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_TYPE amount_logical_type, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_SCALE amount_logical_scale, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_NULLABLE amount_nullable, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_HANDLE due_logical_status, read_handle, 2, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_TYPE due_logical_type, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_SCALE due_logical_scale, logical_info
    EXPAND DB_COLUMN_LOGICAL_INFO_NULLABLE due_nullable, logical_info
    EXPAND DB_EXPORT_NULL_BITMAP_HANDLE amount_export_status, amount_export_written, amount_export_rows, amount_nulls, NULL_BITMAP_BYTES, read_handle, 3
    EXPAND DB_EXPORT_NULL_BITMAP_HANDLE due_export_status, due_export_written, due_export_rows, due_date_nulls, NULL_BITMAP_BYTES, read_handle, 4
    EXPAND DB_NULL_BITMAP_GET amount_null_row0_status, amount_null_row0, amount_nulls, NULL_BITMAP_BYTES, 0
    EXPAND DB_NULL_BITMAP_GET amount_null_row1_status, amount_null_row1, amount_nulls, NULL_BITMAP_BYTES, 1
    EXPAND DB_NULL_BITMAP_GET amount_null_row2_status, amount_null_row2, amount_nulls, NULL_BITMAP_BYTES, 2
    EXPAND DB_NULL_BITMAP_GET amount_null_row3_status, amount_null_row3, amount_nulls, NULL_BITMAP_BYTES, 3
    EXPAND DB_NULL_BITMAP_GET due_null_row0_status, due_null_row0, due_date_nulls, NULL_BITMAP_BYTES, 0
    EXPAND DB_NULL_BITMAP_GET due_null_row1_status, due_null_row1, due_date_nulls, NULL_BITMAP_BYTES, 1
    EXPAND DB_NULL_BITMAP_GET due_null_row2_status, due_null_row2, due_date_nulls, NULL_BITMAP_BYTES, 2
    EXPAND DB_NULL_BITMAP_GET due_null_row3_status, due_null_row3, due_date_nulls, NULL_BITMAP_BYTES, 3

    EXPAND DB_RANGE_DECIMAL_I64_HANDLE amount_range_status, amount_range_written, amount_range_total, range_rows, RANGE_ROWS_CAP, read_handle, 1, 2, 0, 0, 0, 0, 50, 0, 0, 4
    amount_range_row0 = load range_rows+0 as u64
    amount_range_row1 = load range_rows+8 as u64
    EXPAND DB_RANGE_DECIMAL_I64_NULL_BITMAP_HANDLE amount_not_null_status, amount_not_null_written, amount_not_null_total, range_rows, RANGE_ROWS_CAP, read_handle, 1, 2, 0, 0, 0, 0, 50, 0, amount_nulls, NULL_BITMAP_BYTES, 0, 0, 4
    amount_not_null_row0 = load range_rows+0 as u64
    EXPAND DB_RANGE_DATE_NULL_BITMAP_HANDLE due_feb_not_null_status, due_feb_not_null_written, due_feb_not_null_total, range_rows, RANGE_ROWS_CAP, read_handle, 2, 2024, 2, 1, 2024, 2, 29, due_date_nulls, NULL_BITMAP_BYTES, 0, 0, 4
    due_feb_not_null_row0 = load range_rows+0 as u64
    EXPAND DB_RANGE_DATE_NULL_BITMAP_HANDLE due_feb_null_status, due_feb_null_written, due_feb_null_total, range_rows, RANGE_ROWS_CAP, read_handle, 2, 2024, 2, 1, 2024, 2, 29, due_date_nulls, NULL_BITMAP_BYTES, 1, 0, 4
    due_feb_null_row0 = load range_rows+0 as u64
    EXPAND DB_RANGE_DATE_HANDLE due_invalid_status, due_invalid_written, due_invalid_total, range_rows, RANGE_ROWS_CAP, read_handle, 2, 2023, 2, 29, 2024, 2, 29, 0, 4
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle

    ok_amount_100_status = eq amount_100_status, SA_DB_OK
    ok_amount_100 = eq amount_100, 10000
    ok_amount_neg_1_status = eq amount_neg_1_status, SA_DB_OK
    ok_amount_neg_1 = eq amount_neg_1, -100
    ok_amount_42_status = eq amount_42_status, SA_DB_OK
    ok_amount_42 = eq amount_42, 4250
    ok_amount_5_status = eq amount_5_status, SA_DB_OK
    ok_amount_5 = eq amount_5, 525
    ok_due_jan_status = eq due_jan_status, SA_DB_OK
    ok_due_feb10_status = eq due_feb10_status, SA_DB_OK
    ok_due_feb20_status = eq due_feb20_status, SA_DB_OK
    ok_due_mar_status = eq due_mar_status, SA_DB_OK
    ok_amount_null_clear_status = eq amount_null_clear_status, SA_DB_OK
    ok_due_null_clear_status = eq due_null_clear_status, SA_DB_OK
    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_amount_index = eq amount_index_status, SA_DB_OK
    ok_due_index = eq due_index_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_amount_logical_status = eq amount_logical_status, SA_DB_OK
    ok_amount_logical_type = eq amount_logical_type, SA_DB_LOGICAL_DECIMAL_I64
    ok_amount_logical_scale = eq amount_logical_scale, 2
    ok_amount_nullable = eq amount_nullable, 1
    ok_due_logical_status = eq due_logical_status, SA_DB_OK
    ok_due_logical_type = eq due_logical_type, SA_DB_LOGICAL_DATE_DAYS
    ok_due_logical_scale = eq due_logical_scale, 0
    ok_due_nullable = eq due_nullable, 1
    ok_amount_export_status = eq amount_export_status, SA_DB_OK
    ok_amount_export_written = eq amount_export_written, NULL_BITMAP_BYTES
    ok_amount_export_rows = eq amount_export_rows, ROWS
    ok_due_export_status = eq due_export_status, SA_DB_OK
    ok_due_export_written = eq due_export_written, NULL_BITMAP_BYTES
    ok_due_export_rows = eq due_export_rows, ROWS
    ok_amount_null_row0_status = eq amount_null_row0_status, SA_DB_OK
    ok_amount_null_row0 = eq amount_null_row0, 0
    ok_amount_null_row1_status = eq amount_null_row1_status, SA_DB_OK
    ok_amount_null_row1 = eq amount_null_row1, 0
    ok_amount_null_row2_status = eq amount_null_row2_status, SA_DB_OK
    ok_amount_null_row2 = eq amount_null_row2, 1
    ok_amount_null_row3_status = eq amount_null_row3_status, SA_DB_OK
    ok_amount_null_row3 = eq amount_null_row3, 0
    ok_due_null_row0_status = eq due_null_row0_status, SA_DB_OK
    ok_due_null_row0 = eq due_null_row0, 0
    ok_due_null_row1_status = eq due_null_row1_status, SA_DB_OK
    ok_due_null_row1 = eq due_null_row1, 0
    ok_due_null_row2_status = eq due_null_row2_status, SA_DB_OK
    ok_due_null_row2 = eq due_null_row2, 1
    ok_due_null_row3_status = eq due_null_row3_status, SA_DB_OK
    ok_due_null_row3 = eq due_null_row3, 0
    ok_amount_range_status = eq amount_range_status, SA_DB_OK
    ok_amount_range_written = eq amount_range_written, 2
    ok_amount_range_total = eq amount_range_total, 2
    ok_amount_range_row0 = eq amount_range_row0, 3
    ok_amount_range_row1 = eq amount_range_row1, 2
    ok_amount_not_null_status = eq amount_not_null_status, SA_DB_OK
    ok_amount_not_null_written = eq amount_not_null_written, 1
    ok_amount_not_null_total = eq amount_not_null_total, 1
    ok_amount_not_null_row0 = eq amount_not_null_row0, 3
    ok_due_feb_not_null_status = eq due_feb_not_null_status, SA_DB_OK
    ok_due_feb_not_null_written = eq due_feb_not_null_written, 1
    ok_due_feb_not_null_total = eq due_feb_not_null_total, 1
    ok_due_feb_not_null_row0 = eq due_feb_not_null_row0, 1
    ok_due_feb_null_status = eq due_feb_null_status, SA_DB_OK
    ok_due_feb_null_written = eq due_feb_null_written, 1
    ok_due_feb_null_total = eq due_feb_null_total, 1
    ok_due_feb_null_row0 = eq due_feb_null_row0, 2
    ok_due_invalid_status = eq due_invalid_status, SA_DB_ERR_INVALID_ARGUMENT
    ok_close = eq close_status, SA_DB_OK

    ok01 = and ok_amount_100_status, ok_amount_100
    ok02 = and ok01, ok_amount_neg_1_status
    ok03 = and ok02, ok_amount_neg_1
    ok04 = and ok03, ok_amount_42_status
    ok05 = and ok04, ok_amount_42
    ok06 = and ok05, ok_amount_5_status
    ok07 = and ok06, ok_amount_5
    ok08 = and ok07, ok_due_jan_status
    ok09 = and ok08, ok_due_feb10_status
    ok10 = and ok09, ok_due_feb20_status
    ok11 = and ok10, ok_due_mar_status
    ok12 = and ok11, ok_amount_null_clear_status
    ok13 = and ok12, ok_due_null_clear_status
    ok14 = and ok13, ok_remove
    ok15 = and ok14, ok_init
    ok16 = and ok15, ok_ingest
    ok17 = and ok16, ok_amount_index
    ok18 = and ok17, ok_due_index
    ok19 = and ok18, ok_open
    ok20 = and ok19, ok_amount_logical_status
    ok21 = and ok20, ok_amount_logical_type
    ok_logical01 = and ok_amount_logical_status, ok_amount_logical_type
    ok_logical02 = and ok_logical01, ok_amount_logical_scale
    ok_logical03 = and ok_logical02, ok_amount_nullable
    ok_logical04 = and ok_logical03, ok_due_logical_status
    ok_logical05 = and ok_logical04, ok_due_logical_type
    ok_logical06 = and ok_logical05, ok_due_logical_scale
    ok_logical07 = and ok_logical06, ok_due_nullable
    ok_logical08 = and ok_logical07, ok_amount_export_status
    ok_logical09 = and ok_logical08, ok_amount_export_written
    ok_logical10 = and ok_logical09, ok_amount_export_rows
    ok_logical11 = and ok_logical10, ok_due_export_status
    ok_logical12 = and ok_logical11, ok_due_export_written
    ok_logical13 = and ok_logical12, ok_due_export_rows
    ok_logical14 = and ok_logical13, ok_amount_null_row0_status
    ok_logical15 = and ok_logical14, ok_amount_null_row0
    ok_logical16 = and ok_logical15, ok_amount_null_row1_status
    ok_logical17 = and ok_logical16, ok_amount_null_row1
    ok_logical18 = and ok_logical17, ok_amount_null_row2_status
    ok_logical19 = and ok_logical18, ok_amount_null_row2
    ok_logical20 = and ok_logical19, ok_amount_null_row3_status
    ok_logical21 = and ok_logical20, ok_amount_null_row3
    ok_logical22 = and ok_logical21, ok_due_null_row0_status
    ok_logical23 = and ok_logical22, ok_due_null_row0
    ok_logical24 = and ok_logical23, ok_due_null_row1_status
    ok_logical25 = and ok_logical24, ok_due_null_row1
    ok_logical26 = and ok_logical25, ok_due_null_row2_status
    ok_logical27 = and ok_logical26, ok_due_null_row2
    ok_logical28 = and ok_logical27, ok_due_null_row3_status
    ok_logical_all = and ok_logical28, ok_due_null_row3
    ok21a = and ok21, ok_logical_all
    ok22 = and ok21a, ok_amount_range_status
    ok23 = and ok22, ok_amount_range_written
    ok24 = and ok23, ok_amount_range_total
    ok25 = and ok24, ok_amount_range_row0
    ok26 = and ok25, ok_amount_range_row1
    ok27 = and ok26, ok_amount_not_null_status
    ok28 = and ok27, ok_amount_not_null_written
    ok29 = and ok28, ok_amount_not_null_total
    ok30 = and ok29, ok_amount_not_null_row0
    ok31 = and ok30, ok_due_feb_not_null_status
    ok32 = and ok31, ok_due_feb_not_null_written
    ok33 = and ok32, ok_due_feb_not_null_total
    ok34 = and ok33, ok_due_feb_not_null_row0
    ok35 = and ok34, ok_due_feb_null_status
    ok36 = and ok35, ok_due_feb_null_written
    ok37 = and ok36, ok_due_feb_null_total
    ok38 = and ok37, ok_due_feb_null_row0
    ok39 = and ok38, ok_due_invalid_status
    ok = and ok39, ok_close

    !amount_100_status
    !amount_100
    !amount_neg_1_status
    !amount_neg_1
    !amount_42_status
    !amount_42
    !amount_5_status
    !amount_5
    !due_jan_status
    !due_jan
    !due_feb10_status
    !due_feb10
    !due_feb20_status
    !due_feb20
    !due_mar_status
    !due_mar
    !amount_null_clear_status
    !due_null_clear_status
    !remove_status
    !init_status
    !ingest_status
    !amount_index_status
    !due_index_status
    !open_status
    !read_handle
    !amount_logical_status
    !amount_logical_type
    !amount_logical_scale
    !amount_nullable
    !due_logical_status
    !due_logical_type
    !due_logical_scale
    !due_nullable
    !amount_export_status
    !amount_export_written
    !amount_export_rows
    !due_export_status
    !due_export_written
    !due_export_rows
    !amount_null_row0_status
    !amount_null_row0
    !amount_null_row1_status
