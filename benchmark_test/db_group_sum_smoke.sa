@import "db.sal"

@const ROOT = utf8:"."
@const TABLE = utf8:"group_sum_orders"
@const SCHEMA_PATH = utf8:"group_sum_orders.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 8\n#def COL_CUSTOMER_STRIDE = 8 // u64\n#def COL_AMOUNT_STRIDE = 8 // i64\n"

#def ROOT_LEN = 1
#def TABLE_LEN = 16
#def SCHEMA_PATH_LEN = 28
#def SCHEMA_LEN = 88
#def ROW_BYTES = 16
#def GROUP_CAP = 3
#def GROUP_BYTES = 24
#def CANDIDATE_ROWS = 3
#def CANDIDATE_BYTES = 24

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    row = alloc ROW_BYTES
    group_keys = alloc GROUP_BYTES
    group_counts = alloc GROUP_BYTES
    group_sums = alloc GROUP_BYTES
    candidate_rows = alloc CANDIDATE_BYTES

    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info

    store row+0, 1 as u64
    store row+8, 10 as i64
    EXPAND DB_INSERT_ROW insert0_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 2 as u64
    store row+8, -5 as i64
    EXPAND DB_INSERT_ROW insert1_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 1 as u64
    store row+8, 20 as i64
    EXPAND DB_INSERT_ROW insert2_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 3 as u64
    store row+8, 7 as i64
    EXPAND DB_INSERT_ROW insert3_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info
    store row+0, 2 as u64
    store row+8, 15 as i64
    EXPAND DB_INSERT_ROW insert4_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, row, ROW_BYTES, info

    store candidate_rows+0, 1 as u64
    store candidate_rows+8, 2 as u64
    store candidate_rows+16, 4 as u64

    EXPAND DB_OPEN_READ_TABLE open_status, read_handle, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_GROUP_SUM_I64_BY_U64_HANDLE group_status, group_written, group_total, group_keys, group_counts, group_sums, GROUP_CAP, read_handle, 0, 1, 0, GROUP_CAP
    group_key0 = load group_keys+0 as u64
    group_count0 = load group_counts+0 as u64
    group_sum0 = load group_sums+0 as i64
    group_key1 = load group_keys+8 as u64
    group_count1 = load group_counts+8 as u64
    group_sum1 = load group_sums+8 as i64
    group_key2 = load group_keys+16 as u64
    group_count2 = load group_counts+16 as u64
    group_sum2 = load group_sums+16 as i64

    EXPAND DB_GROUP_SUM_I64_BY_U64_HANDLE page_status, page_written, page_total, group_keys, group_counts, group_sums, GROUP_CAP, read_handle, 0, 1, 1, 1
    page_key0 = load group_keys+0 as u64
    page_count0 = load group_counts+0 as u64
    page_sum0 = load group_sums+0 as i64

    EXPAND DB_GROUP_ROWS_SUM_I64_BY_U64_HANDLE candidate_status, candidate_written, candidate_total, group_keys, group_counts, group_sums, GROUP_CAP, read_handle, 0, 1, candidate_rows, CANDIDATE_ROWS, 0, GROUP_CAP
    candidate_key0 = load group_keys+0 as u64
    candidate_count0 = load group_counts+0 as u64
    candidate_sum0 = load group_sums+0 as i64
    candidate_key1 = load group_keys+8 as u64
    candidate_count1 = load group_counts+8 as u64
    candidate_sum1 = load group_sums+8 as i64

    EXPAND DB_GROUP_SUM_I64_BY_U64_SORTED_HANDLE sorted_status, sorted_written, sorted_total, group_keys, group_counts, group_sums, GROUP_CAP, read_handle, 0, 1, 2, 1, 0, 2
    sorted_key0 = load group_keys+0 as u64
    sorted_count0 = load group_counts+0 as u64
    sorted_sum0 = load group_sums+0 as i64
    sorted_key1 = load group_keys+8 as u64
    sorted_count1 = load group_counts+8 as u64
    sorted_sum1 = load group_sums+8 as i64

    EXPAND DB_GROUP_ROWS_SUM_I64_BY_U64_SORTED_HANDLE sorted_candidate_status, sorted_candidate_written, sorted_candidate_total, group_keys, group_counts, group_sums, GROUP_CAP, read_handle, 0, 1, candidate_rows, CANDIDATE_ROWS, 2, 0, 0, GROUP_CAP
    sorted_candidate_key0 = load group_keys+0 as u64
    sorted_candidate_count0 = load group_counts+0 as u64
    sorted_candidate_sum0 = load group_sums+0 as i64
    sorted_candidate_key1 = load group_keys+8 as u64
    sorted_candidate_count1 = load group_counts+8 as u64
    sorted_candidate_sum1 = load group_sums+8 as i64

    EXPAND DB_GROUP_ROWS_SUM_I64_BY_U64_HANDLE empty_status, empty_written, empty_total, group_keys, group_counts, group_sums, 0, read_handle, 0, 1, candidate_rows, 0, 0, 0
    EXPAND DB_CLOSE_READ_TABLE close_status, read_handle
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_insert0 = eq insert0_status, SA_DB_OK
    ok_insert1 = eq insert1_status, SA_DB_OK
    ok_insert2 = eq insert2_status, SA_DB_OK
    ok_insert3 = eq insert3_status, SA_DB_OK
    ok_insert4 = eq insert4_status, SA_DB_OK
    ok_open = eq open_status, SA_DB_OK
    ok_group_status = eq group_status, SA_DB_OK
    ok_group_written = eq group_written, 3
    ok_group_total = eq group_total, 3
    ok_group_key0 = eq group_key0, 1
    ok_group_count0 = eq group_count0, 2
    ok_group_sum0 = eq group_sum0, 30
    ok_group_key1 = eq group_key1, 2
    ok_group_count1 = eq group_count1, 2
    ok_group_sum1 = eq group_sum1, 10
    ok_group_key2 = eq group_key2, 3
    ok_group_count2 = eq group_count2, 1
    ok_group_sum2 = eq group_sum2, 7
    ok_page_status = eq page_status, SA_DB_OK
    ok_page_written = eq page_written, 1
    ok_page_total = eq page_total, 3
    ok_page_key0 = eq page_key0, 2
    ok_page_count0 = eq page_count0, 2
    ok_page_sum0 = eq page_sum0, 10
    ok_candidate_status = eq candidate_status, SA_DB_OK
    ok_candidate_written = eq candidate_written, 2
    ok_candidate_total = eq candidate_total, 2
    ok_candidate_key0 = eq candidate_key0, 2
    ok_candidate_count0 = eq candidate_count0, 2
    ok_candidate_sum0 = eq candidate_sum0, 10
    ok_candidate_key1 = eq candidate_key1, 1
    ok_candidate_count1 = eq candidate_count1, 1
    ok_candidate_sum1 = eq candidate_sum1, 20
    ok_sorted_status = eq sorted_status, SA_DB_OK
    ok_sorted_written = eq sorted_written, 2
    ok_sorted_total = eq sorted_total, 3
    ok_sorted_key0 = eq sorted_key0, 1
    ok_sorted_count0 = eq sorted_count0, 2
    ok_sorted_sum0 = eq sorted_sum0, 30
    ok_sorted_key1 = eq sorted_key1, 2
    ok_sorted_count1 = eq sorted_count1, 2
    ok_sorted_sum1 = eq sorted_sum1, 10
    ok_sorted_candidate_status = eq sorted_candidate_status, SA_DB_OK
    ok_sorted_candidate_written = eq sorted_candidate_written, 2
    ok_sorted_candidate_total = eq sorted_candidate_total, 2
    ok_sorted_candidate_key0 = eq sorted_candidate_key0, 2
    ok_sorted_candidate_count0 = eq sorted_candidate_count0, 2
    ok_sorted_candidate_sum0 = eq sorted_candidate_sum0, 10
    ok_sorted_candidate_key1 = eq sorted_candidate_key1, 1
    ok_sorted_candidate_count1 = eq sorted_candidate_count1, 1
    ok_sorted_candidate_sum1 = eq sorted_candidate_sum1, 20
    ok_empty_status = eq empty_status, SA_DB_OK
    ok_empty_written = eq empty_written, 0
    ok_empty_total = eq empty_total, 0
    ok_close = eq close_status, SA_DB_OK
    ok_verify = eq verify_status, SA_DB_OK

    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_insert0
    ok03 = and ok02, ok_insert1
    ok04 = and ok03, ok_insert2
    ok05 = and ok04, ok_insert3
    ok06 = and ok05, ok_insert4
    ok07 = and ok06, ok_open
    ok08 = and ok07, ok_group_status
    ok09 = and ok08, ok_group_written
    ok10 = and ok09, ok_group_total
    ok11 = and ok10, ok_group_key0
    ok12 = and ok11, ok_group_count0
    ok13 = and ok12, ok_group_sum0
    ok14 = and ok13, ok_group_key1
    ok15 = and ok14, ok_group_count1
    ok16 = and ok15, ok_group_sum1
    ok17 = and ok16, ok_group_key2
    ok18 = and ok17, ok_group_count2
    ok19 = and ok18, ok_group_sum2
    ok20 = and ok19, ok_page_status
    ok21 = and ok20, ok_page_written
    ok22 = and ok21, ok_page_total
    ok23 = and ok22, ok_page_key0
    ok24 = and ok23, ok_page_count0
    ok25 = and ok24, ok_page_sum0
    ok26 = and ok25, ok_candidate_status
    ok27 = and ok26, ok_candidate_written
    ok28 = and ok27, ok_candidate_total
    ok29 = and ok28, ok_candidate_key0
    ok30 = and ok29, ok_candidate_count0
    ok31 = and ok30, ok_candidate_sum0
    ok32 = and ok31, ok_candidate_key1
    ok33 = and ok32, ok_candidate_count1
    ok34 = and ok33, ok_candidate_sum1
    ok35 = and ok34, ok_sorted_status
    ok36 = and ok35, ok_sorted_written
    ok37 = and ok36, ok_sorted_total
    ok38 = and ok37, ok_sorted_key0
    ok39 = and ok38, ok_sorted_count0
    ok40 = and ok39, ok_sorted_sum0
    ok41 = and ok40, ok_sorted_key1
    ok42 = and ok41, ok_sorted_count1
    ok43 = and ok42, ok_sorted_sum1
    ok44 = and ok43, ok_sorted_candidate_status
    ok45 = and ok44, ok_sorted_candidate_written
    ok46 = and ok45, ok_sorted_candidate_total
    ok47 = and ok46, ok_sorted_candidate_key0
    ok48 = and ok47, ok_sorted_candidate_count0
    ok49 = and ok48, ok_sorted_candidate_sum0
    ok50 = and ok49, ok_sorted_candidate_key1
    ok51 = and ok50, ok_sorted_candidate_count1
    ok52 = and ok51, ok_sorted_candidate_sum1
    ok53 = and ok52, ok_empty_status
    ok54 = and ok53, ok_empty_written
    ok55 = and ok54, ok_empty_total
    ok56 = and ok55, ok_close
    ok = and ok56, ok_verify

    !remove_status
    !init_status
    !insert0_status
    !insert1_status
    !insert2_status
    !insert3_status
    !insert4_status
    !open_status
    !read_handle
    !group_status
    !group_written
    !group_total
    !group_key0
    !group_count0
    !group_sum0
    !group_key1
    !group_count1
    !group_sum1
    !group_key2
    !group_count2
    !group_sum2
    !page_status
    !page_written
    !page_total
    !page_key0
    !page_count0
    !page_sum0
    !candidate_status
    !candidate_written
    !candidate_total
    !candidate_key0
