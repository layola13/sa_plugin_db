@import "db.sal"
@import "sa_std/fmt.sai"
@import "sa_std/io/print.sai"
@import "sa_std/time.sai"

@const ROOT = utf8:"."
@const TABLE = utf8:"members"
@const SCHEMA_PATH = utf8:"members.sadb-schema"
@const SCHEMA = utf8:"#def MAX_ROWS = 50000\n#def COL_ID_STRIDE = 8 // u64\n#def COL_PLAN_STRIDE = 8 // u64\n#def COL_STATUS_STRIDE = 8 // u64\n#def COL_POINTS_STRIDE = 8 // u64\n"
@const NL = utf8:"\n"
@const DB_CREATE = utf8:"db_create_ns="
@const DB_PREP = utf8:"db_prepare_columns_ns="
@const DB_INSERT = utf8:"db_insert_columns_ns="
@const DB_SUM1 = utf8:"db_sum_before_ns="
@const DB_UPDATE = utf8:"db_update_all_ns="
@const DB_SUM2 = utf8:"db_sum_after_ns="
@const DB_COUNT = utf8:"db_count_plan_one_ns="
@const DB_COMPACT = utf8:"db_compact_ns="
@const DB_VERIFY = utf8:"db_verify_ns="
@const ROWS_LABEL = utf8:"rows="
@const SUM_BEFORE_LABEL = utf8:"sum_before="
@const SUM_AFTER_LABEL = utf8:"sum_after="
@const PLAN_ONE_LABEL = utf8:"plan_one_count="
@const UPDATED_LABEL = utf8:"updated_rows="

#def ROOT_LEN = 1
#def TABLE_LEN = 7
#def SCHEMA_PATH_LEN = 19
#def SCHEMA_LEN = 152
#def ROWS = 50000
#def COL_BYTES = 400000
#def COLUMN_COUNT = 4
#def COLUMNS_BYTES = 64
#def FMT_BUF_BYTES = 32

#def DB_CREATE_LEN = 13
#def DB_PREP_LEN = 22
#def DB_INSERT_LEN = 21
#def DB_SUM1_LEN = 17
#def DB_UPDATE_LEN = 17
#def DB_SUM2_LEN = 16
#def DB_COUNT_LEN = 21
#def DB_COMPACT_LEN = 14
#def DB_VERIFY_LEN = 13
#def ROWS_LABEL_LEN = 5
#def SUM_BEFORE_LABEL_LEN = 11
#def SUM_AFTER_LABEL_LEN = 10
#def PLAN_ONE_LABEL_LEN = 15
#def UPDATED_LABEL_LEN = 13

[MACRO] PRINT_U64_LINE %label, %label_len, %value
    __fmt_buf_%value = stack_alloc FMT_BUF_BYTES
    __fmt_len_slot_%value = stack_alloc 8
    __fmt_status_%value = call @sa_fmt_u64_into(%value, 10, __fmt_buf_%value, FMT_BUF_BYTES, &__fmt_len_slot_%value)
    __fmt_len_%value = load __fmt_len_slot_%value+0 as u64
    call @sa_print_bytes(&%label, %label_len)
    call @sa_print_bytes(&__fmt_buf_%value, __fmt_len_%value)
    call @sa_print_bytes(&NL, 1)
    !__fmt_status_%value
    !__fmt_len_%value
[END_MACRO]

@main() -> i32:
L_ENTRY:
    info = stack_alloc SaDbTableInfo_SIZE
    columns = stack_alloc COLUMNS_BYTES
    i_slot = stack_alloc 8
    id_col = alloc COL_BYTES
    plan_col = alloc COL_BYTES
    status_col = alloc COL_BYTES
    points_col = alloc COL_BYTES

    t_create0 = call @sa_time_instant_ns()
    EXPAND DB_REMOVE_TABLE remove_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    EXPAND DB_INIT_SCHEMA init_status, ROOT, ROOT_LEN, SCHEMA_PATH, SCHEMA_PATH_LEN, SCHEMA, SCHEMA_LEN, info
    t_create1 = call @sa_time_instant_ns()
    db_create_ns = sub t_create1, t_create0
    store i_slot+0, 0 as u64
    t_prep0 = call @sa_time_instant_ns()
    jmp L_FILL_COND

L_FILL_COND:
    i = load i_slot+0 as u64
    fill_cond = ult i, ROWS
    br fill_cond -> L_FILL_BODY, L_FILL_DONE

L_FILL_BODY:
    off = mul i, 8
    id_ptr = ptr_add id_col, off
    plan_ptr = ptr_add plan_col, off
    status_ptr = ptr_add status_col, off
    points_ptr = ptr_add points_col, off
    id_value = add i, 1
    plan_low = and i, 3
    plan_value = add plan_low, 1
    status_value = and i, 1
    points_value = mul id_value, 10
    store id_ptr+0, id_value as u64
    store plan_ptr+0, plan_value as u64
    store status_ptr+0, status_value as u64
    store points_ptr+0, points_value as u64
    next_i = add i, 1
    store i_slot+0, next_i as u64
    !i
    !fill_cond
    !off
    !id_ptr
    !plan_ptr
    !status_ptr
    !points_ptr
    !id_value
    !plan_low
    !plan_value
    !status_value
    !points_value
    !next_i
    jmp L_FILL_COND

L_FILL_DONE:
    !i
    !fill_cond
    t_prep1 = call @sa_time_instant_ns()
    db_prepare_columns_ns = sub t_prep1, t_prep0

    EXPAND DB_COLUMN_INPUT_SET columns, 0, id_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 1, plan_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 2, status_col, COL_BYTES
    EXPAND DB_COLUMN_INPUT_SET columns, 3, points_col, COL_BYTES

    t_insert0 = call @sa_time_instant_ns()
    EXPAND DB_INGEST_COLUMNS ingest_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, ROWS, columns, COLUMN_COUNT, info
    t_insert1 = call @sa_time_instant_ns()
    db_insert_columns_ns = sub t_insert1, t_insert0
    EXPAND DB_INFO_ROW_COUNT row_count, info

    t_sum10 = call @sa_time_instant_ns()
    EXPAND DB_OPEN_READ_TABLE open_sum_status, read_handle_before, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_SUM_U64_HANDLE sum_status, points_sum_before, read_handle_before, 3
    EXPAND DB_CLOSE_READ_TABLE close_sum_status, read_handle_before
    t_sum11 = call @sa_time_instant_ns()
    db_sum_before_ns = sub t_sum11, t_sum10

    t_update0 = call @sa_time_instant_ns()
    EXPAND DB_UPDATE_U64_ADD update_status, updated_rows, ROOT, ROOT_LEN, TABLE, TABLE_LEN, 3, 0, ROWS, 5
    t_update1 = call @sa_time_instant_ns()
    db_update_all_ns = sub t_update1, t_update0

    t_sum20 = call @sa_time_instant_ns()
    EXPAND DB_OPEN_READ_TABLE open_after_status, read_handle_after, ROOT, ROOT_LEN, TABLE, TABLE_LEN
    EXPAND DB_SUM_U64_HANDLE sum_after_status, points_sum_after, read_handle_after, 3
    t_sum21 = call @sa_time_instant_ns()
    db_sum_after_ns = sub t_sum21, t_sum20

    t_count0 = call @sa_time_instant_ns()
    EXPAND DB_COUNT_U64_EQ_HANDLE count_status, plan_one_count, read_handle_after, 1, 1
    EXPAND DB_CLOSE_READ_TABLE close_after_status, read_handle_after
    t_count1 = call @sa_time_instant_ns()
    db_count_plan_one_ns = sub t_count1, t_count0

    t_compact0 = call @sa_time_instant_ns()
    EXPAND DB_COMPACT compact_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    t_compact1 = call @sa_time_instant_ns()
    db_compact_ns = sub t_compact1, t_compact0

    t_verify0 = call @sa_time_instant_ns()
    EXPAND DB_VERIFY verify_status, ROOT, ROOT_LEN, TABLE, TABLE_LEN, info
    t_verify1 = call @sa_time_instant_ns()
    db_verify_ns = sub t_verify1, t_verify0

    EXPAND PRINT_U64_LINE DB_CREATE, DB_CREATE_LEN, db_create_ns
    EXPAND PRINT_U64_LINE DB_PREP, DB_PREP_LEN, db_prepare_columns_ns
    EXPAND PRINT_U64_LINE DB_INSERT, DB_INSERT_LEN, db_insert_columns_ns
    EXPAND PRINT_U64_LINE DB_SUM1, DB_SUM1_LEN, db_sum_before_ns
    EXPAND PRINT_U64_LINE DB_UPDATE, DB_UPDATE_LEN, db_update_all_ns
    EXPAND PRINT_U64_LINE DB_SUM2, DB_SUM2_LEN, db_sum_after_ns
    EXPAND PRINT_U64_LINE DB_COUNT, DB_COUNT_LEN, db_count_plan_one_ns
    EXPAND PRINT_U64_LINE DB_COMPACT, DB_COMPACT_LEN, db_compact_ns
    EXPAND PRINT_U64_LINE DB_VERIFY, DB_VERIFY_LEN, db_verify_ns
    EXPAND PRINT_U64_LINE ROWS_LABEL, ROWS_LABEL_LEN, row_count
    EXPAND PRINT_U64_LINE SUM_BEFORE_LABEL, SUM_BEFORE_LABEL_LEN, points_sum_before
    EXPAND PRINT_U64_LINE SUM_AFTER_LABEL, SUM_AFTER_LABEL_LEN, points_sum_after
    EXPAND PRINT_U64_LINE PLAN_ONE_LABEL, PLAN_ONE_LABEL_LEN, plan_one_count
    EXPAND PRINT_U64_LINE UPDATED_LABEL, UPDATED_LABEL_LEN, updated_rows

    ok_remove = eq remove_status, SA_DB_OK
    ok_init = eq init_status, SA_DB_OK
    ok_ingest = eq ingest_status, SA_DB_OK
    ok_open_sum_status = eq open_sum_status, SA_DB_OK
    ok_sum_status = eq sum_status, SA_DB_OK
    ok_close_sum_status = eq close_sum_status, SA_DB_OK
    ok_update_status = eq update_status, SA_DB_OK
    ok_open_after_status = eq open_after_status, SA_DB_OK
    ok_sum_after_status = eq sum_after_status, SA_DB_OK
    ok_count_status = eq count_status, SA_DB_OK
    ok_close_after_status = eq close_after_status, SA_DB_OK
    ok_compact_status = eq compact_status, SA_DB_OK
    ok_verify_status = eq verify_status, SA_DB_OK
    ok_rows = eq row_count, ROWS
    ok_sum_before = eq points_sum_before, 12500250000
    ok_updated = eq updated_rows, ROWS
    ok_sum_after = eq points_sum_after, 12500500000
    ok_count = eq plan_one_count, 12500
    ok01 = and ok_remove, ok_init
    ok02 = and ok01, ok_ingest
    ok03 = and ok02, ok_open_sum_status
    ok04 = and ok03, ok_sum_status
    ok05 = and ok04, ok_close_sum_status
    ok06 = and ok05, ok_update_status
    ok07 = and ok06, ok_open_after_status
    ok08 = and ok07, ok_sum_after_status
    ok09 = and ok08, ok_count_status
    ok10 = and ok09, ok_close_after_status
    ok11 = and ok10, ok_compact_status
    ok12 = and ok11, ok_verify_status
    ok13 = and ok12, ok_rows
    ok14 = and ok13, ok_sum_before
    ok15 = and ok14, ok_updated
    ok16 = and ok15, ok_sum_after
    ok = and ok16, ok_count

    !remove_status
    !init_status
    !ingest_status
    !open_sum_status
    !read_handle_before
    !sum_status
    !close_sum_status
    !update_status
    !open_after_status
    !read_handle_after
    !sum_after_status
    !count_status
    !close_after_status
    !compact_status
    !verify_status
    !t_create0
    !t_create1
    !t_prep0
    !t_prep1
    !t_insert0
    !t_insert1
    !t_sum10
    !t_sum11
    !t_update0
    !t_update1
    !t_sum20
    !t_sum21
    !t_count0
    !t_count1
    !t_compact0
    !t_compact1
    !t_verify0
    !t_verify1
    !db_create_ns
    !db_prepare_columns_ns
    !db_insert_columns_ns
    !db_sum_before_ns
    !db_update_all_ns
    !db_sum_after_ns
    !db_count_plan_one_ns
    !db_compact_ns
    !db_verify_ns
    !row_count
    !points_sum_before
    !updated_rows
    !points_sum_after
    !plan_one_count
    !ok_remove
    !ok_init
    !ok_ingest
    !ok_open_sum_status
    !ok_sum_status
    !ok_close_sum_status
    !ok_update_status
    !ok_open_after_status
    !ok_sum_after_status
    !ok_count_status
    !ok_close_after_status
    !ok_compact_status
    !ok_verify_status
    !ok_rows
    !ok_sum_before
    !ok_updated
    !ok_sum_after
    !ok_count
    !ok01
    !ok02
    !ok03
    !ok04
    !ok05
    !ok06
    !ok07
    !ok08
    !ok09
    !ok10
    !ok11
    !ok12
    !ok13
    !ok14
    !ok15
    !ok16
    !id_col
    !plan_col
    !status_col
    !points_col
    br ok -> L_OK, L_FAIL

L_OK:
    !ok
    return 0

L_FAIL:
    !ok
    panic(9101)
